					}

					var nano_banana='';
					if(!$('.realism_switch_label').hasClass('enabled')) {
						nano_banana=1;
					}

					var auto_improve_prompt='';
					if($('.auto_improve_prompt_active').is(':checked')) {
						auto_improve_prompt=1;
					}

					var model_ids='';
					if(selectedModelIds.length>1) {
						model_ids=selectedModelIds;
					}

					var params={
						mode:'copycat',
						auto_improve_prompt:auto_improve_prompt,

						copycat_id:copycatUrl,
						copycat_url:copycatUrl,
						copycat_strength:$('.copycat_strength').val(),
						copycat_what:$('.copycat_what').val(),
						
						clothing_id:clothingUrl,
