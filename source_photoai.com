<!-- Import the component -->
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>

<script>
	
	
	// Global variable to store ElevenLabs voices
	var elevenLabsVoices = [];

	$(function() {

		// Load ElevenLabs voices on page load
		$.ajax({
			url: '/assets/tmp/elevenlabs_voices.json?' + Date.now(),
			dataType: 'json',
			success: function(data) {
				// Handle new wrapper format with 'voices' array
				elevenLabsVoices = data.voices || data;
				console.log('Loaded ' + elevenLabsVoices.length + ' ElevenLabs voices');
				// Initialize mocap voice selector from cookie after voices are loaded
				initMocapVoiceFromCookie();
			},
			error: function() {
				console.error('Error fetching ElevenLabs voices');
			}
		});

		$('.faq h4').bind('click',function() {
			$(this).toggleClass('expanded');
			$(this).next('div.answer').toggleClass('expanded');
		});
		
		var heroHeight=$('.hero').height();
		$(window).scroll(function() {
			$('.tooltip-ui').hide();
			if($(window).scrollTop()>heroHeight) {
				if(!$('.cta-box').hasClass('floating')) {
					$('.cta-box').addClass('floating');
				}
			} else {
				if($('.cta-box').hasClass('floating')) {
					$('.cta-box').removeClass('floating');
				}
			}
		});
		$('.tooltip').mouseenter(function() {

			if(isMobile) {
				return;
			}

			var $tooltip = $('.tooltip-ui');
			var rect = this.getBoundingClientRect();
			var leftPx = rect.left;
			var topPx;

			// Get tooltip content
			var tooltipUiText = $(this).data('tooltip');
			tooltipUiText = str_replace('*linebreak*', '<br/>', tooltipUiText);
			var tooltipImage = $(this).data('tooltip-image');

			// Inject content
			if (tooltipImage) {
				$tooltip.find('img')
					.attr('src', 'https://resizeapi.com/resize-cgi/image/format=jpeg,width=800,quality=75/' + tooltipImage)
					.show();
			} else {
				$tooltip.find('img').hide();
			}

			$tooltip.find('span').html(tooltipUiText);

			// Wait for DOM to update so dimensions are correct
			$tooltip.css({ visibility: 'hidden', display: 'block' }); // temporarily show to get size
			var tooltipWidth = $tooltip.outerWidth();
			var tooltipHeight = $tooltip.outerHeight();
			$tooltip.css({ visibility: '', display: 'none' }); // hide again until ready

			const margin = 4;

			// Prefer below the element
			topPx = rect.bottom + margin;

			// If not enough space below, show above
			if ((rect.bottom + tooltipHeight + margin) > window.innerHeight) {
				topPx = rect.top - tooltipHeight - margin;
			}

			// Horizontal adjustment
			if ((leftPx + tooltipWidth) > window.innerWidth) {
				leftPx = window.innerWidth - tooltipWidth - margin;
			}
			if (leftPx < margin) {
				leftPx = margin;
			}

			$tooltip.css({
				left: leftPx + 'px',
				top: topPx + 'px'
			});

			console.log('checkIfOutsideWindowBoxX=' + (leftPx + tooltipWidth));
			console.log('$(window).width()=' + $(window).width());

			$tooltip.show();
		});

		$('.tooltip').mouseleave(function() {
			$('.tooltip-ui').hide();
		});
	})

	// Initialize mocap voice selector from cookie (defined here so it's available when AJAX loads voices)
	function initMocapVoiceFromCookie() {
		if (!elevenLabsVoices || elevenLabsVoices.length === 0) return;

		var cookieVoiceId = getCookie('last_voice_id');
		if (cookieVoiceId) {
			for (var i = 0; i < elevenLabsVoices.length; i++) {
				if (elevenLabsVoices[i].id === cookieVoiceId) {
					var voice = elevenLabsVoices[i];
					$('.mocap_voice_selector').data('selected-voice', voice.id);

					var displayName = '';
					if (voice.language_emoji) displayName += voice.language_emoji + ' ';
					if (voice.emoji) displayName += voice.emoji + ' ';
					displayName += voice.name;

					$('.mocap_selected_voice').text(displayName);
					$('.mocap_voice_selector').addClass('selected');
					break;
				}
			}
		}
	}
</script>


	
