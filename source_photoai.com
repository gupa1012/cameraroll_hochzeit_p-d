				<div class="feature ai-marketing" id="ai-marketing">
					<h2>Create product videos with AI models</h2>
					<p>Create professional product videos and photos with AI models presenting your products. Upload a photo of your product and your AI model will hold it and present it. Perfect for TikTok ads, Instagram marketing, and e-commerce content. Scale infinitely without hiring human models: just upload your product, write your script, select an AI voice, add auto -captions if you want and let your AI models showcase your product.</p>
					
					<div class="marketing-videos-grid">
						<div class="phone-container">
						<img src="/assets/product-example-farm-box.jpg" class="product-example-image" alt="Farm box product">
							<video autoplay loop muted playsinline>
								<source src="https://r2-us-west.photoai.com/1757615122-edbda9dbd5a5186c55a85df798d08afe-1-captioned.mp4" type="video/mp4">
							</video>
						</div>
						
						<div class="phone-container">
							<img src="/assets/product-example-dino.jpg" class="product-example-image" alt="Dinosaur toy product">
							<video autoplay loop muted playsinline>
								<source src="https://r2-us-west.photoai.com/1757618445-62eca79ab8b671b977a42ab95f017f5e-1-captioned.mp4" type="video/mp4">
							</video>
						</div>
						
						<div class="phone-container">
							<img src="/assets/product-example-electrolux.jpg" class="product-example-image" alt="Electrolux appliance product">
							<video autoplay loop muted playsinline>
																<source src="https://r2-us-west.photoai.com/1757627627-098240a22758d47fe37d90cb0d54836e-1-captioned.mp4" type="video/mp4">
							</video>
						</div>
					</div>
				</div>
				
				<script>
					// Handle video sound on click
					document.addEventListener('DOMContentLoaded', function() {
						const phoneContainers = document.querySelectorAll('.feature.ai-marketing .phone-container');
						const marketingSection = document.querySelector('.feature.ai-marketing');
						
						phoneContainers.forEach(container => {
							container.style.cursor = 'pointer';
							
							container.addEventListener('click', function(e) {
								e.stopPropagation(); // Prevent event bubbling
								
								// Get all videos in the marketing section
								const allVideos = document.querySelectorAll('.feature.ai-marketing .phone-container video');
								const clickedVideo = this.querySelector('video');
								
								// Mute all videos first
								allVideos.forEach(video => {
									video.muted = true;
								});
								
								// Toggle the clicked video's mute state
								if (clickedVideo) {
									clickedVideo.muted = false;
									
									// Optional: Reset all container transforms, then apply to clicked one
									phoneContainers.forEach(pc => {
										// Reset to default transforms based on position
										const index = Array.from(phoneContainers).indexOf(pc);
										if (window.innerWidth >= 768) {
											if (index === 0) {
												pc.style.transform = 'perspective(1000px) rotateY(25deg) scale(0.82)';
											} else if (index === 1) {
												pc.style.transform = 'perspective(1000px) scale(0.82)';
											} else if (index === 2) {
												pc.style.transform = 'perspective(1000px) rotateY(-25deg) scale(0.82)';
											}
											pc.style.zIndex = '1';
										}
									});
									
									// Apply active transform to clicked container
									if (window.innerWidth >= 768) {
										this.style.transform = 'perspective(1000px) rotateY(0deg) scale(1.05)';
										this.style.zIndex = '20';
									}
								}
							});
						});
						
						// Click outside to mute all videos
						document.addEventListener('click', function(e) {
							// Check if click is outside the marketing section
							if (marketingSection && !marketingSection.contains(e.target)) {
								const allVideos = document.querySelectorAll('.feature.ai-marketing .phone-container video');
								
								// Mute all videos
								allVideos.forEach(video => {
									video.muted = true;
								});
								
								// Reset all container transforms to default
								phoneContainers.forEach(pc => {
									const index = Array.from(phoneContainers).indexOf(pc);
									if (window.innerWidth >= 768) {
										if (index === 0) {
											pc.style.transform = 'perspective(1000px) rotateY(25deg) scale(0.82)';
										} else if (index === 1) {
											pc.style.transform = 'perspective(1000px) scale(0.82)';
										} else if (index === 2) {
											pc.style.transform = 'perspective(1000px) rotateY(-25deg) scale(0.82)';
										}
										pc.style.zIndex = '1';
									}
								});
							}
						});
					});
				</script>



				
