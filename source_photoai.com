<script>
document.addEventListener('click', function(e) {
    if (!e.target.closest('.mobile-menu-btn') && !e.target.closest('.mobile-dropdown')) {
        var dd = document.querySelector('.mobile-dropdown');
        if (dd) dd.classList.remove('open');
    }
});
document.querySelectorAll('.packs-cat-link').forEach(function(link) {
    link.addEventListener('mouseenter', function() {
        var cat = this.dataset.cat;
        var mega = this.closest('.packs-mega-dropdown');
        mega.querySelectorAll('.packs-cat-link').forEach(function(l) { l.classList.remove('active'); });
        this.classList.add('active');
        var grid = mega.querySelector('.packs-grid');
        grid.classList.add('visible');
        var links = grid.querySelectorAll('a');
        var count = 0;
        links.forEach(function(a) {
            if (a.dataset.cat === cat) { a.style.display = ''; count++; }
            else { a.style.display = 'none'; }
        });
        var cols = Math.max(2, Math.ceil(count / 15));
        grid.style.setProperty('--dropdown-rows', Math.ceil(count / cols));
    });
});
</script>






