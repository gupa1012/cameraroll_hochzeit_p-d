		$('body').on('click','.action-copy-prompt',async function(event) {
			event.stopPropagation();

			// If sidebar is collapsed and floating prompt box is closed, open the sidebar
			if(document.documentElement.classList.contains('sidebar-collapsed') && $('.floating_prompt_box').hasClass('hidden')) {
				document.documentElement.classList.remove('sidebar-collapsed');
				try{localStorage.setItem('sidebar-collapsed','false')}catch(e){}
				var fp=document.querySelector('.floating_prompt_box');if(fp){fp.style.display='none'}
				var baseGc=parseInt(localStorage.getItem('grid-cols'))||5;
				document.documentElement.style.setProperty('--grid-cols',baseGc);
				document.documentElement.setAttribute('data-grid-cols',baseGc);
			}

			$('.select_mode').val('prompt').change();


			if(copycatId) {
				alert("FYI: you have a photo set under [ Remix a photo ], that will be used with your prompt. To remove the remix photo, press the trash icon under [ Remix a photo ].");
			}

			if($(this).parent().hasClass('image_viewer_buttons')) {
				// image viewer download button
				var photo_id=$('.image_viewer').data('photo-id');
				// close image viewer
				$('.image_viewer_backdrop').click();
			}
			else {
				// photo box hover download button
				var photo_id=$(this).parent().parent().data('photo-id');
			}

			// Close image viewer if triggered from sidebar/bottom bar
			if($('.image_viewer').data('sidebar-triggered')) {
				$('.image_viewer').data('sidebar-triggered', false);
				closeImageViewer();
			}

			var weHaveChangedTheModelForUser=false;

			var photo_model_id=$('.div_output_image.photo-'+photo_id).data('model-id');
			var photo_model_ids=$('.div_output_image.photo-'+photo_id).data('model-ids');


			if(selectedFolder!='examples') {
				// if example img, don't ask to change model
				// <auto select the model used for image>
					// when copy prompt, auto select the model used for image
					// because if you copycat a AI Valentina photo you don't
					// want AI Pieter to generate it
					if(selectedFolder!='examples') { /* don't ask if examples folder */
						if(photo_model_ids) {
							// Photo was generated with multiple models
							// jQuery's .data() auto-parses JSON, so it might already be an array
							var photoModelIdsArray = Array.isArray(photo_model_ids) ? photo_model_ids : JSON.parse(photo_model_ids);

							// Check if arrays match (same models selected)
							var arraysMatch = photoModelIdsArray.length === selectedModelIds.length &&
								photoModelIdsArray.every(function(id) { return selectedModelIds.includes(id); });

							if(!arraysMatch && photoModelIdsArray.length > 0) {
								var modelNames = photoModelIdsArray.map(function(id) {
									return $('.model_selector .model_sample[data-model-id="'+id+'"]').data('model-name') || id;
								}).join(' and ');

								if(confirm("This photo was made with models ["+modelNames+"], do you want to select those models?")) {
									// Deselect all current models and select the photo's models
									$('.model_sample.active').removeClass('active');
									photoModelIdsArray.forEach(function(id) {
										$('.model_sample[data-model-id="'+id+'"]').addClass('active');
									});
									// Set select value without triggering change (which would reset multi-select)
									selectModel(photoModelIdsArray[0], false);
									// Update thumbnails after selecting models
									updateModelThumbnails();
									weHaveChangedTheModelForUser=true;
								}
							}
						} else if(selectedModelIds[0]!=photo_model_id && !empty(photo_model_id)) {
							// Single model photo - original logic
							var modelName = $('.model_selector .model_sample[data-model-id="'+photo_model_id+'"]').data('model-name');
							if(modelName && photo_model_id) {
								if(confirm("Your current model selected is ["+$('.model_selector .model_sample.active').first().data('model-name')+"], do you want to change it to "+photo_model_id+" ["+modelName+"]?")) {
									selectModel(photo_model_id);
								}
							}
						}
					}
				// </auto select the model used for image>
			}


			// <get prompt data>
				var manual_prompt=$(this).parent().parent().data('manual-prompt');
				if(!manual_prompt) {
					// 2024-05-07 if no manual prompt data, because we are removing it
					// from main db, get it from the prompts db via ?action=get-prompt-data
					var promptData=await fetch('/?action=get-prompt-data&photo_id='+photo_id);
					var promptData=await promptData.json(); 
					var manual_prompt=promptData['manual_prompt'];
					var manual_negative_prompt=promptData['manual_negative_prompt'];
				}
				else {
					// get it from the data- attributes
					var manual_prompt=$(this).parent().parent().data('manual-prompt');
					var manual_negative_prompt=$(this).parent().parent().data('manual-negative-prompt');
				}

				// <copy prompt to clipboard>
					// 2025-05-04 this is actually annoying if you wanna copy prompts from one to the other
					// var promptText = manual_prompt;

					// navigator.clipboard.writeText(promptText)
					// 	.then(() => {
					// 		console.log("Prompt copied to clipboard "+promptText);
					// 	})
					// 	.catch((err) => {
					// 		console.error("Failed to copy prompt: ", err);
					// 	});
				// </copy prompt to clipboard>

				
				// fill textareas
				// if prompt is object (JSON parsed by jQuery), convert back to string
				if(typeof manual_prompt === 'object' && manual_prompt !== null) {
					manual_prompt = JSON.stringify(manual_prompt, null, 2);
				}
				if(typeof manual_negative_prompt === 'object' && manual_negative_prompt !== null) {
					manual_negative_prompt = JSON.stringify(manual_negative_prompt, null, 2);
				}
				$('textarea.manual_prompt').val(manual_prompt).change();
				$('textarea.manual_negative_prompt').val(manual_negative_prompt).change();

				var emotion=$(this).parent().parent().data('emotion');
				$('div.sidebar select.emotion').val(emotion);

				var model_strength=$(this).parent().parent().data('model-strength');

				if(model_strength) {
					$('div.sidebar input.model_strength').val(model_strength);
					updateModelStrengthRange();
				}

				var place=$(this).parent().parent().data('place');
				$('div.sidebar select.place').val(place).change();

				var camera=$(this).parent().parent().data('camera');
				$('div.sidebar select.camera').val(camera).change();

				var film=$(this).parent().parent().data('film');
				$('div.sidebar select.film').val(film).change();

				// <copy orientation>
				var $img = $(this).parent().parent().find('img.output_image');
				var imgW = parseInt($img.data('width')) || 0;
				var imgH = parseInt($img.data('height')) || 0;
				if(imgW && imgH) {
					var ratio = imgW / imgH;
					var orientation = 'portrait';
					if(ratio > 1.9) orientation = 'panorama';
					else if(ratio > 1.8) orientation = 'cinematic';
					else if(ratio > 1.6) orientation = '16:9';
					else if(ratio > 1.2) orientation = 'landscape';
					else if(ratio > 0.9) orientation = 'square';
					else if(ratio < 0.65) orientation = '9:16';
					else orientation = 'portrait';
					$('div.sidebar select.orientation').val(orientation).change();
				}
				// </copy orientation>

				var custom_lora_url = $(this).parent().parent().data('custom-lora-url');

				if(custom_lora_url) {
					
						console.log(custom_lora_url);

						$('div.sidebar input.custom_lora_url').val(custom_lora_url);

						var custom_lora_id = custom_lora_url.split('/').pop();

						if($(".civitai_model_selector .model_sample.civitai[data-model-version-id='" + custom_lora_id + "']").length) {
							// check if LoRa exists in Civitai selector
							$(".civitai_model_selector .model_sample.civitai[data-model-version-id='" + custom_lora_id + "']").click();

							console.log(".civitai_model_selector .model_sample.civitai[data-model-version-id='" + custom_lora_id + "']");

							$(".civitai_model_selector").animate({
								scrollTop: $(".civitai_model_selector .model_sample.civitai[data-model-version-id='" + custom_lora_id + "']").offset().top - $(".civitai_model_selector").offset().top + $(".civitai_model_selector").scrollTop()
							}, 500);
						}

									}


			// </get prompt data>

			
			$('.action-take-photo').addClass('blinking');

			// disable because we only want prompt copy not CARBON COPY root prompt, but less user enable it
			// $('div.sidebar .manual_seed_active').prop('checked',false).change();

			var seed=$(this).parent().parent().data('seed');
			$('input.manual_seed').val(seed).change();

			if($('div.sidebar .manual_seed_active').prop('checked')) {
				// if copying seed, and manual seed already active, don't run 16 photos for it, just make 1
				$('select.amount_of_photos').val('1').change();
			}

			// scroll up to model because we have changed the model
			if(weHaveChangedTheModelForUser) {
				if(isMobile) {
					$('html, body').animate({
						scrollTop: $('.sidebar .model_id').offset().top - 28
					}, 500);
				} else {
					$('.sidebar').animate({
						scrollTop:
						-$('.sidebar').offset().top+$('.sidebar').scrollTop()+$('.sidebar .model_id').offset().top-28
					},500);
				}
			}
			else {
				if(isMobile) {
					$('html, body').animate({
						scrollTop: $('.sidebar div.prompt_mode .h3_input').offset().top - 14
					}, 500);
				} else {
					$('.sidebar').animate({
						scrollTop:
						-$('.sidebar').offset().top+$('.sidebar').scrollTop()+$('.sidebar div.prompt_mode .h3_input').offset().top-14
					},500);
				}
			}

		});



		$('body').on('click','.action-carbon-copy',function(event) {
			event.stopPropagation();

			// If sidebar is collapsed and floating prompt box is closed, open the sidebar
			if(document.documentElement.classList.contains('sidebar-collapsed') && $('.floating_prompt_box').hasClass('hidden')) {
				document.documentElement.classList.remove('sidebar-collapsed');
				try{localStorage.setItem('sidebar-collapsed','false')}catch(e){}
				var fp=document.querySelector('.floating_prompt_box');if(fp){fp.style.display='none'}
				var baseGc=parseInt(localStorage.getItem('grid-cols'))||5;
				document.documentElement.style.setProperty('--grid-cols',baseGc);
				document.documentElement.setAttribute('data-grid-cols',baseGc);
			}

			
				if($('.image_viewer').is(':visible')) {
