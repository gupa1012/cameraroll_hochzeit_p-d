	<style>
		/* back-drop - styles in shared backdrop rule, just override z-index */
		.inpaint_editor_backdrop {
			z-index:9998;
		}
		

		/* modal */
		.inpaint_editor {
			display: none;
			position: fixed;
			margin: auto;
			left:50%;
			top:50%;
			transform:translateX(-50%) translateY(-50%);
			background: #121212;
			border-radius: 12px;
			box-shadow: 0 20px 40px rgba(0,0,0,0.5);
			padding: 28px;
			box-sizing: border-box;
			z-index: 10000;
			flex-direction: column;
			overflow: hidden;
		}

		/* canvas stack */
		.inpaint_editor_wrapper {
			margin:0 auto;
			position: relative;
			width: 100%;
			overflow:hidden;
			border-radius:12px;
		}
		.inpaint_canvas_container {
			position: absolute;
			width: 100%;
			height: 100%;
			top: 0;
		}
		
		.inpaint_editor_image {
			width: 100%;
			height: 100%;
			object-fit: contain;
		}

		.inpaint_editor_mask_canvas {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			cursor: crosshair;
			opacity: 0.8;
			// mix-blend-mode: screen;
			mix-blend-mode: normal;
			filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.3));
		}
		.inpaint_brush_cursor {
			position: absolute;
			pointer-events: none;
			border: 2px solid white;
			border-radius: 50%;
			opacity: 0.8;
			z-index: 10001;
			display: none;
			transform: translate(-50%, -50%);
			box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.5);
		}

		.inpaint_editor_controls {
			display: flex;
			flex-direction: column;
			gap: 10px;
			margin-top: 14px;
		}

		.inpaint_editor_slider {
			display: flex;
			align-items: center;
			gap: 10px;
			color: #fff;
			font-size: 14px;
		}

		#inpaint_editor_brush_size {
			flex: 1;
		}
		.inpaint_editor_brush_size_value {
			min-width:45px;
			text-align:right;
		}

		.inpaint_editor_tip {
			color: rgba(255,255,255,0.5);
			text-align: center;
			margin:0 auto;
			margin-top: 5px;
			max-width: 300px;
			word-wrap: break-word;
			line-height: 1.3;
		}
		.inpaint_editor_prompt {
			background: #1e1e1e;
			color: #fff;
			border: 1px solid #333;
			border-radius: 8px;
			padding: 10px;
			font-size: 16px; /* important for ios to not zoom in auto */
			resize: none;
			height: 80px;
			width: 100%;
			box-sizing: border-box;
			font-family: inherit;
			line-height: 1.4;
		}

		.button.action-inpaint-submit {
			line-height: 40px;
			padding: 0 16px;
			cursor: pointer;
			width: 100%;
			text-align: center;
		}
	</style>
	<script>
		$(function() {
			const inpaint_editor_$editor     = $('.inpaint_editor');
			const inpaint_editor_$backdrop   = $('.inpaint_editor_backdrop');
			const inpaint_editor_$img        = inpaint_editor_$editor.find('.inpaint_editor_image');
			const inpaint_editor_canvas      = inpaint_editor_$editor.find('.inpaint_editor_mask_canvas')[0];
			const inpaint_editor_ctx         = inpaint_editor_canvas.getContext('2d');

			// brush settings
			let inpaint_editor_brushSize = Math.max(8, Math.round(window.innerWidth / 80));
			const inpaint_editor_brushOpacity = 1;  // 0–1
			const inpaint_editor_brushBlur    = 4;    // px

			let inpaint_editor_drawing = false;
			let inpaint_editor_imgURL  = '';
			let inpaint_editor_photoID = '';
			
			// brush cursor
			const inpaint_editor_$brushCursor = $('.inpaint_brush_cursor');
			
			// Update brush cursor size
			const inpaint_editor_updateBrushCursor = () => {
				const size = inpaint_editor_brushSize * 2; // diameter
				inpaint_editor_$brushCursor.css({
					width: size + 'px',
					height: size + 'px'
				});
			};
			
			// Show/hide brush cursor
			const inpaint_editor_showBrushCursor = () => {
				inpaint_editor_$brushCursor.show();
			};
			
			const inpaint_editor_hideBrushCursor = () => {
				inpaint_editor_$brushCursor.hide();
			};
			
			// Move brush cursor to mouse position
			const inpaint_editor_moveBrushCursor = (e) => {
				const rect = inpaint_editor_canvas.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const y = e.clientY - rect.top;
				
				inpaint_editor_$brushCursor.css({
					left: x + 'px',
					top: y + 'px'
				});
			};
			
			// holographic animation
			let inpaint_editor_hueOffset = 0;
			let inpaint_editor_animationFrame = null;
			
			// Create off-screen canvas for mask storage
			const inpaint_editor_maskCanvas = document.createElement('canvas');
			const inpaint_editor_maskCtx = inpaint_editor_maskCanvas.getContext('2d');
			
			// Start continuous holographic animation
			const inpaint_editor_animateHologram = () => {
				// Only animate if editor is visible and has content
				if (inpaint_editor_$editor.is(':visible') && inpaint_editor_maskCanvas.width > 0) {
					const time = Date.now() * 0.002;
					
					// Clear main canvas
					inpaint_editor_ctx.clearRect(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
					
					// Create animated holographic gradient overlay
					const gradient = inpaint_editor_ctx.createLinearGradient(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
					const hue1 = (time * 50) % 360;
					const hue2 = (time * 50 + 60) % 360;
					const hue3 = (time * 50 + 120) % 360;
					const hue4 = (time * 50 + 180) % 360;
					const hue5 = (time * 50 + 240) % 360;
					
					gradient.addColorStop(0, `hsl(${hue1}, 100%, 80%)`);
					gradient.addColorStop(0.25, `hsl(${hue2}, 100%, 70%)`);
					gradient.addColorStop(0.5, `hsl(${hue3}, 100%, 75%)`);
					gradient.addColorStop(0.75, `hsl(${hue4}, 100%, 70%)`);
					gradient.addColorStop(1, `hsl(${hue5}, 100%, 80%)`);
					
					// Apply the holographic gradient only where the mask exists
					inpaint_editor_ctx.save();
					inpaint_editor_ctx.globalCompositeOperation = 'source-over';
					inpaint_editor_ctx.fillStyle = gradient;
					inpaint_editor_ctx.fillRect(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
					
					// Use the stored mask as an alpha mask
					inpaint_editor_ctx.globalCompositeOperation = 'destination-in';
					inpaint_editor_ctx.drawImage(inpaint_editor_maskCanvas, 0, 0);
					inpaint_editor_ctx.restore();
				}
				
				inpaint_editor_animationFrame = requestAnimationFrame(inpaint_editor_animateHologram);
			};
			
			// Helper function to close editor and stop animation
			const inpaint_editor_close = () => {
				if (inpaint_editor_animationFrame) {
					cancelAnimationFrame(inpaint_editor_animationFrame);
					inpaint_editor_animationFrame = null;
				}
				inpaint_editor_$backdrop.add(inpaint_editor_$editor).hide();
				inpaint_editor_hideBrushCursor();
				inpaint_editor_ctx.clearRect(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
				inpaint_editor_maskCtx.clearRect(0, 0, inpaint_editor_maskCanvas.width, inpaint_editor_maskCanvas.height);

			};

			$('#inpaint_editor_brush_size').val(inpaint_editor_brushSize);
			$('.inpaint_editor_brush_size_value').text(inpaint_editor_brushSize + 'px');

			$(window).on('resize', () => {
				const newBrushSize = Math.max(8, Math.round(window.innerWidth / 80));
				inpaint_editor_brushSize = newBrushSize;
				$('#inpaint_editor_brush_size').val(newBrushSize).trigger('input');
			});

			// handle brush size slider
			$('.inpaint_editor_brush_size').on('input', function () {
				inpaint_editor_brushSize = parseInt($(this).val(), 10);
				$('.inpaint_editor_brush_size_value').text(inpaint_editor_brushSize+'px');
				const percent = (this.value - this.min) / (this.max - this.min) * 100;
				this.style.background = 'linear-gradient(to right, #f47353 ' + percent + '%, #1e1e1e ' + percent + '%, #1e1e1e 100%)';
				// Update brush cursor size
				inpaint_editor_updateBrushCursor();
			});

			// init slider bg
			$('.inpaint_editor_brush_size').each(function () {
				const value = parseInt(this.value, 10);
				const percent = (value - this.min) / (this.max - this.min) * 100;
				this.style.background = 'linear-gradient(to right, #f47353 ' + percent + '%, #1e1e1e ' + percent + '%, #1e1e1e 100%)';
			});

			// open editor
			$('body').on('click', '.action-inpaint', function(event) {

				console.log('inpaint editor clicked');


				


				event.stopPropagation();
				const $card = $(this).closest('.div_output_image');
				inpaint_editor_imgURL  = $card.find('.output_image').data('src');
				inpaint_editor_photoID = $card.data('photo-id');

				// Close image viewer if triggered from sidebar/bottom bar
				if($('.image_viewer').data('sidebar-triggered')) {
					$('.image_viewer').data('sidebar-triggered', false);
					closeImageViewer();
				}

				// Get existing AI edit prompt if available
				const existingAiEditPrompt = $card.data('ai-edit-prompt') || '';

				// Check if this image has an existing inpaint mask
				// const existingMaskURL = $card.hasClass('inpaint') ? $card.data('inpaint-mask-url') : null;
				const existingMaskURL = null; // Always start with empty mask, even for already inpainted images
				console.log('Inpaint editor opening - Card has inpaint class:', $card.hasClass('inpaint'), 'Existing mask URL (disabled):', existingMaskURL);

				// Clear the previous image and any existing mask to prevent old content from showing
				inpaint_editor_$img.attr('src', '');
				inpaint_editor_ctx.clearRect(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
				inpaint_editor_maskCtx.clearRect(0, 0, inpaint_editor_maskCanvas.width, inpaint_editor_maskCanvas.height);
				
				inpaint_editor_$img
					.attr('src', inpaint_editor_imgURL)
					.one('load', function(){
						// natural image size
						const iw = this.naturalWidth;
						const ih = this.naturalHeight;

						// max available space (N% of viewport)
						let maxW = window.innerWidth  * 0.65;
						let maxH = window.innerHeight * 0.65;

						if(isMobile) {
							maxW = window.innerWidth  * 0.9;
							maxH = window.innerHeight * 0.9;
						}

						// compute scaled dimensions
						let w = iw, h = ih;
						if (w > maxW) { let s = maxW / w; w = maxW; h = h * s; }
						if (h > maxH) { let s = maxH / h; h = maxH; w = w * s; }

						// size the canvas
						// Resize editor wrapper (image container)
						inpaint_editor_$editor.find('.inpaint_editor_wrapper').css({
							width: w + 'px',
							height: h + 'px'
						});

						// Resize canvas and image
						inpaint_editor_$img.css({ width: w + 'px', height: h + 'px' });
						inpaint_editor_canvas.width  = w;
						inpaint_editor_canvas.height = h;
						inpaint_editor_ctx.clearRect(0, 0, w, h);
						
						// Setup off-screen mask canvas
						inpaint_editor_maskCanvas.width = w;
						inpaint_editor_maskCanvas.height = h;
						inpaint_editor_maskCtx.clearRect(0, 0, w, h);
						
						// Load existing mask if available
						if (existingMaskURL) {
							console.log('Loading existing mask:', existingMaskURL);
							const maskImg = new Image();
							maskImg.crossOrigin = 'anonymous';
							maskImg.onload = function() {
								console.log('Mask loaded successfully, processing mask');
								// Create temporary canvas to process the mask
								const tempCanvas = document.createElement('canvas');
								const tempCtx = tempCanvas.getContext('2d');
								tempCanvas.width = w;
								tempCanvas.height = h;
								
								// Scale mask from original image size to current display size
								// Mask was created at natural image size (iw, ih)
								// Canvas is now scaled to display size (w, h)
								tempCtx.drawImage(maskImg, 0, 0, iw, ih, 0, 0, w, h);
								
								// Get image data to process pixel by pixel
								const imageData = tempCtx.getImageData(0, 0, w, h);
								const data = imageData.data;
								
								// Process each pixel - convert white pixels to brush strokes
								for (let i = 0; i < data.length; i += 4) {
									const r = data[i];
									const g = data[i + 1];
									const b = data[i + 2];
									
									// Check if pixel is white (masked area)
									if (r > 200 && g > 200 && b > 200) {
										// Convert to brush stroke (white on visible canvas, black on mask canvas)
										const x = (i / 4) % w;
										const y = Math.floor((i / 4) / w);
										
										// Draw brush stroke on visible canvas
										inpaint_editor_ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
										inpaint_editor_ctx.fillRect(x, y, 1, 1);
										
										// Mark on mask canvas  
										inpaint_editor_maskCtx.fillStyle = 'black';
										inpaint_editor_maskCtx.fillRect(x, y, 1, 1);
									}
								}
								console.log('Mask processing completed');
							};
							maskImg.onerror = function() {
								console.error('Failed to load existing mask:', existingMaskURL);
							};
							maskImg.src = existingMaskURL;
						}
					});

				inpaint_editor_$backdrop.add(inpaint_editor_$editor).show();
				
				// Update the currently selected model name when opening the inpaint editor
				var selectedModelName = $('.model_selector .model_sample.active').first().data('model-name');
				if(selectedModelName && selectedModelName !== 'Select a model' && selectedModelName !== 'Train your own') {
					$('.currentlySelectedModelName').text(selectedModelName);
				} else {
					$('.currentlySelectedModelName').text('(no model selected)');
				}
				
				// Initialize brush cursor
				inpaint_editor_updateBrushCursor();
				
				// Prefill prompt with existing AI edit prompt if available
				if (existingAiEditPrompt) {
					$('.inpaint_editor_prompt').val(existingAiEditPrompt);
				} else {
					$('.inpaint_editor_prompt').val('');
				}

				// Focus on prompt input if not mobile, and select all if there's existing text
				if ($(window).width() >= 800) {
					setTimeout(() => {
						$('.inpaint_editor_prompt').focus();
						if (existingAiEditPrompt) {
							$('.inpaint_editor_prompt').select();
						}
					}, 100);
				}
				
				// Start holographic animation
				if (inpaint_editor_animationFrame) {
					cancelAnimationFrame(inpaint_editor_animationFrame);
				}
				inpaint_editor_animateHologram();
			});

			// draw handler (mouse + touch)
			const inpaint_editor_draw = e => {
				if (!inpaint_editor_drawing) return;

				const rect = inpaint_editor_canvas.getBoundingClientRect();
				const evt  = e.touches ? e.touches[0] : e;
				const x    = evt.clientX - rect.left;
				const y    = evt.clientY - rect.top;

				// Draw to the mask canvas (white brush for mask data)
				inpaint_editor_maskCtx.save();
				inpaint_editor_maskCtx.globalAlpha = inpaint_editor_brushOpacity;
				inpaint_editor_maskCtx.filter = `blur(${inpaint_editor_brushBlur}px)`;
				inpaint_editor_maskCtx.fillStyle = '#fff';
				inpaint_editor_maskCtx.beginPath();
				inpaint_editor_maskCtx.arc(x, y, inpaint_editor_brushSize, 0, Math.PI * 2);
				inpaint_editor_maskCtx.fill();
				inpaint_editor_maskCtx.restore();
			};

			// bind drawing events
			inpaint_editor_canvas.addEventListener('mousedown',  e => { inpaint_editor_drawing = true;  inpaint_editor_draw(e); });
			inpaint_editor_canvas.addEventListener('mousemove',  e => { 
				inpaint_editor_draw(e); 
				inpaint_editor_moveBrushCursor(e); 
			});
			inpaint_editor_canvas.addEventListener('mouseup',    () => { inpaint_editor_drawing = false; });
			inpaint_editor_canvas.addEventListener('mouseleave', () => { 
				inpaint_editor_drawing = false; 
				// inpaint_editor_hideBrushCursor(); 
			});
			inpaint_editor_canvas.addEventListener('mouseenter', inpaint_editor_showBrushCursor);
			
			inpaint_editor_canvas.addEventListener('touchstart', e => {
				inpaint_editor_drawing = true;
				inpaint_editor_draw(e);
				e.preventDefault(); // <- prevent scroll start
			}, { passive: false });

			inpaint_editor_canvas.addEventListener('touchmove', e => {
				inpaint_editor_draw(e);
				e.preventDefault(); // <- prevent scroll while dragging
			}, { passive: false });

			inpaint_editor_canvas.addEventListener('touchend',   () => { inpaint_editor_drawing = false; },           { passive: false });

			inpaint_editor_prompt = $('.inpaint_editor_prompt');

			// handle resize
			$(window).on('resize', () => {
				if (!inpaint_editor_imgURL) return;
				inpaint_editor_canvas.width  = inpaint_editor_$img[0].clientWidth;
				inpaint_editor_canvas.height = inpaint_editor_$img[0].clientHeight;
			});

			// submit mask
			$('body').on('click', '.action-inpaint-submit', function() {
				flash();
				
				// Convert mask to pure black and white using the mask canvas
				const imgData = inpaint_editor_maskCtx.getImageData(0, 0, inpaint_editor_maskCanvas.width, inpaint_editor_maskCanvas.height);
				const data = imgData.data;
				for (let i = 0; i < data.length; i += 4) {
					const alpha = data[i + 3]; // opacity
					const isMarked = alpha > 0;
					data[i] = data[i + 1] = data[i + 2] = isMarked ? 255 : 0; // white or black
					data[i + 3] = 255; // full opacity
				}

				
				// <resize mask to exact same image size as original image>
					// Step 1: create a temp canvas with image's natural size
					const naturalW = inpaint_editor_$img[0].naturalWidth;
					const naturalH = inpaint_editor_$img[0].naturalHeight;

					const tmpCanvas = document.createElement('canvas');
					tmpCanvas.width = naturalW;
					tmpCanvas.height = naturalH;
					const tmpCtx = tmpCanvas.getContext('2d');

					// Step 2: scale mask canvas onto tmpCanvas
					tmpCtx.drawImage(inpaint_editor_maskCanvas, 0, 0, naturalW, naturalH);

					// Step 3: convert that to pure black and white
					const tmpImgData = tmpCtx.getImageData(0, 0, naturalW, naturalH);
					const tmpData = tmpImgData.data;
					for (let i = 0; i < tmpData.length; i += 4) {
						const alpha = tmpData[i + 3];
						const isMarked = alpha > 0;
						tmpData[i] = tmpData[i + 1] = tmpData[i + 2] = isMarked ? 255 : 0;
						tmpData[i + 3] = 255;
					}
					tmpCtx.putImageData(tmpImgData, 0, 0);

					// Step 4: final output
					const inpaint_mask_data = tmpCanvas.toDataURL('image/png');
				// </resize mask to exact same image size as original image>

				// Check if mask is empty (no pixels drawn)
				let hasMask = false;
				for (let i = 0; i < tmpData.length; i += 4) {
					if (tmpData[i] > 0 || tmpData[i + 1] > 0 || tmpData[i + 2] > 0) {
						hasMask = true;
						break;
					}
				}

				console.log("Submitting to server - has mask:", hasMask);

				// use the currently selected model for inpainting/edit
				var inpaint_model_id=currentModelId;
				var inpaint_model_strength=$('input.model_strength').val();

				var photo_url=inpaint_editor_imgURL;
				var inpaint_prompt=inpaint_editor_prompt.val();
				if(!inpaint_prompt) {
					// make it ' ' so it will be used as a remover
					inpaint_prompt=' ';
				}

				// clear and close inpaint editor
				inpaint_editor_close();
				$('.inpaint_editor_prompt').val('');
				
				$('html').addClass('taking-photos');

				// <add preliminary placeholders for image>					
					var i=0;

					// preliminaryId is used to replace/remove the preliminary photo box after getting the AJAX back
					var preliminaryId='preliminary_id_'+Math.floor(Math.random() * 1000);

					var photo={};
					photo['status']='preliminary';
					photo['photo_url']=inpaint_editor_imgURL;
					photo['width']=inpaint_editor_$img[0].naturalWidth;
					photo['height']=inpaint_editor_$img[0].naturalHeight;

					var html=makePhotoBox(photo,null,null,preliminaryId);

					// add one
					$('.div_output_images.camera').prepend(
						html
					);
				// </add preliminary placeholder for image>


				if(
					selectedFolder!='camera'
				) {
					//
					// if we are not in the camera folder
					// and user upscales
					// glow the top_folder_selector of camera
					// so user knows the upscale will run there
					//
					// for @johnonolan
					//
					setTimeout(function() {
						$('.top_folder_selector h3[data-folder="camera"]').addClass('blinking');
						$('.top_folder_selector h3[data-folder="camera"]').addClass('glow');
						setTimeout(function() {
							$('.top_folder_selector h3[data-folder="camera"]').removeClass('glow');
						},500);
					},500);
				}


				
				// Route to appropriate action based on mask presence
				const actionType = hasMask ? 'inpaint' : 'ai-edit';
				const ajaxData = hasMask ? {
					action: 'inpaint',
					inpaint_prompt: inpaint_prompt,
					original_photo_id: inpaint_editor_photoID,
					inpaint_mask_data: inpaint_mask_data,
					model_id: inpaint_model_id,
					model_strength: inpaint_model_strength
				} : {
					action: 'ai-edit',
					ai_edit_prompt: inpaint_prompt,
					original_photo_id: inpaint_editor_photoID,
					model_id: inpaint_model_id,
					model_strength: inpaint_model_strength
				};

				$.ajax({
					url: '/?action=' + actionType + '',
					type: 'POST',
					data: ajaxData,
					dataType:'json',
				}).done(function(reply) {

					// <remove preliminary placeholders>
						$('.div_output_images .div_output_image.preliminary.'+preliminaryId).remove();
					// </remove preliminary placeholders>

					if(!reply.success) {
						if(reply.error=='out_of_credits') {
							// alert("⚡️ You're out of credits. Upgrade now to get more credits and continue editing your photos with AI.");
							// window.location.href='https://photoai.com/upgrade';
							window.location.reload();
							return;
						}
						alert(reply.message);
						return;
					}

					photo=reply.photos[0];
					console.log(photo);

					// hack to show the image as a placeholder
					// photo['upscaled']=1;
					
					// it should be postprocessing so it shows the original pic (hack)
					photo['status']='postprocessing';

					photo['preprocessed_photo_url']=photo_url;
					photo['original_photo_url']=photo_url;

					var html=makePhotoBox(photo);

					// add one
					$('.div_output_images.camera').prepend(
						html
					);

					// <start poller for each image>
						loadingSpinnerStep(photo['photo_id']);
						setTimeout(waitForServerToGenerate,(pollIntervalTime*2*Math.random()),photo['photo_id'],'poll_for_preprocessed');
					// </start poller for each image>


						
				});
			});

			// submit on Enter in textarea (without Shift)
			inpaint_editor_prompt.on('keydown', function(e) {
				if (e.key === 'Enter' && !e.shiftKey) {
					e.preventDefault();
					$('.action-inpaint-submit').click();
				}
			});

			// close on backdrop, cancel button, or Esc
			inpaint_editor_$backdrop.on('click', () => {
				inpaint_editor_close();
			});
			$('.action-inpaint-cancel').on('click', () => {
				inpaint_editor_close();
			});
			$('.action-inpaint-clear').on('click', () => {
				// Clear both canvases
				inpaint_editor_ctx.clearRect(0, 0, inpaint_editor_canvas.width, inpaint_editor_canvas.height);
				inpaint_editor_maskCtx.clearRect(0, 0, inpaint_editor_maskCanvas.width, inpaint_editor_maskCanvas.height);
			});
			$(document).on('keyup', e => {
				if (e.key === 'Escape') {
					inpaint_editor_close();
				}
			});
			
		});
	</script>
	<div class="inpaint_editor_backdrop"></div>
	<div class="inpaint_editor">
		<div class="inpaint_editor_wrapper">
			<img class="inpaint_editor_image" src="">
			<div class="inpaint_canvas_container">
				<canvas class="inpaint_editor_mask_canvas"></canvas>
				<div class="inpaint_brush_cursor"></div>
			</div>
		</div>
		<div class="inpaint_editor_controls">
			<div class="inpaint_editor_slider">
				<label for="inpaint_editor_brush_size">Brush size</label>
				<input type="range" class="inpaint_editor_brush_size" id="inpaint_editor_brush_size" min="5" max="100" value="50" />
				<label class="inpaint_editor_brush_size_value">50px</label>
			</div>
			<textarea class="inpaint_editor_prompt" placeholder="What do you want to replace or change? Brush and leave this prompt blank to remove an object. To replace people, select their model, brush them out and use &quot;model&quot; as prompt..."></textarea>
			<div class="button gradient action-inpaint-submit">Magic edit</div>
			<div class="button reverse action-inpaint-cancel">Cancel</div>
						<p class="subline" style="margin:0;text-align:center;">
				One magic edit costs 5 credits.<br/>
				Your currently selected model <span style="max-width: 100px; display: inline-block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; vertical-align: bottom; margin-bottom: -1px;" class="currentlySelectedModelName"></span> is used for edits.<br/>
				To replace people, select their model, brush them out and use "model" as prompt.
			</p>
		</div>
	</div>




	<style>
		/* backdrop styles in shared rule, just override z-index */
		.crop_editor_backdrop {
			z-index: 9998;
		}

		.crop_editor,
		.crop_editor * {
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
		}

		.crop_editor {
			display: none;
			position: fixed;
			left: 50%;
			top: 50%;
			transform: translate(-50%, -50%);
			background: #121212;
			border-radius: 12px;
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
			padding: 28px;
			z-index: 10000;
			overflow: hidden;
			flex-direction: column;
		}
		.crop_editor_overlay {
			position: absolute;
			background: rgba(0, 0, 0, 0.6);
			pointer-events: none;
			z-index: 10;
			box-sizing: border-box;
			transform: translateZ(0); /* ADD THIS to force GPU rendering, prevents seam artifacts */
		}

		.crop_editor_overlay.top,
		.crop_editor_overlay.bottom {
			left: 0;
			width: 100%;
		}

		.crop_editor_overlay.left,
		.crop_editor_overlay.right {
			top: 0;
			height: 100%;
		}
		.crop_editor_wrapper {
			position: relative;
			overflow: hidden;
		}

		.crop_editor_image {
			pointer-events: none;
			user-drag: none;
			-webkit-user-drag: none;
			transform-origin: center center;
			transition: none;
		}

		.crop_editor_crop_area {
			position: absolute;
			border: 1px solid #4da6ff;
			cursor: move;
			box-sizing: border-box;
		}

		.crop_handle {
			position: absolute;
			width: 8px;
			height: 8px;
			background: white;
			border: 1px solid #4da6ff;
			box-shadow: 0 0 2px rgba(0,0,0,0.4);
			border-radius: 0;
			z-index: 11;
		}

		.crop_handle.nw { top: -6px; left: -6px; cursor: nwse-resize; }
		.crop_handle.ne { top: -6px; right: -6px; cursor: nesw-resize; }
		.crop_handle.sw { bottom: -6px; left: -6px; cursor: nesw-resize; }
		.crop_handle.se { bottom: -6px; right: -6px; cursor: nwse-resize; }
		.crop_handle.n { top: -6px; left: 50%; transform: translateX(-50%); cursor: ns-resize; }
		.crop_handle.s { bottom: -6px; left: 50%; transform: translateX(-50%); cursor: ns-resize; }
		.crop_handle.e { right: -6px; top: 50%; transform: translateY(-50%); cursor: ew-resize; }
		.crop_handle.w { left: -6px; top: 50%; transform: translateY(-50%); cursor: ew-resize; }

		@media (max-width: 600px) {
			.crop_handle {
				width: 16px;
				height: 16px;
			}

			.crop_handle.nw { top: -8px; left: -8px; }
			.crop_handle.ne { top: -8px; right: -8px; }
			.crop_handle.sw { bottom: -8px; left: -8px; }
			.crop_handle.se { bottom: -8px; right: -8px; }
			.crop_handle.n  { top: -8px; left: 50%; transform: translateX(-50%); }
			.crop_handle.s  { bottom: -8px; left: 50%; transform: translateX(-50%); }
			.crop_handle.e  { right: -8px; top: 50%; transform: translateY(-50%); }
			.crop_handle.w  { left: -8px; top: 50%; transform: translateY(-50%); }
		}

		.crop_editor_controls {
			margin-top: 14px;
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		.button.action-crop-submit {
			height: 40px;
			line-height: 40px;
			padding: 0 16px;
			cursor: pointer;
			border-radius: 8px;
			border: none;
			text-align: center;
			width:100%;
		}

		.crop_aspect_ratio_buttons {
			display: flex;
			gap: 8px;
			justify-content: center;
			margin-top: 8px;
		}

		.button.action-crop-aspect-ratio {
			padding: 7px;
			cursor: pointer;
			border-radius: 6px;
			border: 1px solid #333;
			background: transparent;
			color: #fff;
			text-align: center;
			font-size: 12px;
			min-width: 50px;
		}

		.button.action-crop-aspect-ratio:hover {
			background: #333;
		}

		.button.action-crop-aspect-ratio.active {
			background: #444;
			border-color: #555;
		}
	</style>

	<div class="crop_editor_backdrop"></div>
	<div class="crop_editor">
	<div class="crop_editor_wrapper">
		<img class="crop_editor_image" src="">
		<div class="crop_editor_overlay top"></div>
		<div class="crop_editor_overlay bottom"></div>
		<div class="crop_editor_overlay left"></div>
		<div class="crop_editor_overlay right"></div>
		<div class="crop_editor_crop_area">
		<div class="crop_handle nw"></div>
		<div class="crop_handle ne"></div>
		<div class="crop_handle sw"></div>
		<div class="crop_handle se"></div>
		<div class="crop_handle n"></div>
		<div class="crop_handle s"></div>
		<div class="crop_handle e"></div>
		<div class="crop_handle w"></div>
		</div>
	</div>
	<div class="crop_editor_controls">
		<div class="button gradient action-crop-submit">Crop</div>
		<div class="button reverse action-crop-cancel">Cancel</div>
		<p class="subline" style="margin-top:0px;text-align:center;">
			One crop costs 1 credit		</p>
		<div class="crop_aspect_ratio_buttons">
			<div class="button action-crop-aspect-ratio" data-ratio="3:4">3:4</div>
			<div class="button action-crop-aspect-ratio" data-ratio="9:16">9:16</div>
			<div class="button action-crop-aspect-ratio" data-ratio="1:1">1:1</div>
			<div class="button action-crop-aspect-ratio" data-ratio="4:3">4:3</div>
			<div class="button action-crop-aspect-ratio" data-ratio="16:9">16:9</div>
		</div>
	</div>
	</div>

	<script>
		$(function(){
			const $editor = $('.crop_editor');
			const $backdrop = $('.crop_editor_backdrop');
			const $img = $('.crop_editor_image');
			const $crop = $('.crop_editor_crop_area');
			const $wrapper = $('.crop_editor_wrapper');

			let isDragging = false;
			let isResizing = false;
			let isPanning = false;
			let startX, startY;
			let startLeft, startTop, startWidth, startHeight;
			let currentHandle = '';
			
			// Zoom and pan state
			let zoomLevel = 1;
			let panX = 0;
			let panY = 0;
			let minZoom = 0.5;
			let maxZoom = 3;
			let imageNaturalWidth = 0;
			let imageNaturalHeight = 0;
			let imageDisplayWidth = 0;
			let imageDisplayHeight = 0;

			// Apply zoom and pan transforms to image
			function applyImageTransform() {
				const transform = `scale(${zoomLevel}) translate(${panX}px, ${panY}px)`;
				$img.css('transform', transform);
				updateOverlayMask();
			}

			// Handle zoom with constraints
			function setZoom(newZoom, centerX = null, centerY = null) {
				const oldZoom = zoomLevel;
				zoomLevel = Math.max(minZoom, Math.min(maxZoom, newZoom));
				
				// If zoom actually changed and we have center coordinates, adjust pan
				if (zoomLevel !== oldZoom && centerX !== null && centerY !== null) {
					const zoomRatio = zoomLevel / oldZoom;
					const rect = $img[0].getBoundingClientRect();
					const imgCenterX = rect.left + rect.width / 2;
					const imgCenterY = rect.top + rect.height / 2;
					
					// Adjust pan to zoom towards the center point
					const deltaX = (centerX - imgCenterX) * (zoomRatio - 1) / zoomLevel;
					const deltaY = (centerY - imgCenterY) * (zoomRatio - 1) / zoomLevel;
					
					panX -= deltaX;
					panY -= deltaY;
					
					// Apply pan constraints
					constrainPan();
				}
				
				applyImageTransform();
			}

			// Constrain pan to keep image visible within wrapper bounds
			function constrainPan() {
				const wrapperW = $wrapper[0].clientWidth;
				const wrapperH = $wrapper[0].clientHeight;
				
				// Calculate how much larger the zoomed image is than the wrapper
				const scaledImageW = imageDisplayWidth * zoomLevel;
				const scaledImageH = imageDisplayHeight * zoomLevel;
				
				// Maximum pan distance is when image edge aligns with wrapper edge
				const maxPanX = Math.max(0, (scaledImageW - wrapperW) / 2 / zoomLevel);
				const maxPanY = Math.max(0, (scaledImageH - wrapperH) / 2 / zoomLevel);
				
				panX = Math.max(-maxPanX, Math.min(maxPanX, panX));
				panY = Math.max(-maxPanY, Math.min(maxPanY, panY));
			}

			// INIT crop box after image load
			function initCropBox() {
				const iw = $img[0].clientWidth;
				const ih = $img[0].clientHeight;
				const wrapperW = $wrapper[0].clientWidth;
				const wrapperH = $wrapper[0].clientHeight;
				
				// Store image dimensions for pan constraints
				imageDisplayWidth = iw;
				imageDisplayHeight = ih;
				imageNaturalWidth = $img[0].naturalWidth;
				imageNaturalHeight = $img[0].naturalHeight;
				
				// Calculate minimum zoom to ensure image always fills wrapper
				// The image should never be smaller than the wrapper
				const minZoomX = wrapperW / iw;
				const minZoomY = wrapperH / ih;
				minZoom = Math.max(minZoomX, minZoomY, 1.0); // Never zoom out beyond 1:1
				
				// Reset zoom and pan
				zoomLevel = minZoom;
				panX = 0;
				panY = 0;
				applyImageTransform();
				
				// same as in zoom-out
				const w = iw * 0.71;
				const h = ih * 0.71;
				
				const x = (iw - w) / 2;
				const y = (ih - h) / 2;
				$crop.css({ left: x, top: y, width: w, height: h });
				updateOverlayMask();
			}

			$backdrop.on('click', () => {
				$backdrop.add($editor).hide();
			});
			$('.action-crop-cancel').on('click', () => {
				$backdrop.add($editor).hide();
			});

			// Lazy load video function
			function lazyLoadVideo($container) {
				var $placeholder = $container.find('.video-lazy-placeholder');

				// If already converted to video, skip
				if($placeholder.length === 0 || $container.data('video-loaded')) return;

				// Get all stored video attributes
				var videoSrc = $placeholder.data('video-src');
				var videoAutoplay = $placeholder.data('video-autoplay');
				var videoPoster = $placeholder.data('video-poster');
				var videoLazyLoading = $placeholder.data('video-lazy-loading') || '';
				var originalPhotoUrl = $placeholder.data('original-photo-url');
				var videoWidth = $placeholder.data('width');
				var videoHeight = $placeholder.data('height');
				var dataSrc = $placeholder.data('src');
				var preprocessedSrc = $placeholder.data('preprocessed-src');

				// Build attributes
				var originalPhotoUrlAttr = originalPhotoUrl ? ' data-original-photo-url="'+originalPhotoUrl+'"' : '';
				var dataSrcAttr = dataSrc ? ' data-src="'+dataSrc+'"' : '';
				var preprocessedSrcAttr = preprocessedSrc ? ' data-preprocessed-src="'+preprocessedSrc+'"' : '';

				// Create the exact same video element that would have been rendered originally (in normal flow)
				var videoHTML = '<video crossorigin="anonymous" '+(videoAutoplay ? videoAutoplay : '')+' playsinline loop muted preload="none" poster="'+videoPoster+'" type="video/mp4" '+videoLazyLoading+originalPhotoUrlAttr+' data-width="'+videoWidth+'" data-height="'+videoHeight+'" width="'+videoWidth+'" height="'+videoHeight+'" class="output_image" '+dataSrcAttr+' '+preprocessedSrcAttr+' src="'+videoSrc+'"></video>';

				// Insert video BEFORE placeholder (so video is in normal flow)
				$placeholder.before(videoHTML);
				$container.data('video-loaded', true);

				// Position placeholder absolutely over the video and fade it out
				$placeholder.addClass('positioned-over-video fading-out');

				// Remove placeholder after fade completes
				setTimeout(function() {
					$placeholder.remove();
				}, 300); // Match CSS transition duration
			}

			// Lazy load videos on hover
			$(document).on('mouseenter', '.div_output_image.video', function() {
				lazyLoadVideo($(this));
			});

			// Also lazy load when clicking action buttons (view, download, etc)
			$(document).on('click', '.div_output_image.video .action-view-image, .div_output_image.video .action-download-image', function() {
				lazyLoadVideo($(this).closest('.div_output_image.video'));
			});

			// Aspect ratio buttons handler (using event delegation)
			$(document).on('click', '.action-crop-aspect-ratio', function() {
				const ratio = $(this).data('ratio');
				const [widthRatio, heightRatio] = ratio.split(':').map(Number);
				
				// Remove active class from all buttons and add to clicked one
				$('.action-crop-aspect-ratio').removeClass('active');
				$(this).addClass('active');
				
				// Get image dimensions
				const imageWidth = $img[0].clientWidth;
				const imageHeight = $img[0].clientHeight;
				
				// Calculate aspect ratio
				const aspectRatio = widthRatio / heightRatio;
				
				// Calculate new crop dimensions centered on current crop area
				const currentCropRect = $crop[0].getBoundingClientRect();
				const imageRect = $img[0].getBoundingClientRect();
				
				// Get current center point relative to image
				const currentCenterX = (currentCropRect.left + currentCropRect.width / 2) - imageRect.left;
				const currentCenterY = (currentCropRect.top + currentCropRect.height / 2) - imageRect.top;
				
				let newWidth, newHeight;
				
				// Try to maintain current crop area size when possible
				const currentWidth = currentCropRect.width || imageWidth * 0.6;
				const currentHeight = currentCropRect.height || imageHeight * 0.6;
				
				// Calculate what the dimensions would be if we maintained current width
				const heightFromWidth = currentWidth / aspectRatio;
				// Calculate what the dimensions would be if we maintained current height  
				const widthFromHeight = currentHeight * aspectRatio;
				
				// Choose the option that fits within the image bounds and is closest to current size
				if (heightFromWidth <= imageHeight && widthFromHeight <= imageWidth) {
					// Both options fit, choose the larger one to maintain crop area
					if (currentWidth * heightFromWidth >= currentHeight * widthFromHeight) {
						newWidth = currentWidth;
						newHeight = heightFromWidth;
					} else {
						newWidth = widthFromHeight;
						newHeight = currentHeight;
					}
				} else if (heightFromWidth <= imageHeight) {
					// Only width-based option fits
					newWidth = currentWidth;
					newHeight = heightFromWidth;
				} else if (widthFromHeight <= imageWidth) {
					// Only height-based option fits
					newWidth = widthFromHeight;
					newHeight = currentHeight;
				} else {
					// Neither fits, constrain to image bounds
					if (imageWidth / imageHeight > aspectRatio) {
						// Image is wider, constrain by height
						newHeight = imageHeight * 0.8;
						newWidth = newHeight * aspectRatio;
					} else {
						// Image is taller, constrain by width
						newWidth = imageWidth * 0.8;
						newHeight = newWidth / aspectRatio;
					}
				}
				
				// Calculate new position (centered)
				const newLeft = Math.max(0, Math.min(imageWidth - newWidth, currentCenterX - newWidth / 2));
				const newTop = Math.max(0, Math.min(imageHeight - newHeight, currentCenterY - newHeight / 2));
				
				// Apply new dimensions and position
				$crop.css({
					left: newLeft + 'px',
					top: newTop + 'px',
					width: newWidth + 'px',
					height: newHeight + 'px'
				});
				
				// Update the overlay mask after resizing
				updateOverlayMask();
			});

			$(document).on('keydown', function(e) {
				if (e.key === 'Enter' && $('.crop_editor:visible').length) {
					e.preventDefault();
					$('.action-crop-submit').trigger('click');
				}
			});

			$('body').on('click', '.action-crop', function(event) {
				event.stopPropagation();


								


				let imgURL, photoID;

				// Check if triggered from sidebar/bottom bar
				if($('.image_viewer').data('sidebar-triggered')) {
					// Get data from image viewer
					imgURL = $('.image_viewer').data('src');
					photoID = $('.image_viewer').data('photo-id');

					$('.image_viewer').data('sidebar-triggered', false);
					closeImageViewer();
				} else {
					// Get data from gallery element
					const $card = $(this).closest('.div_output_image');
					imgURL = $card.find('.output_image').data('src');
					photoID = $card.data('photo-id');
				}

				$editor.data('photo-id', photoID); // store photo_id

				$img.attr('src', imgURL).one('load', function() {
					const iw = this.naturalWidth;
					const ih = this.naturalHeight;

					let maxW = window.innerWidth * 0.7;
					let maxH = window.innerHeight * 0.7;

					if (isMobile) {
						maxW = window.innerWidth * 0.95;
						maxH = window.innerHeight * 0.95;
					}

					const scale = Math.min(maxW / iw, maxH / ih);
					const finalW = Math.round(iw * scale);
					const finalH = Math.round(ih * scale);

					$img.css({ width: finalW + 'px', height: finalH + 'px' });
					
					// Update aspect ratio buttons based on image orientation
					const isPortrait = ih > iw;
					const $aspectButtons = $('.crop_aspect_ratio_buttons');
					
					if (isPortrait) {
						// Portrait image: show 3:4, 9:16, 1:1
						$aspectButtons.html(`
							<div class="button action-crop-aspect-ratio" data-ratio="3:4">3:4</div>
							<div class="button action-crop-aspect-ratio" data-ratio="9:16">9:16</div>
							&nbsp;&nbsp;
							<div class="button action-crop-aspect-ratio" data-ratio="1:1">1:1</div>
							&nbsp;&nbsp;
							<div class="button action-crop-aspect-ratio" data-ratio="4:3">4:3</div>
							<div class="button action-crop-aspect-ratio" data-ratio="16:9">16:9</div>
						`);
					}
					
					initCropBox();
				});

				$backdrop.add($editor).show();
			});

			// Mouse wheel zoom with iOS-style crop expansion
			let lastWheelTime = 0;
			const wheelThrottle = 25; // Minimum ms between wheel events
			
			$wrapper.on('wheel', function(e) {
				e.preventDefault();
				
				// Throttle wheel events to prevent too rapid firing
				const now = Date.now();
				if (now - lastWheelTime < wheelThrottle) {
					return;
				}
				lastWheelTime = now;
				
				const delta = e.originalEvent.deltaY;
				const zoomOut = delta > 0;
				const zoomFactor = zoomOut ? 0.9 : 1.1;
				const rect = $wrapper[0].getBoundingClientRect();
				const centerX = e.clientX;
				const centerY = e.clientY;
				
				// If zooming out and already at minimum zoom, expand crop box instead
				if (zoomOut && zoomLevel <= minZoom) {
					const currentWidth = $crop.width();
					const currentHeight = $crop.height();
					const currentLeft = parseFloat($crop.css('left'));
					const currentTop = parseFloat($crop.css('top'));
					
					const imgWidth = $img[0].clientWidth;
					const imgHeight = $img[0].clientHeight;
					
					// Maintain the aspect ratio of the current selection
					const aspectRatio = currentWidth / currentHeight;
					
					// Calculate theoretical maximum dimensions maintaining aspect ratio
					let maxWidth = imgWidth;
					let maxHeight = imgWidth / aspectRatio;
					if (maxHeight > imgHeight) {
						maxHeight = imgHeight;
						maxWidth = imgHeight * aspectRatio;
					}
					
					// Round to prevent floating point accumulation
					maxWidth = Math.round(maxWidth);
					maxHeight = Math.round(maxHeight);
					
					// Check if already at or very close to maximum size (within 2px tolerance)
					if (currentWidth >= maxWidth - 2 && currentHeight >= maxHeight - 2) {
						return; // Skip expansion to prevent rounding errors
					}
					
					// Use a moderate expansion factor with throttling
					// 1.11 = 11% expansion per throttled event
					const expansionFactor = 1.11;
					
					// Calculate new dimensions while maintaining aspect ratio
					let newWidth = currentWidth * expansionFactor;
					let newHeight = currentHeight * expansionFactor;
					
					// Clamp to maximum dimensions and round to integers
					newWidth = Math.round(Math.min(newWidth, maxWidth));
					newHeight = Math.round(Math.min(newHeight, maxHeight));
					
					// Ensure aspect ratio is maintained after rounding
					const roundedRatio = newWidth / newHeight;
					if (Math.abs(roundedRatio - aspectRatio) > 0.01) {
						if (newWidth === maxWidth) {
							newHeight = Math.round(newWidth / aspectRatio);
						} else {
							newWidth = Math.round(newHeight * aspectRatio);
						}
					}
					
					// Center the expanded crop box
					const newLeft = Math.max(0, currentLeft - (newWidth - currentWidth) / 2);
					const newTop = Math.max(0, currentTop - (newHeight - currentHeight) / 2);
					
					// Ensure crop box stays within image bounds and round positions
					const adjustedLeft = Math.round(Math.min(Math.max(0, newLeft), imgWidth - newWidth));
					const adjustedTop = Math.round(Math.min(Math.max(0, newTop), imgHeight - newHeight));
					
					$crop.css({
						left: adjustedLeft,
						top: adjustedTop,
						width: newWidth,
						height: newHeight
					});
					
					updateOverlayMask();
				} else {
					// Normal zoom behavior
					setZoom(zoomLevel * zoomFactor, centerX, centerY);
				}
			});

			$('.crop_editor_wrapper').on('mousedown', function(e) {
				// skip if clicking a handle or the crop box button
				if (
					$(e.target).closest('.crop_handle, .action-crop-submit').length > 0
				) return;

				// Check if we should pan (when zoomed) or drag crop box
				if (zoomLevel > 1 && !$(e.target).closest('.crop_editor_crop_area').length) {
					isPanning = true;
					startX = e.clientX;
					startY = e.clientY;
					const currentTransform = $img.css('transform');
					// Extract current pan values if any
					e.preventDefault();
					return;
				}

				isDragging = true;
				startX = e.clientX;
				startY = e.clientY;
				startLeft = parseFloat($crop.css('left'));
				startTop = parseFloat($crop.css('top'));
				e.preventDefault();
			});

			// RESIZE handles
			$('.crop_handle').on('mousedown', function(e){
				isResizing = true;
				currentHandle = $(this).attr('class').split(' ')[1]; // eg. 'nw', 's'
				startX = e.clientX;
				startY = e.clientY;
				startLeft = parseFloat($crop.css('left'));
				startTop = parseFloat($crop.css('top'));
				startWidth = $crop.width();
				startHeight = $crop.height();
				e.preventDefault();
				e.stopPropagation();
			});

			document.addEventListener('touchmove', function(e) {
				if (isPinching && e.touches.length === 2) {
					e.preventDefault();
					const currentDistance = getTouchDistance(e.touches);
					const currentCenter = getTouchCenter(e.touches);
					
					// Calculate zoom based on distance change
					const distanceRatio = currentDistance / lastTouchDistance;
					const newZoom = zoomLevel * distanceRatio;
					
					setZoom(newZoom, currentCenter.x, currentCenter.y);
					
					lastTouchDistance = currentDistance;
					lastTouchCenter = currentCenter;
				} else if (isPanning && e.touches.length === 1) {
					e.preventDefault();
					const dx = e.touches[0].clientX - startX;
					const dy = e.touches[0].clientY - startY;
					
					panX += dx / zoomLevel;
					panY += dy / zoomLevel;
					constrainPan();
					applyImageTransform();
					
					startX = e.touches[0].clientX;
					startY = e.touches[0].clientY;
				} else if (isDragging || isResizing) {
					e.preventDefault();
					const touch = e.touches[0];
					const simulatedEvent = new MouseEvent('mousemove', {
						clientX: touch.clientX,
						clientY: touch.clientY
					});
					document.dispatchEvent(simulatedEvent);
				}
			}, { passive: false });

			document.addEventListener('mousemove', function(e) {
				if (isPanning) {
					const dx = e.clientX - startX;
					const dy = e.clientY - startY;
					
					panX += dx / zoomLevel;
					panY += dy / zoomLevel;
					constrainPan();
					applyImageTransform();
					
					startX = e.clientX;
					startY = e.clientY;
				}
				else if (isDragging) {
					const dx = e.clientX - startX;
					const dy = e.clientY - startY;

					const wrapRect = $img[0].getBoundingClientRect();
					const cropW = $crop.width();
					const cropH = $crop.height();

					let newLeft = Math.min(
						Math.max(startLeft + dx, 0),
						wrapRect.width - cropW
					);
					let newTop = Math.min(
						Math.max(startTop + dy, 0),
						wrapRect.height - cropH
					);

					$crop.css({ left: newLeft, top: newTop });
				}
				if (isResizing) {
					const dx = e.clientX - startX;
					const dy = e.clientY - startY;
					let newLeft = startLeft, newTop = startTop, newWidth = startWidth, newHeight = startHeight;

					const wrapRect = $img[0].getBoundingClientRect();
					const minSize = 32;
					const isShiftHeld = e.shiftKey;
					const originalAspectRatio = startWidth / startHeight;

					switch (currentHandle) {
						case 'nw':
							if (isShiftHeld) {
								// Proportional resize from northwest corner
								const scale = Math.min(
									(startWidth - dx) / startWidth,
									(startHeight - dy) / startHeight
								);
								newWidth = startWidth * scale;
								newHeight = startHeight * scale;
								newLeft = startLeft + startWidth - newWidth;
								newTop = startTop + startHeight - newHeight;
							} else {
								newLeft = Math.max(startLeft + dx, 0);
								newTop = Math.max(startTop + dy, 0);
								newWidth = startWidth - (newLeft - startLeft);
								newHeight = startHeight - (newTop - startTop);
							}
							break;
						case 'ne':
							if (isShiftHeld) {
								// Proportional resize from northeast corner
								const scale = Math.min(
									(startWidth + dx) / startWidth,
									(startHeight - dy) / startHeight
								);
								newWidth = startWidth * scale;
								newHeight = startHeight * scale;
								newTop = startTop + startHeight - newHeight;
							} else {
								newTop = Math.max(startTop + dy, 0);
								newWidth = Math.min(startWidth + dx, wrapRect.width - startLeft);
								newHeight = startHeight - (newTop - startTop);
							}
							break;
						case 'sw':
							if (isShiftHeld) {
								// Proportional resize from southwest corner
								const scale = Math.min(
									(startWidth - dx) / startWidth,
									(startHeight + dy) / startHeight
								);
								newWidth = startWidth * scale;
								newHeight = startHeight * scale;
								newLeft = startLeft + startWidth - newWidth;
							} else {
								newLeft = Math.max(startLeft + dx, 0);
								newWidth = startWidth - (newLeft - startLeft);
								newHeight = Math.min(startHeight + dy, wrapRect.height - startTop);
							}
							break;
						case 'se':
							if (isShiftHeld) {
								// Proportional resize from southeast corner
								const scale = Math.min(
									(startWidth + dx) / startWidth,
									(startHeight + dy) / startHeight
								);
								newWidth = startWidth * scale;
								newHeight = startHeight * scale;
							} else {
								newWidth = Math.min(startWidth + dx, wrapRect.width - startLeft);
								newHeight = Math.min(startHeight + dy, wrapRect.height - startTop);
							}
							break;
						case 'n':
							if (isShiftHeld) {
								// Proportional resize from north, maintain aspect ratio
								newHeight = startHeight - dy;
								newWidth = newHeight * originalAspectRatio;
								newLeft = startLeft - (newWidth - startWidth) / 2;
								newTop = startTop + dy;
							} else {
								newTop = Math.max(startTop + dy, 0);
								newHeight = startHeight - (newTop - startTop);
							}
							break;
						case 's':
							if (isShiftHeld) {
								// Proportional resize from south, maintain aspect ratio
								newHeight = startHeight + dy;
								newWidth = newHeight * originalAspectRatio;
								newLeft = startLeft - (newWidth - startWidth) / 2;
							} else {
								newHeight = Math.min(startHeight + dy, wrapRect.height - startTop);
							}
							break;
						case 'e':
							if (isShiftHeld) {
								// Proportional resize from east, maintain aspect ratio
								newWidth = startWidth + dx;
								newHeight = newWidth / originalAspectRatio;
								newTop = startTop - (newHeight - startHeight) / 2;
							} else {
								newWidth = Math.min(startWidth + dx, wrapRect.width - startLeft);
							}
							break;
						case 'w':
							if (isShiftHeld) {
								// Proportional resize from west, maintain aspect ratio
								newWidth = startWidth - dx;
								newHeight = newWidth / originalAspectRatio;
								newLeft = startLeft + dx;
								newTop = startTop - (newHeight - startHeight) / 2;
							} else {
								newLeft = Math.max(startLeft + dx, 0);
								newWidth = startWidth - (newLeft - startLeft);
							}
							break;
					}

					// Enforce min size
					newWidth = Math.max(newWidth, minSize);
					newHeight = Math.max(newHeight, minSize);

					// Enforce right and bottom bounds
					if (newLeft + newWidth > wrapRect.width) newWidth = wrapRect.width - newLeft;
					if (newTop + newHeight > wrapRect.height) newHeight = wrapRect.height - newTop;

					$crop.css({
						left: newLeft,
						top: newTop,
						width: newWidth,
						height: newHeight
					});
				}
				updateOverlayMask();
			}, { passive: false });

			$(document).on('mouseup', function(){
				isDragging = false;
				isResizing = false;
				isPanning = false;
			});

			document.addEventListener('touchend', function(e){
				if (e.touches.length === 0) {
					// All fingers lifted
					isDragging = false;
					isResizing = false;
					isPanning = false;
					isPinching = false;
				} else if (e.touches.length === 1 && isPinching) {
					// One finger remains after pinch - switch to pan mode if zoomed
					isPinching = false;
					if (zoomLevel > 1) {
						isPanning = true;
						startX = e.touches[0].clientX;
						startY = e.touches[0].clientY;
					}
				}
			}, { passive: false });



			// Touch gesture variables
			let lastTouchDistance = 0;
			let lastTouchCenter = { x: 0, y: 0 };
			let isPinching = false;

			// Calculate distance between two touch points
			function getTouchDistance(touches) {
				const dx = touches[0].clientX - touches[1].clientX;
				const dy = touches[0].clientY - touches[1].clientY;
				return Math.sqrt(dx * dx + dy * dy);
			}

			// Calculate center point between two touches
			function getTouchCenter(touches) {
				return {
					x: (touches[0].clientX + touches[1].clientX) / 2,
					y: (touches[0].clientY + touches[1].clientY) / 2
				};
			}

			// mobile touch handlers
			$('.crop_editor_wrapper')[0].addEventListener('touchstart', function(e) {
				if (e.touches.length === 2) {
					// Two fingers - start pinch zoom
					isPinching = true;
					isDragging = false;
					lastTouchDistance = getTouchDistance(e.touches);
					lastTouchCenter = getTouchCenter(e.touches);
					e.preventDefault();
				} else if (e.touches.length === 1) {
					// One finger
					isPinching = false;
					if (!$(e.target).hasClass('crop_handle')) {
						if (zoomLevel > 1 && !$(e.target).closest('.crop_editor_crop_area').length) {
							// Pan when zoomed in
							isPanning = true;
							startX = e.touches[0].clientX;
							startY = e.touches[0].clientY;
						} else {
							// Drag crop box
							isDragging = true;
							startX = e.touches[0].clientX;
							startY = e.touches[0].clientY;
							startLeft = parseFloat($crop.css('left'));
							startTop = parseFloat($crop.css('top'));
						}
						e.preventDefault();
					}
				}
			}, { passive: false });

			$('.crop_handle').each(function() {
				this.addEventListener('touchstart', function(e) {
					isResizing = true;
					currentHandle = $(this).attr('class').split(' ')[1];
					startX = e.touches[0].clientX;
					startY = e.touches[0].clientY;
					startLeft = parseFloat($crop.css('left'));
					startTop = parseFloat($crop.css('top'));
					startWidth = $crop.width();
					startHeight = $crop.height();
					e.preventDefault();
					e.stopPropagation();
				}, { passive: false });
			});


			
			// SUBMIT crop
			$('.action-crop-submit').on('click', function(){

				flash();
				
				const imgRect = $img[0].getBoundingClientRect();
				const cropRect = $crop[0].getBoundingClientRect();

				const naturalW = $img[0].naturalWidth;
				const naturalH = $img[0].naturalHeight;
				const displayW = $img[0].clientWidth;
				const displayH = $img[0].clientHeight;

				// Calculate the position of the crop box relative to the original (unzoomed) image
				const wrapperRect = $wrapper[0].getBoundingClientRect();
				
				// Get crop position relative to wrapper
				const cropRelativeX = cropRect.left - wrapperRect.left;
				const cropRelativeY = cropRect.top - wrapperRect.top;
				
				// Account for zoom and pan transforms
				// The image center in wrapper coordinates
				const imageCenterX = displayW / 2;
				const imageCenterY = displayH / 2;
				
				// Calculate the actual position on the original image
				// Reverse the transform: (point - imageCenter) / zoom - pan + imageCenter
				const originalX = (cropRelativeX - imageCenterX) / zoomLevel - panX + imageCenterX;
				const originalY = (cropRelativeY - imageCenterY) / zoomLevel - panY + imageCenterY;
				const originalCropW = $crop.width() / zoomLevel;
				const originalCropH = $crop.height() / zoomLevel;

				const scaleX = naturalW / displayW;
				const scaleY = naturalH / displayH;

				const xMin = Math.round(originalX * scaleX);
				const yMin = Math.round(originalY * scaleY);
				const xMax = xMin + Math.round(originalCropW * scaleX);
				const yMax = yMin + Math.round(originalCropH * scaleY);

				const cropW = Math.round(originalCropW * scaleX);
				const cropH = Math.round(originalCropH * scaleY);
				

				$backdrop.add($editor).hide();

				console.log({ xMin, xMax, yMin, yMax });

				// TODO: replace with AJAX send like inpaint
				
				// Add preliminary placeholder
				const preliminaryId = 'preliminary_id_' + Math.floor(Math.random() * 1000);
				const photo = {
					status: 'preliminary',
					photo_url: $img.attr('src'),
					width: cropW,
					height: cropH
				};
				console.log(photo);
				const html = makePhotoBox(photo, null, null, preliminaryId);
				$('.div_output_images.camera').prepend(html);

				// Glow camera folder if needed
				if (selectedFolder != 'camera') {
					setTimeout(() => {
						$('.top_folder_selector h3[data-folder="camera"]').addClass('blinking glow');
						setTimeout(() => {
							$('.top_folder_selector h3[data-folder="camera"]').removeClass('glow');
						}, 500);
					}, 500);
				}



				// Send AJAX request
				$.ajax({
					url: '/?action=crop',
					type: 'POST',
					data: {
						action: 'crop',
						original_photo_id: $editor.data('photo-id'), // reuse same var if needed
						// submit the width and height too, so we can return it and set the right dimensions in the gallery immediately
						crop_width: cropW,
						crop_height: cropH,
						crop_xmin: xMin,
						crop_xmax: xMax,
						crop_ymin: yMin,
						crop_ymax: yMax
					},
					dataType: 'json'
				}).done(function(reply) {

					$('.div_output_images .div_output_image.preliminary.' + preliminaryId).remove();

					if (!reply.success) {
						if (reply.error == 'out_of_credits') {
							window.location.reload();
							return;
						}
						alert(reply.message);
						return;
					}

					const photo = reply.photos[0];
					photo.status = 'postprocessing';
					photo.preprocessed_photo_url = $img.attr('src');
					photo.original_photo_url = $img.attr('src');

					const html = makePhotoBox(photo);

					$('.div_output_images.camera').prepend(html);

					loadingSpinnerStep(photo.photo_id);
					setTimeout(waitForServerToGenerate, (pollIntervalTime * 2 * Math.random()), photo.photo_id, 'poll_for_preprocessed');
				});

			});

			function updateOverlayMask() {
				const wrapRect = $wrapper[0].getBoundingClientRect();
				const cropRect = $crop[0].getBoundingClientRect();

				const x = Math.round(cropRect.left - wrapRect.left);
				const y = Math.round(cropRect.top - wrapRect.top);
				const w = Math.round(cropRect.width);
				const h = Math.round(cropRect.height);
				const wrapW = Math.round(wrapRect.width);
				const wrapH = Math.round(wrapRect.height);

				$('.crop_editor_overlay.top').css({
					top: 0,
					left: 0,
					width: wrapW + 'px',
					height: Math.max(0, y) + 'px'
				});
				$('.crop_editor_overlay.bottom').css({
					top: Math.min(wrapH, y + h) + 'px',
					left: 0,
					width: wrapW + 'px',
					height: Math.max(0, wrapH - (y + h)) + 'px'
				});
				$('.crop_editor_overlay.left').css({
					top: Math.max(0, y) + 'px',
					left: 0,
					width: Math.max(0, x) + 'px',
					height: Math.min(h, wrapH - Math.max(0, y)) + 'px'
				});
				$('.crop_editor_overlay.right').css({
					top: Math.max(0, y) + 'px',
					left: Math.min(wrapW, x + w) + 'px',
					width: Math.max(0, wrapW - (x + w)) + 'px',
					height: Math.min(h, wrapH - Math.max(0, y)) + 'px'
				});
			}
		});
	</script>


