	function updateModelThumbnails() {
		var $container = $('.select_your_model_current_model_thumbnails');
		$container.empty();
		$('.model_selector .model_sample.active img').each(function() {
			$container.append('<img src="'+$(this).attr('src')+'">');
		});
	}
	function ucfirst (str) {
	  str += ''
	  var f = str.charAt(0)
		.toUpperCase()
	  return f + str.substr(1)
	}
	
	function explode(delimiter, string, limit) {
		
		if (arguments.length < 2 || typeof delimiter === 'undefined' || typeof string === 'undefined') return null;
		if (delimiter === '' || delimiter === false || delimiter === null) return false;
		if (typeof delimiter === 'function' || typeof delimiter === 'object' || typeof string === 'function' || typeof string ===
		'object') {
		return {
			0: ''
		};
		}
		if (delimiter === true) delimiter = '1';

		// Here we go...
		delimiter += '';
		string += '';

		var s = string.split(delimiter);

		if (typeof limit === 'undefined') return s;

		// Support for limit
		if (limit === 0) limit = 1;

		// Positive limit
		if (limit > 0) {
		if (limit >= s.length) return s;
		return s.slice(0, limit - 1)
			.concat([s.slice(limit - 1)
			.join(delimiter)
			]);
		}

		// Negative limit
		if (-limit >= s.length) return [];

		s.splice(s.length + limit);
		return s;
	}


	function flash(event){
		$('.flash')
			.show()
			.animate({opacity: 0.5}, 300) 
			.fadeOut(300)
			.css({'opacity': 1});
	}

	// <big flash - 1 video frame long>
		// Preload flash.mp3 for instant playback
		var flashAudio = document.createElement('audio');
		flashAudio.src = '/assets/flash.mp3';
		flashAudio.preload = 'auto';
		flashAudio.style.display = 'none';
		document.body.appendChild(flashAudio);

		function bigFlash(event){
			$('.big-flash').show();
			setTimeout(function() {
				$('.big-flash').hide();
			}, 23);
			// play flashAudio at half volume
			try {
				flashAudio.currentTime = 0;
				flashAudio.volume = 0.5;
				flashAudio.play();
			} catch(e) {
				// ignore errors if autoplay is blocked
			}
		}
	// </big flash - 1 video frame long>


	
