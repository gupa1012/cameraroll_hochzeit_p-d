										<h4>
						<a href="/faq/what-file-formats-of-photos-do-you-accept-for-creating-an-ai-model">
							
What file formats of photos do you accept for creating an AI model?						</a>
					</h4>
					<script type="application/ld+json">
						{
							"@context": "https://schema.org",
							"@type": "QAPage",
							"mainEntity": {
								"@type": "Question",
								"name": "Photo AI",
								"text": "\nWhat file formats of photos do you accept for creating an AI model?",
