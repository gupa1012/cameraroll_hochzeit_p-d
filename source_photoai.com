			// Lazy load videos: show poster image initially, replace with video on hover
			// Store all video attributes in data-* attributes so we can recreate the exact video element on hover
			var outputImageHTML='<img class="output_image video-lazy-placeholder" src="'+videoPosterURL+'" width="'+photo['width']+'" height="'+video['height']+'" '+
				'data-video-crossorigin="anonymous" '+
				'data-video-autoplay="'+videoAutoplayAttribute+'" '+
				'data-video-poster="'+videoPosterURL+'" '+
				'data-video-src="'+src+'" '+
