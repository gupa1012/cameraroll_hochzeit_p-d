	.main {
		margin-bottom:28px;
	}
	.pricing,
	.testimonials,
	html.frontpage .templates,
	.faq {
		max-width:1200px;
		margin:0 auto;
		margin-bottom:28px;
		margin-top:28px;
	}
	html.pricing_table {
		overflow:hidden;
	}
	.pricing {
		max-width:1400px;
	}
	.faq-img {
		object-fit:cover;
		float:left;
		clear:both;
		width:50%;
		width:calc(50% - 14px);
		margin-left:14px;
		margin-top:28px;
		height:auto;
	}
	.faq-right {
		text-align:left;
		width:50%;
		float:right;
		margin-top:28px;
	}
	.faq-right a {
		text-decoration:none;
	}
	@media (max-width:600px) {
		.faq-img {
			display:none;
		}
		.faq-right {
			width:auto;
			float:none;
		}
	}
	.faq h2,
	.faq h3,
	.faq h4,
	.faq p {
		margin:14px;
	}

	.pricing h2,
	.templates h2,
	.feature h2,
	.faq h2 {
		font-size:42px;
	}
	.faq h4 {
		cursor:pointer;
		border-top:1px solid var(--global-border-color);
		padding-top:21px;
		padding-bottom:21px;
		margin-top:0;
		margin-bottom:0;
		position:relative;
		padding-right:28px;
	}
	.faq h4:after {
		content:'+';
		font-size:20px;
		position: absolute;
		right:14px;
		top: 50%;
		transform: translateY(-50%);
		font-weight:400;
		transition: transform .3s ease-out;
	}
	.faq h4.expanded:after {
		transform: translateY(-50%) rotate(-45deg);
		transition: transform .3s ease-out;
	}
	.faq h4:not(.expanded):hover {
		opacity:0.75;
	}
	.faq h4:active {
		opacity:0.5;
	}
	.faq h4 {
		font-weight:800;
		font-size:18px;
		line-height:1.5;
		user-select: none;
	}
	.faq h4:not(.expanded):last-of-type {
		border-bottom:1px solid var(--global-border-color);
	}
	.templates p,
	.feature p,
	.faq p,
	.faq div.answer {
		line-height:1.75;
		font-size:18px;
		overflow:hidden;
		margin-top:0;
		transition: none;
	}
	/* trick to expand and hide answers in FAQ */
	.faq div.answer {
		max-height:0px;
		overflow:hidden;
	}
	.faq div.answer.expanded p {
		margin-bottom:28px;
	}
	.faq div.answer img,
	.faq div.answer video {
		max-width: calc(100% - 14px - 14px);
		margin: 14px;
	}
	.faq div.answer.expanded {
		max-height:initial;
		transition: .3s ease;
		padding-bottom:28px;
	}
	.blog {		
		max-width:1200px;
		margin:0 auto;
		margin-bottom:28px;
		margin-top:28px;
		margin-top:28px;
