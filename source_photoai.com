		padding:15%;
		border-radius:32px;*/
/*	}*/
	.div_uploader.active,
	.div_lipsync_video_selector.active,
	.div_import_uploader.active,
	.div_clothing_uploader.active,
	.div_product_uploader.active,
	.div_product_scene_uploader.active,
	.div_mocap_video_uploader.active,
	.div_mocap_person_uploader.active,
	.div_copycat_uploader.active,
	.div_training_uploader.active {
		background-size: cover;
	}
	.div_uploader.collapsed,
	.div_lipsync_video_selector.collapsed,
	.div_import_uploader.collapsed,
	.div_product_uploader.collapsed,
	.div_product_scene_uploader.collapsed,
	.div_mocap_video_uploader.collapsed,
	.div_mocap_person_uploader.collapsed,
	.div_clothing_uploader.collapsed,
	.div_copycat_uploader.collapsed,
	.div_training_uploader.collapsed {
		height: 175px;
		margin-top: 14px;
	}
	.div_lipsync_video_selector_center,
	.div_uploader_center,
	.div_import_uploader_center,
	.div_product_uploader_center,
	.div_product_scene_uploader_center,
	.div_mocap_video_uploader_center,
	.div_mocap_person_uploader_center,
	.div_copycat_uploader_center,
	.div_clothing_uploader_center,
	.div_training_uploader_center {
		z-index:1;
		padding: 14px;
		left: 50%;
		top: 50%;
		width: 100%;
		position: absolute;
		transform: translateX(-50%) translateY(-50%);
	}
	.div_training_uploader .primed_text {
		color:#fff;
		text-shadow: 1px 1px 1px var(--global-background-color);
		display:none;
	}
	.div_training_uploader.primed svg {
		display:none;
	}
	.div_training_uploader.primed .idle_text {
		display:none;
	}
	.div_training_uploader.primed .primed_text {
		display:block;
	}
	.div_uploader svg,
	.div_import_uploader_center svg,
	.div_clothing_uploader_center svg,
	.div_copycat_uploader_center svg,
	.div_product_uploader_center svg,
	.div_product_scene_uploader_center svg,
	.div_mocap_video_uploader_center svg,
	.div_mocap_person_uploader_center svg,
	.div_training_uploader_center svg {
		vertical-align: middle;
		margin-right: 7px;
	}
	.div_uploader.active,
	.div_import_uploader.active,
	.div_clothing_uploader.active,
	.div_product_uploader.active,
	.div_product_scene_uploader.active,
	.div_mocap_video_uploader.active,
	.div_mocap_person_uploader.active,
	.div_copycat_uploader.active {
		width:50%;
	}
	.div_uploader.active .div_uploader_center,
	.div_import_uploader.active .div_clothing_uploader_center,
	.div_product_uploader.active .div_product_uploader_center,
	.div_product_scene_uploader.active .div_product_uploader_center,
	.div_product_scene_uploader.active .div_product_scene_uploader_center,
	.div_mocap_video_uploader.active .div_mocap_video_uploader_center,
	.div_mocap_person_uploader.active .div_mocap_person_uploader_center,
	.div_clothing_uploader.active .div_clothing_uploader_center,
	.div_copycat_uploader.active .div_copycat_uploader_center {
		display:none;
	}

	.div_import_uploader:hover,
	.div_clothing_uploader:hover,
	.div_product_uploader:hover,
	.div_product_scene_uploader:hover,
	.div_mocap_video_uploader:hover,
	.div_mocap_person_uploader:hover,
	.div_copycat_uploader:hover,
	.div_training_uploader:hover {
		opacity: 0.75;
	}

	.div_import_uploader.drag-over,
	.div_clothing_uploader.drag-over,
	.div_product_uploader.drag-over,
	.div_product_scene_uploader.drag-over,
	.div_mocap_video_uploader.drag-over,
	.div_mocap_person_uploader.drag-over,
	.div_copycat_uploader.drag-over {
		outline: 2px solid #f47353;
	}
	.div_import_uploader:active,
	.div_clothing_uploader:active,
	.div_product_uploader:active,
	.div_product_scene_uploader:active,
	.div_mocap_video_uploader:active,
	.div_mocap_person_uploader:active,
	.div_copycat_uploader:active,
	.div_training_uploader:active {
		opacity: 0.5;
