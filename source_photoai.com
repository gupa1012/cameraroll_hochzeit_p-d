		<script>
			(function() {
				var gridColsMap = [8, 6, 5, 4, 3];
				var slider = document.querySelector('.grid_size_slider');
				var savedGrid = localStorage.getItem('grid-cols');
				if(savedGrid) {
					var idx = gridColsMap.indexOf(parseInt(savedGrid));
					if(idx !== -1) {
						slider.value = idx + 1;
						document.documentElement.setAttribute('data-grid-cols', savedGrid);
						document.documentElement.style.setProperty('--grid-cols', savedGrid);
					}
				}
				slider.addEventListener('input', function() {
					var cols = gridColsMap[parseInt(this.value) - 1];
					document.documentElement.setAttribute('data-grid-cols', cols);
					document.documentElement.style.setProperty('--grid-cols', cols);
					localStorage.setItem('grid-cols', cols);
				});
			})();
		</script>

