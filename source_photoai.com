	@media (max-width:800px) {
		.header h2 {
			display:none;
		}
		.div_output_images {
			padding-left:14px;
			padding-right:14px;
		}
		html:not(.guest) .div_pose,
		html:not(.guest) .div_template,
		html:not(.guest) .div_output_image,
		.div_output_image.landscape {
/*			width: calc(100% - 14px);*/
