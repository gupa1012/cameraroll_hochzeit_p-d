	* {
		box-sizing: border-box;
	}
	body,input,select,textarea,a {
		color: var(--global-text-color);
	}
	body,input,select,textarea {
		font-family: monospace;
		font-family: -apple-system,"system-ui","Segoe UI",sans-serif;
		background: #111;
	}
	textarea.manual_negative_prompt:focus,
	textarea.manual_negative_prompt:active,
	textarea.manual_negative_prompt.active {
		min-height:125px;
	}
	textarea.manual_prompt:focus,
	textarea.manual_prompt:active,
	textarea.manual_prompt.active {
		min-height:110px;
	}

	/* Auto-detecting prompt animation */
	textarea.manual_prompt.auto-detecting {
		position: relative;
		border: 2px solid transparent;
		background-image: 
			linear-gradient(var(--input-background-color), var(--input-background-color)),
			linear-gradient(45deg, 
				#f79533,
				#0d0d0d,
				#f37055,
				#0d0d0d,
				#ef4e7b,
				#0d0d0d,
				#a166ab,
				#0d0d0d,
				#5073b8,
				#0d0d0d,
				#1098ad,
				#0d0d0d,
				#07b39b,
				#0d0d0d,
				#6fba82,
				#0d0d0d
			);
		background-origin: border-box;
		background-clip: padding-box, border-box;
		background-size: 100%, 400% 400%;
		animation: auto-detecting-border 3s infinite;
		outline:none;
	}
	input,select,textarea,.button {
		padding: 14px;
		border-radius: 12px;
		border: 1px solid rgba(255,255,255,0.2);
		font-size: 16px;
		background: var(--input-background-color);
	}
	input.active,select.active,textarea.active,
	input:focus,select:focus,textarea:focus {
		outline: 2px solid #f47353;
	}
	select {
		appearance:none;
	}
	input.model_strength {
		-webkit-appearance: none; /* Remove default appearance */
		width: 100%;
		outline: none;
		overflow:hidden;
	}
	input.model_strength::-webkit-slider-runnable-track {
		width: 100%;
		height: 8px;
		background: transparent;
		border-radius: 5px;
	}
	input.model_strength::-webkit-slider-thumb {
		-webkit-appearance: none;
		appearance: none;
		opacity:1;
		width: 30px;
		height: 36px;
		background: #f47353;
		margin-top: -14px;
		margin-left: -14px;
	}
	input.model_strength::-moz-range-track {
		background: #f47353;
		border-radius: 5px;
	}
	input.model_strength::-moz-range-thumb {
		opacity:0;
		width: 20px;
		height: 20px;
		background: #f47353;
		border-radius: 50%;
	}
	.infinity_scroll_sensor {
		height:100px;
	}
	p.subline {
		font-size:12px;
		color:rgba(255,255,255,0.5);
		margin-top:-14px;
	}
	.sidebar textarea,
	.sidebar input,
	.sidebar select {
