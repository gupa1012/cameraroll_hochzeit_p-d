<style>

	/* set css var for border-radius */
	:root {
		--global-border-radius: 12px;
		/* --global-border-radius: 0; */
		/* --gradient: linear-gradient(60deg,#f79533,#f37055,#ef4e7b,#a166ab,#5073b8,#1098ad,#07b39b,#6fba82); */
		--gradient: linear-gradient(90deg, #FF0F7B 0%, #F89B29 100%);
	}

	:root.dark {
		--meta-label-background-color:rgba(0,0,0,0.5);
		--global-background-color: #111;
		--sidebar-background-color:#0d0d0d;
		--header-background-color:#000;
		--input-background-color:#161616;
		--hover-background-color:#3f3f3f;
		--global-text-color: #fff;
		--global-link-color:#fff;
		--global-border-color: #343434;
		--global-text-color:#fff;
		--photo-border-color:#343434;
		--copycat-gallery-background:rgba(0,0,0,0.75);
		--take-photo-container-height:82px;
	}
	:root {
		--bold:600;
		--meta-label-background-color:rgba(255,255,255,0.5);
		--loading-spinner-color: #fff;
/*		--copycat-gallery-height: 135px;*/
		--copycat-gallery-height: 0px;
		--header-height: 60px;
		--left-sidebar-width: 400px;
		--highlight-background-color:#fff38f;
		--global-background-color: #dfdfdf;
		--sidebar-background-color:#fff;
		--header-background-color:#fff;
		--input-background-color:#fff;
		--global-text-color: #1c1c1c;
		--global-link-color: #1c1c1c;
		--global-border-color: #dcdddd;
		--take-photo-container-height:82px;
		--global-text-color:#000;
		--photo-border-color:#dddddd;
		--copycat-gallery-background:rgba(255,255,255,0.75);
	}
	:root.training_mode,
	:root.design_mode,
	:root.prompt_mode {
		--copycat-gallery-height: 1px; /* cannot be zero or shit breaks */
	}
	@-webkit-keyframes rotating /* Safari and Chrome */ {
		from {
			-webkit-transform: rotate(0deg);
			-o-transform: rotate(0deg);
			transform: rotate(0deg);
		}
		to {
			-webkit-transform: rotate(360deg);
			-o-transform: rotate(360deg);
			transform: rotate(360deg);
		}
	}
	@keyframes rotating {
		from {
			-ms-transform: rotate(0deg);
			-moz-transform: rotate(0deg);
			-webkit-transform: rotate(0deg);
			-o-transform: rotate(0deg);
			transform: rotate(0deg);
		}
		to {
			-ms-transform: rotate(360deg);
			-moz-transform: rotate(360deg);
			-webkit-transform: rotate(360deg);
			-o-transform: rotate(360deg);
			transform: rotate(360deg);
		}
	}

	.photo_pack_filters {
		display: none;
	}

	/* Hide search and filters for photo packs and community tabs */
	.selected-folder-templates .search-and-filters,
	.selected-folder-examples .search-and-filters {
		display:none;
	}

	/* Show .photo_pack_filters only for templates */
	.selected-folder-templates .photo_pack_filters {
		display: flex;
	}

	html.training_mode .div_generate_button_container {
		display:none;
	}
	html.training .logo-icon,
	html.taking-photos .logo-icon,
	html.guest .logo-icon {
		-webkit-animation: rotating 5s linear infinite;
		-moz-animation: rotating 5s linear infinite;
		-ms-animation: rotating 5s linear infinite;
		-o-animation: rotating 5s linear infinite;
		animation: rotating 5s linear infinite;
	}
	.logo-icon {
		width: 30px;
		height: 30px;
		display: inline-block;
		vertical-align: middle;
		flex-shrink: 0;
		background: var(--gradient);
		-webkit-animation: animatedgradient 6s ease infinite alternate;
		animation: animatedgradient 6s ease infinite alternate;
		background-size: 300% 300%;
		mask-image: url('/assets/logo.svg');
		mask-repeat: no-repeat;
		mask-size: contain;
		-webkit-mask-image: url('/assets/logo.svg');
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-size: contain;
	}
	html:not(.guest) .logo-text {
		display: none;
	}
	html.guest .templates {

	}
	html.training_tab_is_open .div_generate_button_container {
		display:none;
	}

	html,body {
		overflow-x:hidden;
	}
		html.template .by-levelsio,
	html.template .already_have_account_text,
	html.template .affiliate_program {
		display:none;
	}
	.floating_prompt_box {
		display:none;
		position: fixed;
		z-index: 100;
		left: 50%;
		transform: translateX(-50%);
		width: calc(92% - var(--left-sidebar-width));
		max-width: 1100px;
		margin-left: calc(var(--left-sidebar-width) / 2);
		min-height: 130px;
		bottom: 50px;
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(20px);
		border: 1px solid var(--global-border-color);
		border-radius: 12px;
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.floating_prompt_box .floating_prompt_close {
		position: absolute;
		top: 8px;
		right: 8px;
		width: 24px;
		height: 24px;
		cursor: pointer;
		opacity: 0.5;
		transition: opacity 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 10;
	}
	.floating_prompt_box .floating_prompt_close:hover {
		opacity: 1;
	}
	.floating_prompt_box .floating_prompt_close svg {
		width: 16px;
		height: 16px;
	}
	.floating_prompt_box textarea {
		background: transparent;
		border: none;
		outline: none;
		color: #fff;
		resize: none;
		font-family: inherit;
		font-size: 16px;
		min-height: 120px;
		max-height: 300px;
		overflow-y: auto;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}
	.floating_prompt_box textarea::-webkit-scrollbar {
		display: none;
	}
	.floating_prompt_box textarea.manual_prompt,
	.floating_prompt_box .manual_prompt.tagify,
	.floating_prompt_box tags.tagify.manual_prompt,
	.floating_prompt_box .tagify {
		background: transparent !important;
		border: none !important;
		outline: none !important;
		box-shadow: none !important;
		min-height: 100px !important;
		max-height: none !important;
		height: auto !important;
	}
	.floating_prompt_box .tagify--mix,
	.floating_prompt_box .tagify:not(.tagify--hasMaxTags) {
		min-height: auto !important;
		max-height: none !important;
		height: auto !important;
	}
	.floating_prompt_box textarea.manual_prompt:focus,
	.floating_prompt_box textarea.manual_prompt:active,
	.floating_prompt_box .manual_prompt.tagify:focus,
	.floating_prompt_box .manual_prompt.tagify:active,
	.floating_prompt_box .manual_prompt.tagify:focus-within,
	.floating_prompt_box tags.tagify.manual_prompt:focus,
	.floating_prompt_box tags.tagify.manual_prompt:focus-within,
	.floating_prompt_box .tagify:focus,
	.floating_prompt_box .tagify.tagify--focus {
		border: none !important;
		outline: none !important;
		box-shadow: none !important;
		min-height: auto !important;
	}
	.floating_prompt_box textarea::placeholder {
		color: rgba(255, 255, 255, 0.5);
	}
	.floating_prompt_box textarea {
		min-height: 50px;
		height: auto;
		padding: 14px;
	}
	.floating_prompt_box .floating_prompt_bottom {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 10px;
		padding: 0 14px 14px 14px;
	}
	.floating_prompt_box .floating_prompt_add_copycat {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 28px;
		font-weight: 300;
		line-height: 1;
		color: #888;
		cursor: pointer;
		border-radius: 50%;
		transition: background 0.15s ease;
	}
	.floating_prompt_box .floating_prompt_add_copycat:hover {
		background: rgba(255,255,255,0.1);
		color: #fff;
	}
	.floating_prompt_box .floating_prompt_copycat_preview {
		display: none;
		padding-left:21px;
		padding-top:21px;
		margin-bottom:-14px;
		position: relative;
		width: fit-content;
	}
	.floating_prompt_box .floating_prompt_copycat_preview.active {
		display: block;
	}
	.floating_prompt_box .floating_prompt_copycat_thumbnail {
		width: 100px;
		height: 100px;
		object-fit: cover;
		border-radius: 8px;
		border: 1px solid rgba(255,255,255,0.2);
	}
	.floating_prompt_box .floating_prompt_copycat_delete {
		position: absolute;
		top: 14px;
		left: 111px;
		width: 18px;
		height: 18px;
		background: rgba(0,0,0,0.7);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.15s ease;
	}
	.floating_prompt_box .floating_prompt_copycat_preview:hover .floating_prompt_copycat_delete {
		opacity: 1;
	}
	.floating_prompt_box .floating_prompt_options {
		display: flex;
		flex-direction: row;
		gap: 10px;
		flex: 1;
	}
	.floating_prompt_box .floating_prompt_options .select_amount_of_photos {
		width: auto;
	}
	.floating_prompt_bottom .floating_realism_switch {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 0 8px;
		background: rgba(255,255,255,0.05);
		border-radius: 8px;
		height: 49px;
		margin:0;
	}
	.floating_prompt_bottom .floating_realism_switch .realism_switch_label,
	.floating_prompt_bottom .floating_realism_switch .nano_banana_label {
		font-size: 16px;
		padding: 0;
		background: none;
		border-radius: 0;
		margin:0;
	}
	.floating_prompt_bottom .floating_realism_switch .nano_banana_label img {
		display: none;
	}
	.floating_prompt_bottom .floating_realism_switch .realism_switch {
		transform: scale(0.8);
	}
	.floating_prompt_box .button.action-take-photo {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		padding: 0;
	}
	.floating_prompt_box .button.action-take-photo svg {
		width: 20px;
		height: 20px;
	}
	@media (max-width: 800px) {
		.floating_prompt_box {
			width: 92%;
			margin-left: 0;
		}
	}
	.sidebar {
