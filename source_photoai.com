				}
			</style>
			<script>
				var photoPackSearchQuery='';
				var photoPackCategory='';

				function filterPhotoPacks() {
					if(selectedFolder!='templates') return;

					var query = $('.photo_pack_search').val().toLowerCase();
					var category = $('.photo_pack_category').val();
					var $container = $('.div_output_images.templates');
					var $templates = $container.find('.div_template');

					if(query == '' && category == '') {
						$templates.show();
						return;
					}

					var matches = [];

					$templates.each(function() {
						var $el = $(this);
						var name = ($el.data('name') || '').toLowerCase();
						var desc = ($el.data('description') || '').toLowerCase();
						var elCategory = $el.data('category') || '';

						// Check category filter first
						if(category && elCategory != category) {
							$el.hide();
							return;
						}

						// If no search query, just show (category already matched)
						if(query == '') {
							matches.push({ el: $el, score: 0, name: name });
							return;
						}

						var score = -1;
						if(name === query) {
							score = 0;
						} else if(name.indexOf(query) === 0) {
							score = 1;
						} else if(name.indexOf(query) > -1) {
							score = 2;
						} else if(desc.indexOf(query) > -1) {
							score = 3;
						}

						if(score >= 0) {
							matches.push({ el: $el, score: score, name: name });
						} else {
							$el.hide();
						}
					});

					matches.sort(function(a, b) {
						if(a.score !== b.score) return a.score - b.score;
						return a.name.localeCompare(b.name);
					});

					matches.forEach(function(item) {
						item.el.detach().appendTo($container).show();
					});
				}

				$(function() {
					$('.photo_pack_search').bind('keyup',function(event) {
						if(photoPackSearchQuery==$(this).val()) return;
						photoPackSearchQuery=$(this).val();
						filterPhotoPacks();
					});

					$('.photo_pack_category').bind('change',function() {
						photoPackCategory=$(this).val();
						filterPhotoPacks();
					});
				});
			</script>
