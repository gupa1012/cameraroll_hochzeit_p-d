	.div_output_image.upscaled,
	.div_output_image.three_d,
	.div_output_image.video,
	.div_output_image.copycat,
	.div_output_image.try_on {
		overflow:visible;
	}

	.div_output_image.upscaled .top_left_label,
	.div_output_image.three_d .top_left_label,
	.div_output_image.video .top_left_label,
	.div_output_image.copycat .top_left_label,
	.div_output_image.try_on .top_left_label {
		border-top-left-radius: 0px;
		padding-left:78px;
	}

	.div_output_image.edit:after {
		content:'edit';
		/*background:rgba(0,0,0,0.5);
		color:#fff;*/
/*		background:rgba(255,255,255,0.5);*/
		background:#2b80de;
		color:#000;
		font-weight:bold;
		position:absolute;
		top:0;
		right:0;
		font-size:8px;
		padding:5px;
		border-top-right-radius: var(--global-border-radius);
		border-bottom-left-radius: 6px;
/*		border-left:1px solid var(--photo-border-color);*/
/*		border-bottom:1px solid var(--photo-border-color);*/
		text-transform: uppercase;
	}

	/* <disable certain actions for example pics> */
		.div_output_image.example {
			cursor:pointer;
		}
	/* </disable certain actions for example pics> */

	.image_viewer {
		border-radius:var(--global-border-radius);
		overflow:hidden;
		-webkit-user-select: none;
		-khtml-user-select: none;
		-moz-user-select: none;
		-ms-user-select: none;
		user-select:none;
		display: none;
/*		border-radius: 12px;*/
		/*width: 832px;*/
		width: auto;
		height: auto;
		transform: translateX(-50%) translateY(-50%);
		position: fixed;
		z-index: 102;
		left: 50%;
		top: 50%;
		object-fit: cover;
		background: #161616;
		/*border: 1px solid rgba(255,255,255,0.2);*/
		/*background: #fff;*/
		/*padding: 7px;*/
/*		box-shadow: 0 0 0 1px var(--global-border-color), 0 2px 4px 0 rgb(0 0 0 / 7%), 0 1px 1.5px 0 rgb(0 0 0 / 5%);*/
		/* dotted bg */
		background: radial-gradient(#424242 0.5px, transparent 0.5px), radial-gradient(#424242 0.5px, #161616 0.5px);
		background-size: 20px 20px;
		background-position: 0 0, 10px 10px;
		background-repeat: initial;
	}
	@media (min-width: 700px) {
		.image_viewer {
			top: calc(50% - 40px);
		}
	}
	@media (min-width: 1200px) {
		.image_viewer {
			left: calc(50% - 195px);
		}
		.image_viewer_arrow_right {
			right: 400px;
		}
	}
	.image_viewer.zoomed-in {
		left: 50%;
		top: 50%;
	}
	.div_output_image_container .model_viewer_background_container {
		display: block;
		height: 100%;
		width: 100%;
		position: absolute;
		z-index: 1;
		overflow:hidden;
	}
	.div_output_image_container .model_viewer_background {
		display: block;
		height: 100%;
		width: 100%;
		position: absolute;
		z-index: 1;
		filter: blur(15px);
	}
	.image_viewer .model_viewer_background {
		display: block;
		height: 100%;
		width: 100%;
		position: absolute;
		z-index: 2;
		filter: blur(100px);
	}
	.image_viewer_bottom_gallery {
		position: fixed;
		z-index: 102;
		bottom:0;
		left:0;
		width:100%;
		display: none;
		height:12.5vh;
		text-align: center;
	}
	.image_viewer_bottom_gallery img {
		height:100%;
		margin-left:7px;
		margin-right:7px;
	}
	.image_viewer .action-save-photo.saved {
		display:block;
	}
	.image_viewer.three_d:hover .action-grab-video-frame,
	.image_viewer.video:hover .action-grab-video-frame,
	.image_viewer:hover .action-save-photo,
	.image_viewer:hover .action-undelete-photo,
	.image_viewer:hover .action-delete-photo {
		display:block;
	}
	.image_viewer.three_d .action-grab-video-frame,
	.image_viewer.video .action-grab-video-frame,
	.image_viewer .action-save-photo,
	.image_viewer .action-undelete-photo,
	.image_viewer .action-delete-photo {
		z-index:104;
		padding:21px;
	}
	@media (max-width:600px) {
		.image_viewer .action-delete-photo {
			/* 2025-07-09 - i keep accidentally deleting photos on mobile */
			display:none;
		}
	}
	.image_viewer.three_d .action-grab-video-frame svg,
	.image_viewer.video .action-grab-video-frame svg,
	.image_viewer .action-save-photo svg,
	.image_viewer .action-undelete-photo svg,
	.image_viewer .action-delete-photo svg {
		height:35px;
		width:38px;
	}

	.image_viewer > video {
		display:none;
	}
	.image_viewer,
	.image_viewer > img,
	.image_viewer > video,
	.image_viewer > model-viewer {
		max-width:90vw;
		max-height:80vh;
	}
	.image_viewer:not(.three_d) > model-viewer {
		display:none !important;
	}

	.image_viewer > img,
	.image_viewer > video,
	.image_viewer > model-viewer {
		display:none;
		background-size:cover;
		background-repeat:no-repeat;
/*		background-size:10%;*/
		width:auto;
		height:auto;
		position:relative;
		z-index:103;
	}
	.image_viewer > img {
		cursor:zoom-in;
	}
	.image_viewer.photo > img:not(.swipe_preview) {
		display:block
	}
	.image_viewer > img.swipe_preview {
		display:none !important;
	}
	.image_viewer.video > video {
		display:block
	}
	.image_viewer.three_d > model-viewer {
		display:block
	}
/*	.image_viewer img.loading {*/
/*		filter:blur(5px);*/
/*	}*/

	.image_viewer.zoomed-in .action-save-photo,
	.image_viewer.zoomed-in .action-delete-photo {
		display:none;
	}

	.image_viewer.zoomed-in > img {
		cursor:zoom-out;
/*		cursor:grab;*/
		max-width:none;
		max-height:none;
	}
	.image_viewer.zoomed-in > img:active {
/*		cursor:grabbing;*/
	}
	.image_viewer.zoomed-in {
		overflow:scroll;
		max-width:100vw;
		max-height:100vh;
		z-index:105;
	}
	.image_viewer:active {
/*		opacity:0.5;*/
	}

	/* Mobile image viewer - full screen vertically scrollable */
	.image_viewer_close_mobile {
		display: none;
	}
	.image_viewer_mobile_sidebar {
		display: none;
	}
	.image_viewer_mobile_nav {
		display: none;
	}
	@media (max-width: 599px) {
		.image_viewer {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			width: 100%;
			height: 100%;
			max-width: 100vw;
			max-height: 100vh;
			transform: none;
			border-radius: 0;
			overflow-y: auto;
			overflow-x: hidden;
			flex-direction: column;
			background: #000;
		}
		/* Override jQuery's display:block with flex for mobile layout */
		.image_viewer[style*="display: block"],
		.image_viewer[style*="display:block"] {
			display: flex !important;
		}
		.image_viewer_close_mobile {
			display: flex;
			position: fixed;
			top: -14px;
			right: 14px;
			width: auto;
			height: auto;
			align-items: center;
			justify-content: center;
			font-size: 35px;
			line-height: 35px;
			color: #fff;
			cursor: pointer;
			z-index: 110;
		}
		.image_viewer > img,
		.image_viewer > video,
		.image_viewer > model-viewer {
			max-width: 100%;
			max-height: none;
			width: 100%;
			height: auto;
			flex-shrink: 0;
		}
		.image_viewer.photo > img,
		.image_viewer.video > video,
		.image_viewer.three_d > model-viewer {
			display: block;
		}
		.image_viewer_mobile_sidebar {
			display: block;
			padding: 16px;
			background: #111;
			flex-shrink: 0;
		}
		.image_viewer_mobile_nav {
			display: block;
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			pointer-events: none;
			z-index: 1000;
		}
		.image_viewer_mobile_arrow_left,
		.image_viewer_mobile_arrow_right {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			width: 44px;
			height: 44px;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			color: #fff;
			pointer-events: auto;
		}
		.image_viewer_mobile_arrow_left {
			left: 8px;
		}
		.image_viewer_mobile_arrow_right {
			right: 8px;
		}
		.image_viewer_mobile_arrow_left svg,
		.image_viewer_mobile_arrow_right svg {
			width: 28px;
			height: 28px;
		}
		.image_viewer_mobile_arrow_left:active,
		.image_viewer_mobile_arrow_right:active {
			opacity: 0.5;
		}
		.image_viewer_mobile_actions {
			display: flex;
			justify-content: space-around;
			padding: 0 0 16px 0;
			border-bottom: 1px solid rgba(255,255,255,0.1);
			margin-bottom: 16px;
		}
		.image_viewer_mobile_actions .mobile-action {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 6px;
			color: #fff;
			font-size: 11px;
			cursor: pointer;
			padding: 8px;
		}
		.image_viewer_mobile_actions .mobile-action img {
			width: 24px;
			height: 24px;
			filter: invert(1);
		}
		.image_viewer_mobile_actions .mobile-action:active {
			opacity: 0.5;
		}
		.image_viewer_mobile_section {
			margin-bottom: 16px;
		}
		.image_viewer_mobile_section_header {
			font-weight: 600;
			font-size: 12px;
			text-transform: uppercase;
			letter-spacing: 0.5px;
			color: rgba(255,255,255,0.5);
			margin-bottom: 8px;
		}
		.image_viewer_mobile_prompt_text {
			font-size: 14px;
			line-height: 1.5;
			color: rgba(255,255,255,0.9);
			word-break: break-word;
		}
		.image_viewer_mobile_actions_grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 8px;
		}
		.image_viewer_mobile_actions_grid .button {
			width: 100%;
			text-align: center;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			font-size: 13px;
		}
		.image_viewer_mobile_actions_grid .button img {
			width: 16px;
			height: 16px;
			filter: invert(1);
		}
		/* Hide desktop elements on mobile */
		.image_viewer .action-delete-photo {
			display: none !important;
		}
		/* Show grab-frame button for videos on mobile */
		.image_viewer.video .action-grab-video-frame {
			display: block !important;
		}
		/* Always show save button on mobile */
		.image_viewer .action-save-photo {
			display: block !important;
		}
		.image_viewer_backdrop,
		.image_viewer_bottom_actions {
			display: none !important;
		}
		/* Hide image-only actions in mobile sidebar when viewing a video */
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-inpaint"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-copycat"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-relight"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-zoom-out"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-add-grain"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-crop"],
		.image_viewer.video .image_viewer_mobile_sidebar [data-action="action-make-3d-model"] {
			display: none !important;
		}
		/* Hide non-applicable actions in mobile sidebar when viewing a 3D model */
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-make-video"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-inpaint"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-copycat"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-upscale"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-relight"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-zoom-out"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-add-grain"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-crop"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-make-talking-video"],
		.image_viewer.three_d .image_viewer_mobile_sidebar [data-action="action-make-3d-model"] {
			display: none !important;
		}
		.image_viewer {
			transition: transform 0.3s ease, opacity 0.3s ease;
		}
		.image_viewer.dragging {
			transition: none;
		}
		.image_viewer > img,
		.image_viewer > video {
			transition: transform 0.3s ease, opacity 0.3s ease;
		}
		.image_viewer.dragging > img,
		.image_viewer.dragging > video {
			transition: none;
		}
		.image_viewer > img.swipe_preview {
			display: none !important;
			position: absolute;
			top: 0;
			width: 100%;
			height: auto;
			z-index: 102;
			pointer-events: none;
		}
		.image_viewer > img.swipe_preview.visible {
			display: block !important;
		}
		.image_viewer.dragging .swipe_preview {
			transition: none;
		}
		.image_viewer .swipe_preview {
			transition: transform 0.3s ease;
		}
	}

