		.main,
		.right,
		.sidebar {
			display:block;
			width:auto;
		}
	}
	.by-levelsio {
		display: block;
		padding: 7px;
		font-size: 12px;
		margin: 0;
		background: #fff;
		color: #000;
		position: fixed;
		bottom: 0;
		right: 0;
		border-top: 1px solid 1px solid rgba(0,0,0,0.125);
		border-left: 1px solid 1px solid rgba(0,0,0,0.125);
		border-top-left-radius: 12px;
		z-index: 99;
		font-weight: bold;
		text-decoration: none;
	}

	.div_output_image.postprocessing model-viewer,
	.div_output_image.postprocessing video.output_image,
	.div_output_image.postprocessing img.output_image {
		/* filter:blur(2px); */
		opacity:0.25;
	}

	.div_output_image.processing video.output_image,
	.div_output_image.processing img.output_image {
		filter:blur(25px);
		opacity:0.5;
		clip-path:inset(0);
	}

	.div_output_image.preliminary {
		border:1px solid #f47353;
		animation-name: preliminary-fading-border;
		animation-duration: 2s;
		animation-iteration-count: 1;
	}
	@keyframes preliminary-fading-border {
		0% {
			border-color: #f47353;
		}
		100% {
			border-color: rgba(0,0,0,0);
		}
	}


	

	.div_output_image model-viewer {
		/* let the blurry bg through */
		background:none;
		z-index:2;
	}
	

	/* currently shown in image viewer for navigating with arrow keys */
	.div_output_image.current {
		border:1px solid #2bde73;
	}

	.div_output_image.saved,
	.div_output_image.frontpaged {
		border:1px solid #f47353;
	}

	.div_output_image.nsfw img {
		filter:blur(50px);
	}

	.div_output_image.nsfw div.nsfw_notice {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translateX(-50%) translateY(-50%);
		z-index: 10;
		color:#fff;
		text-align:center;
		font-weight:bold;
		font-size:12px;
	}

	.div_output_image.postprocessing .loading_spinner,
	.div_output_image.placeholder .loading_spinner {
		display: block;
	}
	.div_output_image.placeholder .loading_spinner {
		width:90%;
	}
	html.guest .div_output_image_meta {
		display:none;
	}
	.div_output_image_meta {
		display:block;
/*		display:none;*/
		font-size: 8px;
		position: absolute;
		background: var(--meta-label-background-color);
		color:var(--global-text-color);
		bottom: 0;
		right: 0;
		padding: 3.5px;
		border-bottom-right-radius: var(--global-border-radius);
		border-top-left-radius: var(--global-border-radius);
		padding-left:7px;
		z-index: 3;
		word-break: break-all;
	}
		/*html.logged-in .div_output_images {
		padding-top:120px;
	}*/

	@media (min-width:1100px) {
		html.guest .div_output_image:nth-child(odd) {
			margin-top:calc(-19vw);
