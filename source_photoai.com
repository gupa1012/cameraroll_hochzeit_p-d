				originalPhotoUrlAttr+' '+
				'data-width="'+video['width']+'" '+
				'data-height="'+video['height']+'" '+
				originalImageAsDataSrc+' '+
				preprocessedImageAsDataSrc+' />';

		}
		else {
			var outputImageHTML='<img '+lazyLoadingTag+altTag+' data-width="'+photo['width']+'" data-height="'+photo['height']+'" width="'+photo['width']+'" height="'+photo['height']+'" class="output_image" '+originalImageAsDataSrc+' '+preprocessedImageAsDataSrc+' src="'+cloudflareCDN+src+'">';
		}





					// frontpage, guest, so wrap img around <a href> to the public photo page
			var outputImageHTML='<a href="/photo/'+photo['slug']+'">'+outputImageHTML+'</a>';
		
		var topLeftLabelHtml='';
		var topLeftLabel='';
		if(photo['emotion']) {
			// topLeftLabel=$('.sidebar .emotion option[value="'+photo['emotion']+'"]').text();
			topLeftLabel=photo['emotion'];
		}

		if(photo['camera']) {
			if(topLeftLabel) {
				topLeftLabel=topLeftLabel+' | ';
			}
			// topLeftLabel=topLeftLabel+' '+$('.sidebar .camera option[value="'+photo['camera']+'"]').text();
			topLeftLabel=topLeftLabel+photo['camera'];
		}

		if(photo['film']) {
			if(topLeftLabel) {
				topLeftLabel=topLeftLabel+' | ';
			}
			// topLeftLabel=topLeftLabel+' '+$('.sidebar .camera option[value="'+photo['camera']+'"]').text();
			topLeftLabel=topLeftLabel+photo['film'];
		}




		if(photo['place']) {
			if(topLeftLabel) {
				topLeftLabel=topLeftLabel+' | ';
			}
			var placeLabel='';
			$('.sidebar select.place option').each(function() {
				if ($(this).val() === photo['place']) {
					placeLabel = $(this).text();
				}
			});
			if(placeLabel) {
				topLeftLabel=topLeftLabel+' '+placeLabel;
			}
			else {
				topLeftLabel=topLeftLabel+photo['place'];
			}
		}
		topLeftLabel=topLeftLabel.trim();
		if(topLeftLabel) {
			topLeftLabelHtml='<div class="top_left_label">'+topLeftLabel+'</div>';
		}

		if(photo['example']) {
			// only show [ Remix ] and [ Copy prompt ] for examples tab
			var outputImageButtonsHtml=
				actionCopyPromptHtml.replace('<br/>','')+
				actionCopycatHTML; // Added missing semicolon
		}



				



		return ''+
			'<div class="div_output_image '+extraClasses+'" data-offset="'+offsetCounter+'" data-photo-id="'+photo['photo_id']+'" data-model-id="'+photo['model_id']+'"'+modelIdsTag+' '+addNoiseDataTag+' '+predictionUrlDataTag+' '
				+' '+seedDataTag+' '+customLoraUrlTag+' '+talkingVideoScriptTag+' '+talkingVideoVoiceIdTag+' '+talkingVideoCaptionsTag+' '
				+cameraDataTag+filmDataTag+modelStrengthTag+placeDataTag+emotionDataTag+aiEditPromptDataTag+manualPromptDataTag+manualVideoPromptDataTag+inpaintMaskUrlDataTag+' '+manualNegativePromptDataTag+' '+rootPromptDataTag+ ' '+rootNegativePromptDataTag+(photo['epoch_published'] ? ' data-epoch-published="'+photo['epoch_published']+'"' : '')+'>'+
								topLeftLabelHtml+
				'<div class="div_output_image_buttons">'+
					outputImageButtonsHtml+
				'</div>'+
				'<div class="div_output_image_meta">'+
					extraMetaText+
				'</div>'+
				loadingSpinnerHTML
				+
				nsfwIconHTML
				+
				copycatImageHTML
				+
				'<div class="div_output_image_container">'+
					outputImageHTML
					+
					combineImageHTML
					+
					inpaintMaskHTML
				'</div>'+
			'</div>';
	}

	function in_array(needle, haystack, argStrict) {
		var key = '',
		strict = !! argStrict;

		//we prevent the double check (strict && arr[key] === ndl) || (!strict && arr[key] == ndl)
		//in just one for, in order to improve the performance 
		//deciding wich type of comparation will do before walk array
		if (strict) {
		for (key in haystack) {
			if (haystack[key] === needle) {
			return true;
			}
		}
		} else {
		for (key in haystack) {
			if (haystack[key] == needle) {
			return true;
			}
		}
		}

		return false;
	}

	function shuffle(array) {
		let currentIndex = array.length,  randomIndex;

		// While there remain elements to shuffle.
		while (currentIndex > 0) {

			// Pick a remaining element.
			randomIndex = Math.floor(Math.random() * currentIndex);
			currentIndex--;

			// And swap it with the current element.
			[array[currentIndex], array[randomIndex]] = [
			array[randomIndex], array[currentIndex]];
		}

		return array;
	}

	function setCookie(cname, cvalue, extimeDays) {
		var d = new Date();
		d.setTime(d.getTime() + (extimeDays*86400*1000));
		var expires = "expires="+d.toGMTString();
		document.cookie = cname + "=" + cvalue + "; " + expires+'; secure;domain=.'+location.hostname+';path=/; samesite=lax';
	}
	function getCookie(cname) {
		var name = cname + "=";
		var ca = document.cookie.split(';');
		for(var i=0; i<ca.length; i++) {
				var c = ca[i];
				while (c.charAt(0)==' ') c = c.substring(1);
				if (c.indexOf(name) != -1) return c.substring(name.length,c.length);
		}
		return "";
	}
	function str_replace(search, replace, subject, count) {
		var i = 0,
			j = 0,
			temp = '',
			repl = '',
			sl = 0,
			fl = 0,
			f = [].concat(search),
			r = [].concat(replace),
			s = subject,
			ra = Object.prototype.toString.call(r) === '[object Array]',
			sa = Object.prototype.toString.call(s) === '[object Array]';
		s = [].concat(s);
		if (count) {
			this.window[count] = 0;
		}

		for (i = 0, sl = s.length; i < sl; i++) {
			if (s[i] === '') {
				continue;
			}
			for (j = 0, fl = f.length; j < fl; j++) {
				temp = s[i] + '';
				repl = ra ? (r[j] !== undefined ? r[j] : '') : r[0];
				s[i] = (temp)
					.split(f[j])
					.join(repl);
				if (count && s[i] !== temp) {
					this.window[count] += (temp.length - s[i].length) / f[j].length;
				}
			}
		}
		return sa ? s : s[0];
	}

	function escapeHtml(text) {
		if(typeof text=='number') {
			var text=text.toString();
		}

		var map = {
			'&': '&amp;',
			'<': '&lt;',
			'>': '&gt;',
			'"': '&quot;',
			"'": '&#039;'
		};
		
		return text.replace(/[&<>"']/g, function(m) { return map[m]; });
	}

	function timeAgoShort(epoch) {
		var secs = ((new Date()).getTime() / 1000) - epoch;
		Math.floor(secs);
		var minutes = secs / 60;
		secs = Math.floor(secs % 60);
		if (minutes < 1) {
			return secs + (secs > 1 ? 's' : 's');
		}
		var hours = minutes / 60;
		minutes = Math.floor(minutes % 60);
		if (hours < 1) {
			return minutes + (minutes > 1 ? 'm' : 'm');
		}
		var days = hours / 24;
		hours = Math.floor(hours % 24);
		if (days < 1) {
			return hours + (hours > 1 ? 'h' : 'h');
		}
		/*var weeks = days / 7;
		days = Math.floor(days % 7);
		if (weeks < 1) {
			return days + (days > 1 ? 'd' : 'd');
		}
		var months = weeks / 4.35;
		weeks = Math.floor(weeks % 4.35);
		if (months < 1) {
			return weeks + (weeks > 1 ? 'w' : 'w');
		}*/
		var months = days / 30;
		days = Math.floor(days % 30);
		if (months < 1) {
			return days + (days > 1 ? 'd' : 'd');
		}
		var years = months / 12;
		months = Math.floor(months % 12);
		if (years < 1) {
			return months + (months > 1 ? 'mo' : 'mo');
		}
		years = Math.floor(years);
		return years + (years > 1 ? 'y' : 'y');
	}
	function loadingSpinnerStep(photo_id) {

		//
		// this function increments the loading spinner used when placeholder images are loading
		// it is tied to each photo_id in an array so each photo has its own progress spinner
		//

		if(typeof loadingSpinnerPhotoIdsFinished[photo_id]!=='undefined') {
			// if finished end
			return;
		}
		if(typeof loadingSpinnerStartTime[photo_id]=='undefined') {
			loadingSpinnerStartTime[photo_id]=microtime();
		}
		if(typeof loadingSpinnerProgress[photo_id]=='undefined') {
			loadingSpinnerProgress[photo_id]=0;
		}

		if(typeof polledServerCount[photo_id]=='undefined') {
			polledServerCount[photo_id]=0;
		}

		// base progress bar time on avg waiting time, e.g. 100% is the avg waiting time
		// var loadingSpinnerDelayBasedOnAvgWaitingTime=1000/60*avgWaitingTime/10;


		loadingSpinnerProgress[photo_id]=loadingSpinnerProgress[photo_id]+0.1;

		// if(loadingSpinnerProgress[photo_id]>99) {
		// 	loadingSpinnerProgress[photo_id]=99;
		// 	// end at 99
		// 	return;
		// }
		// if(loadingSpinnerProgress[photo_id]>95) {
		// 	// delay at end 
		// 	loadingSpinnerDelay[photo_id]=loadingSpinnerDelayBasedOnAvgWaitingTime+loadingSpinnerProgress[photo_id]*20;
		// }
		// else if(loadingSpinnerProgress[photo_id]>90) {
		// 	// delay at end 
		// 	loadingSpinnerDelay[photo_id]=loadingSpinnerDelayBasedOnAvgWaitingTime+loadingSpinnerProgress[photo_id]*8;
		// }
		// else if(loadingSpinnerProgress[photo_id]>75) {
		// 	// delay at end 
		// 	loadingSpinnerDelay[photo_id]=loadingSpinnerDelayBasedOnAvgWaitingTime+loadingSpinnerProgress[photo_id]*3;
		// }
		// else {
		// 	loadingSpinnerDelay[photo_id]=loadingSpinnerDelayBasedOnAvgWaitingTime;
		// }

		
		$('.photo-'+photo_id+' .loading_message').show();

		var timeSpentSeconds=(microtime()-loadingSpinnerStartTime[photo_id])/1000;

		if(timeSpentSeconds>60) {
			var addZero='';
			if((timeSpentSeconds-Math.floor(timeSpentSeconds/60)*60)<10) {
				addZero='0';
			}
			timeSpentText=Math.floor(timeSpentSeconds/60)+'m'+addZero+(timeSpentSeconds-Math.floor(timeSpentSeconds/60)*60).toFixed(0)+'s';
		}
		else {
			timeSpentText=timeSpentSeconds.toFixed(1)+'s';
		}
		if(!loadingSpinnerPhotoIdsPreprocessed[photo_id]) {
			// if(timeSpentSeconds>180) {
				// timeSpentText='Booting up model, this usually takes 3mins and it\'s fast once it\'s booted...<br/><br/>'+timeSpentText;
			// }
			if(timeSpentSeconds>1000) {
				timeSpentText='This is taking longer than expected. Try reloading the page.<br/><br/>Processing runs in the background and will show up when you come back later.<br/><br/>'+timeSpentText;
			}
		}

		// if($('.photo-'+photo_id).hasClass('video')) {
			// $('.photo-'+photo_id+' .loading_spinner .loading_message').html(timeSpentText+"<br/><br/>You can close this tab and come back later as the video is generated in the background. Once it's done it'll show up in your gallery here.");
		// }
		// else {
			$('.photo-'+photo_id+' .loading_spinner .loading_message').html(timeSpentText);
		// }

		// slowly unblur pic until done
		// var blurAmountPx=Math.round(25 * (1 - timeSpentSeconds / 180)*10)/10;
		// console.log(blurAmountPx);
		// console.log($('.photo-'+photo_id+' .div_output_image_container img.output_image').length);
		// console.log('.photo-'+photo_id+' .div_output_image_container img.output_image');
		// $('.photo-'+photo_id+'.postprocessing .div_output_image_container img.output_image').css('filter','blur('+blurAmountPx+'px)');



		if(!loadingSpinnerPhotoIdsFinished[photo_id]) {
			// loadingSpinnerTimeout[photo_id]=setTimeout(loadingSpinnerStep,loadingSpinnerDelay[photo_id],photo_id);
			window.requestAnimationFrame(function() {
				loadingSpinnerStep(photo_id);
			});
		}

		// console.log('loadingSpinnerStep '+photo_id+' '+loadingSpinnerDelay[photo_id]+'ms '+loadingSpinnerProgress[photo_id]+'%');
	}


	// on return to tab, set title back to original
	var originalPageTitle=window.document.title;
	window.addEventListener('visibilitychange', function() {
		if (!document.hidden) {
			window.document.title = originalPageTitle;
		}
	});

	var pageTitleGeneratingTimer=null;
	function waitForServerToGenerate(photo_id,what) {
		//
		// check every N seconds, if output_image_uid.json exists yet after requesting to generate it
		// the JSON contains the images
		//

		if(typeof photo_id==='undefined') {
			return;
		}

		if (pageTitleGeneratingTimer===null) {
			var dots = 0;
			pageTitleGeneratingTimer = setInterval(function() {
				dots = (dots + 1) % 4;
				window.document.title = 'Generating' + '.'.repeat(dots);
			}, 500);
		}

		// console.log('waitForServerToGenerate '+photo_id);
		polledServerCount[photo_id]++;


		// try N times then give up
		if(polledServerCount[photo_id]>5000) {
			// alert("Giving up, the AI API might be down, sometimes it's a bit unstable. Please try again in an hour! Upgrade to Pro and you can can come back later and your renders will show up when you reload the page in your own private workspace.");
			console.log('max polled, so stop trying now');
			// showStripeModal();
			$('.loading_spinner.main').hide();
			clearTimeout(loadingSpinnerTimeout);
			$('.loading_spinner .loading_message').text('');
			return;
		}

		var time=Math.floor(Date.now() / 1000);

		console.log(what);


		if(what=='poll_for_preprocessed') {
			var url='/assets/tmp/'+photo_id+'-pre.json?'+time;
		}
		else if(what=='poll_for_postprocessed') {
			var url='/assets/tmp/'+photo_id+'.json?'+time;
		}
		else if(what=='poll_for_auto_detect_clothes') {
			var url='/assets/tmp/'+photo_id+'-prompt.json?'+time;
			var val=$('div.sidebar textarea.manual_prompt').val();
			if(val.indexOf('...')>-1) {
				$('.sidebar textarea.manual_prompt').val('Analyzing clothes, this can take up to 30 seconds.');	
			}
			else if(val.indexOf('..')>-1) {
				$('.sidebar textarea.manual_prompt').val('Analyzing clothes, this can take up to 30 seconds...');
			}
			else if(val.indexOf('.')>-1) {
				$('.sidebar textarea.manual_prompt').val('Analyzing clothes, this can take up to 30 seconds..');
			}
		}
		else {
			alert("No poll for what in waitForServerToGenerate specified");
			return;
		}

		$.ajax({
			async:true,
			timeout: 3000,
			url: url,
			type: 'GET'
		}).done(function(photo) {

			if(what=='poll_for_auto_detect_clothes') {
				var prompt=photo;
				$('.loading_spinner.main').hide();

				if(prompt.prompt!='') {
					$('.sidebar textarea.manual_prompt').val('(full body frontal photo) of model wearing '+prompt.prompt+'');
					$('.sidebar textarea.manual_prompt').addClass('active');
				}

				autoDetectingPromptNow=false;
				// Remove auto-detecting animation class
				$('.sidebar textarea.manual_prompt').removeClass('auto-detecting');
				return;
			}


			if(photo['status']=='nsfw_detected') {
				alert("❌ "+(photo['error'] ? "Flagged: " + photo['error']+"\n\n" : "")+"Your photo was flagged by our API's content filter. You were not charged credits for this. This is not Photo AI's content filter by the way, it's our API's content filter.\n\nWe think AI content filters are a bit too strict and they have a lot of false positives, and we're trying to convince our API providers to be more chill.");
				$('.div_output_image.photo-'+photo['photo_id']).remove();
				return;
			}

			// <show finished image after>
				if(
					photo['status']=='finished' ||
					photo['status']=='nsfw_detected' /* if nsfw detected, also finish but don't show pic */
				) {
					// newly finished photo, add it
					console.log(photo['photo_id']+' is finished! adding to photos now');

					if(photo['status']=='finished') {
						if(photo.cost_in_credits) {
							// decrement user credits with cost of finished photo from the photo's cost_in_credits data
							if($('.photoCreditsLeft').data('credits')-photo.cost_in_credits<0) {
								// Not enough regular credits, check extra credits
								var remainingCost = photo.cost_in_credits - $('.photoCreditsLeft').data('credits');
								$('.photoCreditsLeft').data('credits',0);
								
								if($('.photoCreditsExtraLeft').data('credits')-remainingCost<0) {
									$('.photoCreditsExtraLeft').data('credits',0);
								} else {
									$('.photoCreditsExtraLeft').data('credits',
										$('.photoCreditsExtraLeft').data('credits')-remainingCost
									);
								}
								$('.photoCreditsExtraLeft').text(number_format(
									$('.photoCreditsExtraLeft').data('credits')
								));
								$('.photoCreditsExtraLeft').addClass('glow');
								setTimeout(function() {
									$('.photoCreditsExtraLeft').removeClass('glow')
								},500);
							}
							else {
								$('.photoCreditsLeft').data('credits',
									$('.photoCreditsLeft').data('credits')-photo.cost_in_credits
								);
								$('.photoCreditsLeft').text(number_format(
									$('.photoCreditsLeft').data('credits')
								));
								$('.photoCreditsLeft').addClass('glow');
								setTimeout(function() {
									$('.photoCreditsLeft').removeClass('glow')
								},500);
							}
						}
					}

					if(photo['photo_id'].split('-')[2]==1){
						//
						// only get avg waiting time from the FIRST photo of the batch
						// cause they run sequentially so it doesn't make sense to show
						// avg waiting time for later ones
						//
						avgWaitingTime=Math.round(photo['epoch_finished']-photo['epoch_queued']);

						if(avgWaitingTime>60) {
							var addZero='';
							if((avgWaitingTime-Math.floor(avgWaitingTime/60)*60)<10) {
								addZero='0';
							}
							var avgWaitingTimeText=Math.floor(avgWaitingTime/60)+'m'+addZero+(avgWaitingTime-Math.floor(avgWaitingTime/60)*60).toFixed(0)+'s';
						}
						else {
							avgWaitingTimeText=avgWaitingTime+'s';
						}

						$('.avgWaitingTime').text(avgWaitingTimeText);
					}

					var html=makePhotoBox(photo);
					
					// replace placeholder for specific photo with photo that's done
					$('.div_output_image.photo-'+photo['photo_id']).replaceWith(html);
					// $('.div_output_image.photo-'+photo['photo_id']).remove();
					// $('.div_output_images').prepend(html);

					// set finished so spinner stops
					loadingSpinnerPhotoIdsFinished[photo_id]=true;

					// check if all images are done and we can unlock take photo button
					if(
						!$('.div_output_images .div_output_image.placeholder').length &&
						!$('.div_output_images .div_output_image.postprocessing').length &&
						!$('.div_output_images .div_output_image.processing').length
					) {
						$('.action-take-photo').removeClass('disabled');
						$('html').removeClass('taking-photos');
						
						// play sound if all jobs are finished
						if(
							!isMobile &&
							document.hidden && // if user is not in the tab now, play sound
							$('.play_sound_on_finish').val()=='yes'
						) {
							var audio = new Audio('/assets/alert2.mp3');
							audio.play();
						}

						// set title back to original
						if (!document.hidden) {
							window.document.title = originalPageTitle;
						} else {
							window.document.title = 'Done!';
						}

						clearInterval(pageTitleGeneratingTimer);
						pageTitleGeneratingTimer=null;

					}
				}
			// </show finished image after>



		}).fail(function(reply) {
			// alert("error");
			// console.log('FAIL Poll try #'+polledServerCount[photo_id]+', not yet ready for '+photo_id);

							setTimeout(waitForServerToGenerate,(pollIntervalTime*2*Math.random()),photo_id,what);
					});
	}

	
	async function preprocessImageFromFileUploader(fileIndex) {					
		// console.log('=============');
		console.log('processing image #'+fileIndex);

		var totalFiles = $('.input_training_uploader')[0].files.length;

		trainingResolution=1024;

		$('.div_training_uploader .loading_spinner').show();
		$('.div_training_uploader .loading_spinner .loading_message').show();
		$('.div_training_uploader .loading_spinner .loading_message').text(
			(fileIndex+1)+'/'+totalFiles
		);
		$('.div_training_uploader_center').hide();

		// <process image>
			var file=$('.input_training_uploader')[0].files[fileIndex];
			// console.log(file.name);

			var fileReader = new FileReader();

			if(typeof file==='undefined') {
				// not a good file, skip
				console.log('Bad file: '+(typeof file));
				// preprocessImageFromFileUploader(fileIndex+1);
				return;
			}

			fileReader.readAsDataURL(file);

			fileReader.onload = function () {

				console.log('#'+fileIndex+' fileReader.onload');

				// <flux>
					var img = document.createElement('img');
					img.src = fileReader.result;

					$('.div_training_uploader .img_training').attr('src',fileReader.result);

					img.onerror = async function() {
						console.log('#'+fileIndex+' error creating img object, skipping photo');
						preprocessImageFromFileUploader(fileIndex+1);
						return;
					}

					img.onload = async function() {
						var maxWidth = 1024;
						var maxHeight = 1024;
						
						var width = img.width;
						var height = img.height;
						
						if (width > height) {
							if (width > maxWidth) {
								height *= maxWidth / width;
								width = maxWidth;
							}
						} else {
							if (height > maxHeight) {
								width *= maxHeight / height;
								height = maxHeight;
							}
						}

						var canvas = document.createElement('canvas');
						canvas.width = width;
						canvas.height = height;
						
						var ctx = canvas.getContext('2d');
						ctx.drawImage(img, 0, 0, width, height);
						
						var dataURL = canvas.toDataURL('image/jpeg');

						$('.div_training_uploader .samples').append('<img class="sample" src="'+dataURL+'" />');

						var blob = await new Promise(resolve => canvas.toBlob(resolve,'image/jpeg'));
						filesToUploadBlobs.push(blob);

						// <auto-detect model attributes for first image>
						if (fileIndex === 0 && blob) {
							// Trigger auto-detection using the first uploaded image
							autoDetectModelAttributes(blob);
						}
						// </auto-detect model attributes for first image>

						// <if done all quit>
							if(fileIndex>=(totalFiles-1)) {
								// done all pics, start uploading here?
								console.log('Done! Processed '+totalFiles+', of which '+filesToUploadBlobs.length+' passed');
								$('.div_training_uploader').addClass('primed');
								$('.action-train-model').removeClass('disabled');
								$('.div_training_uploader .loading_spinner').hide();
								$('.div_training_uploader').css('background-image','');
								$('.div_training_uploader').removeClass('active');
								$('.div_training_uploader_center').show();
								
								// if we here, all good
								// set train button to blinking
								$('.action-train-model').addClass('blinking');
							}
							else {
								// more pics to do! do next pic
								console.log('Now have '+(filesToUploadBlobs.length)+' usable photos');
								preprocessImageFromFileUploader(fileIndex+1)
							}
						// </if done all quit>

					}
				// <flux>
			}
		// </process image>

	}

	// <auto-detect model attributes function>
		function autoDetectModelAttributes(imageBlob) {
			// Only auto-detect for real person models, not AI influencers
			if ($('.select_create_model_real_or_ai').val() === 'ai_influencer') {
				return;
			}

			// Show loading indicator
			$('.training_p').before('<div class="model-auto-detect-loading">🤖 Analyzing images to detect model attributes...</div>');
			
			// Prepare FormData for the request
			var formData = new FormData();
			formData.append('image', imageBlob, 'training_image.jpg');

			// Make AJAX request to auto-detection endpoint
			$.ajax({
				url: '/auto_detect_features',
				type: 'POST',
				data: formData,
				processData: false,
				contentType: false,
				dataType: 'json',
				timeout: 30000,
				success: function(response) {
					$('.model-auto-detect-loading').remove();
					
					if (response.success) {
						// Auto-populate form fields with detected values
						// but only if they're not set yet
						if (response.name && $('.input_create_model_name').val() === '') {
							$('.input_create_model_name').val(response.name);
						}
						if (response.gender && $('.select_create_model_gender').val() === '') {
							$('.select_create_model_gender').val(response.gender);
						}
						if (response.age && $('.input_create_model_age').val() === '') {
							$('.input_create_model_age').val(response.age);
						}
						if (response.ethnicity && $('.select_create_model_ethnicity').val() === '') {
							$('.select_create_model_ethnicity').val(response.ethnicity);
						}
						if (response.eye_color && $('.select_create_model_eye_color').val() === '') {
							$('.select_create_model_eye_color').val(response.eye_color);
						}
						if (response.hair_bald && $('.select_create_model_hair_bald').val() === '') {
							$('.select_create_model_hair_bald').val(response.hair_bald);
						}
						
						// Add visual feedback
						$('.training_p').before('<div class="model-auto-detect-success">✅ Model attributes auto-detected! You can modify them above if you want.</div>');
						setTimeout(function() {
							$('.model-auto-detect-success').fadeOut(function() {
								$(this).remove();
							});
						}, 5000);
					} else {
						console.log('Auto-detection failed:', response);
					}
				},
				error: function(xhr, status, error) {
					$('.auto-detect-loading').remove();
					console.log('Auto-detection error:', error);
					// Fail silently - user can fill manually
				}
			});
		}
	// </auto-detect model attributes function>

	$(function() {
		// monitor changes to the ai influencer inputs
		// and live generate a preview
		$('.select_create_model_real_or_ai, .input_create_model_name, .select_create_model_gender, .input_create_model_age, .select_create_model_ethnicity, .select_create_model_nationality, .select_create_model_height, .select_create_model_hair, .select_create_model_hair_color, .select_create_model_eye_color, .select_create_model_body, .select_create_model_breast, .select_create_model_butt, .select_create_model_beard')
		.on('change', function() {
			if ($('.select_create_model_real_or_ai').val() === 'ai_influencer') {
				previewAIInfluencer();
			}
		});
	});

	function previewAIInfluencer() {
		console.log('previewAIInfluencer');

		if(!empty($('.input_create_model_age').val()) && $('.input_create_model_age').val()<18) {
			return;
		}

		$('.div_create_model_ai_influencer_preview .loading_spinner').show();
		
		$.ajax({
			type: 'POST',
			url: '/?action=preview-ai-influencer',
			dataType: 'json',
			data: {
				gender: $('.select_create_model_gender').val(),
				age: $('.input_create_model_age').val(),
				ethnicity: $('.select_create_model_ethnicity').val(),
				nationality: $('.select_create_model_nationality').val(),
				height: $('.select_create_model_height').val(),
				beard: $('.select_create_model_beard').val(),
				hair: $('.select_create_model_hair').val(),
				hair_color: $('.select_create_model_hair_color').val(),
				eye_color: $('.select_create_model_eye_color').val(),
				body: $('.select_create_model_body').val(),
				breast: $('.select_create_model_breast').val(),
				butt: $('.select_create_model_butt').val()
			}
		}).done(function(response) {
			// Handle the response from the server
			// console.log(response);
			$('.div_create_model_ai_influencer_preview .loading_spinner').hide();
			if(response.img) {
				console.log(response.img);
				$('.img_create_model_ai_influencer_preview').attr('src',response.img);
			}
		});
	}


	var creatingAIInfluencerAlready=false;

	function createAIInfluencer() {

		if(creatingAIInfluencerAlready) {
			return;
		}

		creatingAIInfluencerAlready=true;

		if ($('.input_create_model_name').val().trim() === '') {
			alert('Please enter a name for your AI influencer.');
			$('.input_create_model_name').focus();
			return;
		}

		if ($('.select_create_model_gender').val() === '') {
			alert('Please select a gender for your AI influencer.');
			$('.select_create_model_gender').focus();
			return;
		}

		if ($('.input_create_model_age').val().trim() === '') {
			alert('Please enter an age for your AI influencer.');
			$('.input_create_model_age').focus();
			return;
		}

		if ($('.select_create_model_ethnicity').val() === '') {
			alert('Please select an ethnicity for your AI influencer.');
			$('.select_create_model_ethnicity').focus();
			return;
		}

		if ($('.select_create_model_height').val() === '') {
			alert('Please select a height for your AI influencer.');
			$('.select_create_model_height').focus();
			return;
		}

		if ($('.select_create_model_hair').val() === '') {
			alert('Please select a hair style for your AI influencer.');
			$('.select_create_model_hair').focus();
			return;
		}

		if ($('.select_create_model_nationality').val() === '') {
			alert('Please select a nationality for your AI influencer.');
			$('.select_create_model_nationality').focus();
			return;
		}

		if ($('.select_create_model_hair_color').val() === '') {
			alert('Please select a hair color for your AI influencer.');
			$('.select_create_model_hair_color').focus();
			return;
		}

		if ($('.select_create_model_eye_color').val() === '') {
			alert('Please select an eye color for your AI influencer.');
			$('.select_create_model_eye_color').focus();
			return;
		}

		if ($('.select_create_model_body').val() === '') {
			alert('Please select a body type for your AI influencer.');
			$('.select_create_model_body').focus();
			return;
		}

		if ($('.select_create_model_gender').val() === 'f') {
			if ($('.select_create_model_breast').val() === '') {
				alert('Please select a chest size for your AI influencer.');
				$('.select_create_model_breast').focus();
				return;
			}

			if ($('.select_create_model_butt').val() === '') {
				alert('Please select a hip size for your AI influencer.');
				$('.select_create_model_butt').focus();
				return;
			}
		}

		
		$('.loading_spinner.main').show();

		$.ajax({
			type: 'POST',
			url: '/?action=create-ai-influencer',
			dataType: 'json',
			data: {
				name: $('.input_create_model_name').val(),
				gender: $('.select_create_model_gender').val(),
				age: $('.input_create_model_age').val(),
				ethnicity: $('.select_create_model_ethnicity').val(),
				nationality: $('.select_create_model_nationality').val(),
				height: $('.select_create_model_height').val(),
				beard: $('.select_create_model_beard').val(),
				hair: $('.select_create_model_hair').val(),
				hair_color: $('.select_create_model_hair_color').val(),
				eye_color: $('.select_create_model_eye_color').val(),
				body: $('.select_create_model_body').val(),
				breast: $('.select_create_model_breast').val(),
				butt: $('.select_create_model_butt').val()
			}
		}).done(function(response) {
			// Handle the response from the server
			// console.log(response);
			
			alert(response.message);

			// now reload the page
			// but wait for sample pics to be made
			window.location.reload();

		});

	}


	function uploadProcessedTrainingImages(filesToUploadBlobs) {

		if(filesToUploadBlobs.length==0) {
			alert("No photos passed, please select more photos");
			return;
		}
		
		if(
			filesToUploadBlobs.length<5		) {
			alert("You don't have enough photos that are good enough to be used for creating a model. For photorealistic results we recommend selecting at least 5+ photos, try selecting more varied input photos.");
			trainingUploadResemblanceCheckDataURLs=[];
			filesToUploadBlobs=[];
			userIsUploading=false;
			$('.input_training_uploader').val('');
			$('.input_training_uploader').removeClass('disabled');
			
			$('.div_training_uploader').css('background-image','');
			$('.div_training_uploader').removeClass('active');
			$('.div_training_uploader_center').show();
			$('.div_training_uploader').removeClass('primed');
			$('.action-train-model').removeClass('disabled');
			$('.div_training_uploader .loading_spinner').hide();
			return;
		}

		$('.loading_spinner.main').show();

		// avoid getting pressed twice
		$('.action-train-model').addClass('disabled');

		console.log('uploadProcessedTrainingImages: '+filesToUploadBlobs.length+' files to upload');

		// <auto skip over 50 photos because training will time out>
			if(filesToUploadBlobs.length>60) {
				filesToUploadBlobs=shuffle(filesToUploadBlobs);
				filesToUploadBlobs=filesToUploadBlobs.slice(0,60);
				console.log("Shuffled photos and took max of 60");
			}
		// </auto skip over 50 photos because training will time out>


		// <first zip all images>
			var zip = new JSZip();

			// <cap filesToUploadBlobs to max 30>
				// 2025-08-29: removed this cause maybe it caused worse resembling models, also see training_upload.php
				// if(filesToUploadBlobs.length > 30) {
				// 	filesToUploadBlobs = filesToUploadBlobs.slice(0, 30);
				// 	console.log("Capped filesToUploadBlobs to max 30 files");
				// }
			// </cap filesToUploadBlobs to max 30>

			for (var i = 0; i < filesToUploadBlobs.length; i++) {

				var blob=filesToUploadBlobs[i];

				if($('.select_create_model_gender').val()=='m') {
					var className='man';
				}
				else if($('.select_create_model_gender').val()=='f') {
					var className='woman';
				}
				else if($('.select_create_model_gender').val()=='o') {
					var className='img';
				}
				else {
					var className=$('.select_create_model_gender').val();
				}
				console.log('zipping file '+className+'-'+(i+1)+'.jpg');

				zip.file(className+'-'+(i+1)+'.jpg', blob);
			}

			zip.generateAsync({type:"blob"}).then(function(zipContent) {

				// <upload zip>
					var uploadUrl='/training_upload';

					var formData = new FormData();
					formData.append('file',zipContent);
					formData.append('name',$('.input_create_model_name').val());
					formData.append('gender',$('.select_create_model_gender').val());
					formData.append('age',$('.input_create_model_age').val());
					formData.append('ethnicity',$('.select_create_model_ethnicity').val());
					formData.append('hair',$('.select_create_model_hair_bald').val());
					formData.append('eye_color',$('.select_create_model_eye_color').val());
					// formData.append('permission',$('.select_create_model_permission').val());
					formData.append('training_photo_count',filesToUploadBlobs.length);

		 			var xhttp = new XMLHttpRequest();
	 					xhttp.open('POST', uploadUrl, true);

					xhttp.onreadystatechange = function() {
						if (this.readyState == 4 && this.status == 200) {
							$('.input_training_uploader').val('');
							$('.div_training_uploader').css('background-image','');
							$('.div_training_uploader').removeClass('active');
							$('.div_training_uploader_center').show();
							$('.input_create_model_name').val('');
							$('.select_create_model_gender').val('');
							$('.select_create_model_eye_color').val('');
							$('.input_create_model_age').val('');
							$('.select_create_model_ethnicity').val('');
							$('.select_create_model_body').val('');
							$('.select_create_model_hair').val('');
							$('.select_create_model_hair_color').val('');
							$('.select_create_model_hair_bald').val('');

							var reply=JSON.parse(xhttp.responseText);
							if(!reply.success) {
								$('.action-train-model').removeClass('disabled');
								$('.loading_spinner.main').hide();
								alert(reply.message);
								return;
							}

							// alert('Uploaded! It will take about 2 seconds to create your model. Come back then to take photos with it! You can close this tab now if you want.');

							// now reload page
							window.location.reload();

						}
					}
					xhttp.send(formData);
				// </upload zip>

			});
		// </first zip all images>

	}

