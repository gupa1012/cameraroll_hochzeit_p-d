	.big-flash {
		pointer-events: none;
		position:fixed; 
		top:0;
		left:0;
		width:100%;
		height:100%;
		background-color:#fff;
		display:none;
		z-index:10000;
	}
	.flash {
		pointer-events: none;
		position:fixed; 
		top:0;
		left:0;
		width:100%;
		height:100%;
		background-color:rgba(255,255,255,0.5);
		display:none;
		z-index:10000;
	}

	.loading_spinner {
		height:auto;
		text-align: center;
		transform: translateX(-50%);
		left: 50%;
		position: absolute;
	}
	.loading_spinner .loading_spinner_svg {
		width:3em;
		height:3em;
	}

	.div_import_uploader .loading_spinner,
	.div_product_uploader .loading_spinner,
	.div_product_scene_uploader .loading_spinner,
	.div_mocap_video_uploader .loading_spinner,
	.div_mocap_person_uploader .loading_spinner,
	.div_clothing_uploader .loading_spinner,
	.div_copycat_uploader .loading_spinner,
	.div_create_model_ai_influencer_preview .loading_spinner,
	.div_training_uploader .loading_spinner,
	.div_output_image .loading_spinner {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translateX(-50%) translateY(-50%);
		z-index: 2;
	}

	.loading_spinner_circle {
		stroke-width: 6;
		stroke-miterlimit: 10;
	}

	.loading_spinner_circle--spinner {
		stroke-dasharray: 1,220;
		stroke-dashoffset: 0;
		-webkit-animation: loading_spinner_dash 1.5s ease-in-out infinite,color 3s ease-in-out infinite;
		animation: loading_spinner_dash 1.5s ease-in-out infinite,color 3s ease-in-out infinite;
		stroke-linecap: square;
		stroke:var(--loading-spinner-color);
	}

	.loading_spinner_circle {
		stroke-width: 6;
		stroke-miterlimit: 10;
	}


	.loading_spinner .loading_spinner_circle {
		stroke:#111 !important;
	}

	.loading_spinner .loading_spinner_circle--spinner {
		stroke:#fff !important;
	}

	.loading_spinner_svg {
		-webkit-animation-duration: 2s;
		animation-duration: 2s;
		-webkit-animation-iteration-count: infinite;
		animation-iteration-count: infinite;
		-webkit-animation-name: loading_spinner_rotate;
		animation-name: loading_spinner_rotate;
		-webkit-animation-timing-function: linear;
		animation-timing-function: linear;
	}
	.loading_spinner .loading_message {
		pointer-events:none;
		margin:0 auto;
		width:100%;
		display:none;
		max-width:95vw;
		pointer-events:none;
		background:none;
		color:var(--global-text-color);
		padding:1em;
		padding:7px;
		padding-left:14px;
		padding-right:14px;
		font-weight:800;
		border-radius:12px;
		border:none;
	}


	.loading_spinner.main {
		z-index:201;
	}
	.loading_spinner {
		pointer-events:none;
		display:none;
		z-index:1;
		position:fixed;
		width:90%;
		top:50%;
		left:50%;
		transform:translateX(-50%) translateY(-50%);
	}
	.loading_spinner .loading_message {
		font-variant-numeric: tabular-nums;
		pointer-events:none;
		margin:0 auto;
		width:100%;
		max-width:95vw;
		pointer-events:none;
		color:var(--global-text-color);
		padding:1em;
		padding:7px;
		padding-left:14px;
		padding-right:14px;
		font-weight:800;
		border-radius:12px;
		display:none;
		color: #fff;
	}
	

	@keyframes loading_spinner_rotate {
		100% {
			-webkit-transform: rotate(1turn);
			transform: rotate(1turn);
			color: transparent;
		}
	}

	@keyframes loading_spinner_dash {
		0% {
			stroke-dasharray: 1,220;
			stroke-dashoffset: 0;
		}
		50% {
			stroke-dasharray: 97.9,220;
			stroke-dashoffset: -38.5;
		}
		100% {
			stroke-dasharray: 97.9,220;
			stroke-dashoffset: -136.4;
		}
	}

	@keyframes loading_spinner_color {
		0% {
			stroke: var(--loading-spinner-color);
		}
		50% {
			stroke: var(--loading-spinner-color);
		}
		100% {
			stroke: var(--loading-spinner-color);
		}
	}

	.alert,
	.notice,
	.error {
		display: block;
		padding: 14px;
		border: 1px solid #ff5252;
		border-radius: 12px;
		color: #ff5252;
		margin:21px;
	}
	.alert h3,
	.notice h3,
	.error h3,
	.alert p,
	.notice p,
	.error p {
		/* internal p or h3 */
		margin-left:0;
		margin-right:0;
		margin-top:0;
		margin-bottom:0;
	}

	.error a:not(.button) {
		color: #ff5252;
	}
	.notice {
		color:#ffc924;
		border-color: #ffc924;
	}
	.notice a:not(.button) {
		color:#ffc924;
	}
	.alert {
		border-color: #2bde73;
		color: #2bde73;
	}
	.alert a:not(.button) {
		color: #2bde73;
	}
	@media (max-width:600px) {
		.hide-on-mobile {
			display: none !important;
		}
	}

	hr {
		border:none;
		border-bottom:1px solid var(--global-border-color);
		margin-top:28px;
		display:block;
	}

	.model_selector hr {
		margin-top:7px;
		margin-bottom:7px;
		margin-left:-7px;
		margin-right:-7px;
	}

	.action-undelete-photo,
	.action-delete-photo {
		z-index:10;
		position: absolute;
		display:none;
		top: 0;
		right: 0;
		padding-right: 7px;
		padding-top: 7px;
		line-height: .5;
		font-size: 40px;
		color: #fff;
		cursor:pointer;

		/* add extra touch space for mobile fingers */
		padding-left:14px;
		padding-bottom:14px;
	}
	.action-undelete-photo {
		top:auto;
		bottom:0;
		padding-bottom:7px;
	}

	.action-undelete-photo:hover,
	.action-delete-photo:hover {
		opacity:0.75;
	}
	.action-undelete-photo:active,
	.action-delete-photo:active {
		opacity:0.5;
	}
	@media (min-width:600px) {
		.div_output_image.finished:hover .action-undelete-photo,
		.div_output_image.finished:hover .action-delete-photo {
			display:block;
		}
	}
	@media (max-width:600px) {
		.div_output_image.active .action-undelete-photo,
		.div_output_image.active .action-delete-photo {
			display:block;
		}	
	}

	.image_viewer .action-grab-video-frame {
		display:none;
	}
	.image_viewer .action-play-slow-motion {
		display: none;
	}
	.image_viewer.video .action-play-slow-motion {
		display: none;
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		left: 20px;
		background:none;
		color: #fff;
		border:2px solid #fff;
		font-weight: bold;
		padding: 8px 16px;
		border-radius: 6px;
		font-size: 14px;
		cursor: pointer;
		user-select: none;
		z-index: 104;
		backdrop-filter: blur(10px);
		transition: all 0.2s ease;
	}
	.image_viewer.video:hover .action-play-slow-motion {
		display: block;
	}
	@media (max-width: 600px) {
		.image_viewer.video .action-play-slow-motion {
			display: block;
		}
	}
	.image_viewer.video .action-play-slow-motion:hover {
		background: rgba(255, 255, 255, 1);
		color:#000;
	}
	.image_viewer.video .action-play-slow-motion:active {
		background: rgba(255, 255, 255, 0.8);
		color:#000;
	}
	.image_viewer.three_d .action-grab-video-frame,
	.image_viewer.video .action-grab-video-frame {
		position: absolute;
		display: none;
		top: calc(calc(100% / 2) - 40px);
		right: 0;
		padding-right: 7px;
		padding-top: 7px;
		cursor:pointer;

		/* add extra touch space for mobile fingers */
		padding-right:14px;
		padding-bottom:14px;
	}

	@media (max-width:600px) {
		/* on mobile always show grab frame in the video viewer without hover */
		.image_viewer.video .action-grab-video-frame {
			display:block;
		}
	}

	.image_viewer.three_d .action-grab-video-frame:hover,
	.image_viewer.video .action-grab-video-frame:hover {
		opacity:0.75;
	}
	.image_viewer.three_d .action-grab-video-frame:active,
	.image_viewer.video .action-grab-video-frame:active {
		opacity:0.5;
	}
	.action-save-photo {
		z-index:10;
		position: absolute;
		display: none;
		top: 0;
		left: 0;
		padding-left: 7px;
		padding-top: 7px;
		cursor:pointer;

		/* add extra touch space for mobile fingers */
		padding-right:14px;
		padding-bottom:14px;
	}
	.action-save-photo:hover {
		opacity:0.75;
	}
	.action-save-photo:active {
		opacity:0.5;
	}
	.action-save-photo.saved {
		display:block;
	}
	.action-save-photo.saved svg {
		fill: #fff;
		-webkit-filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
		filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
	}
	@media (hover: hover) {
		.action-save-photo:hover svg {
			fill: #fff;
			-webkit-filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
			filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
		}
	}
	.action-undelete-photo.trashed svg,
	.action-undelete-photo:hover svg,
	.action-delete-photo.trashed svg,
	.action-delete-photo:hover svg {
		fill: #fff;
		-webkit-filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
		filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.35));
	}
	.action-undelete-photo.trashed svg path,
	.action-undelete-photo:hover svg path,
	.action-delete-photo.trashed svg path,
	.action-delete-photo:hover svg path {
		fill-rule: initial;
	}



	@media (min-width:600px) {
		.div_output_image.finished:hover .action-save-photo {
			display:block;
		}
	}
	@media (max-width:600px) {
		.div_output_image.active .action-save-photo {
			display:block;
		}	
	}
	.action-save-photo svg {
		width: 30px;
		height: 25px;
		stroke-width: 30;
		stroke: #fff;
		fill: none;
	}
	.runtime {
		font-family:monospace;
		position:absolute;
		pointer-events:none;
		top:0;
		right:0;
		font-size:8px;
		font-weight:bold;
/*		z-index:1000000000;*/
		z-index:99;
		opacity:0.5;
		padding:3.5px;
		text-shadow: 1px 1px 1px var(--global-background-color);
	}
	.div_stripe_modal_disclaimer {
		font-size: 11px;
		margin-top: 28px;
		max-width: 900px;
		margin: 14px auto;
		opacity:0.5;
		margin-top:14px;
	}
	.modal_alert_backdrop,
	.div_stripe_modal_backdrop,
	.div_login_modal_backdrop,
	.image_viewer_backdrop,
	.inpaint_editor_backdrop,
	.crop_editor_backdrop,
	.talking_video_modal_backdrop,
	.voice_selector_modal_backdrop {
		cursor: pointer;
		position: fixed;
		z-index: 100;
		background: rgba(0,0,0,0.85);
		backdrop-filter: blur(12px);
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		display: none;
	}
	.div_stripe_modal_backdrop {
		cursor:default;
	}
	.image_viewer_backdrop {
/*		cursor:zoom-out;*/
		cursor:default;
	}
	.image_viewer_arrow_left,
	.image_viewer_arrow_right {
		display:none;
	}
	.image_viewer_arrow_left.visible,
	.image_viewer_arrow_right.visible {
		display:block;
	}
	.image_viewer_arrow_left {
		position:absolute;
		top:50%;
		left:14px;
		width:30px;
		transform:translateY(-50%);
		z-index:10;
		cursor:pointer;
	}
	.image_viewer_arrow_right {
		position:absolute;
		top:50%;
		right:14px;
		width:30px;
		transform:translateY(-50%);
		z-index:10;
		cursor:pointer;
	}
	.image_viewer_arrow_left:hover,
	.image_viewer_arrow_right:hover {
		opacity:0.75;
	}
	.image_viewer_arrow_left:active,
	.image_viewer_arrow_right:active {
		opacity:0.5;
	}
	@media (max-width:700px) {
		.image_viewer_arrow_left.visible,
		.image_viewer_arrow_right.visible {
			display:none;
		}
	}
	@media (max-width:600px) {
		/* Hide fixed arrows on mobile - use in-flow mobile nav instead */
		.image_viewer_arrow_left.visible,
		.image_viewer_arrow_right.visible {
			display:none;
		}
	}
	/* Image viewer sidebar - desktop only */
	.image_viewer_sidebar {
		display: none;
		position: fixed;
		z-index: 103;
		top: 20px;
		bottom: 20px;
		right: 20px;
		width: 350px;
		overflow-y: auto;
		background: rgba(22,22,22,0.95);
		border-radius: var(--global-border-radius);
		border: 1px solid rgba(255,255,255,0.1);
		padding: 16px;
		flex-direction: column;
	}
	@media (min-width: 1200px) {
		.image_viewer_sidebar.visible {
			display: flex;
		}
	}
	.image_viewer_sidebar_close {
		position: absolute;
		top: 12px;
		right: 12px;
		width: 28px;
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 24px;
		color: rgba(255,255,255,0.6);
		cursor: pointer;
		border-radius: 50%;
		transition: background 0.15s, color 0.15s;
	}
	.image_viewer_sidebar_close:hover {
		background: rgba(255,255,255,0.1);
		color: rgba(255,255,255,0.9);
	}
	.image_viewer_sidebar_section {
		margin-bottom: 16px;
	}
	.image_viewer_sidebar_section:last-child {
		margin-bottom: 0;
	}
	.image_viewer_sidebar_section_header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: 600;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: rgba(255,255,255,0.5);
		margin-bottom: 8px;
	}
	.image_viewer_sidebar_prompt_text {
		font-size: 13px;
		line-height: 1.5;
		color: rgba(255,255,255,0.9);
		word-break: break-word;
		cursor: pointer;
		transition: background 0.15s;
		padding: 8px;
		margin: -8px;
		border-radius: 6px;
		max-height: 350px;
		overflow-y: auto;
	}
	.image_viewer_sidebar_prompt_text:hover {
		background: rgba(255,255,255,0.05);
	}
	.image_viewer_sidebar_photo_prompt_text {
		font-size: 13px;
		line-height: 1.5;
		color: rgba(255,255,255,0.9);
		word-break: break-word;
		max-height: 350px;
		overflow-y: auto;
		padding: 8px;
		margin: -8px;
		border-radius: 6px;
	}
	.image_viewer_sidebar_info_row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 6px 0;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}
	.image_viewer_sidebar_info_row:last-child {
		border-bottom: none;
	}
	.image_viewer_sidebar_info_label {
		color: rgba(255,255,255,0.5);
		font-size: 12px;
	}
	.image_viewer_sidebar_info_value {
		color: rgba(255,255,255,0.9);
		font-size: 12px;
	}
	.image_viewer_sidebar_actions {
		margin-top: auto;
	}
	.image_viewer_sidebar_actions_grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 8px;
	}
	.image_viewer_sidebar_actions_grid .button {
		width: 100%;
		text-align: center;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 600;
		padding: 12px 10px;
		background: transparent;
		border: 1px solid rgba(255,255,255,0.15);
		border-radius: 12px;
		color: #fff;
		transition: background 0.15s, border-color 0.15s;
	}
	.image_viewer_sidebar_actions_grid .button:hover {
		background: rgba(255,255,255,0.1);
		color: #fff;
	}
	.image_viewer_sidebar_actions_grid .button img {
		width: 18px;
		height: 18px;
		filter: invert(1);
	}
	/* Bottom action bar - horizontal buttons below image */
	.image_viewer_bottom_actions {
		display: none;
		position: fixed;
		z-index: 104;
		bottom: 40px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(30,30,30,0.95);
		border-radius: 50px;
		padding: 8px 12px;
		border: 1px solid rgba(255,255,255,0.1);
	}
	@media (min-width: 700px) {
		.image_viewer_bottom_actions.visible {
			display: flex;
			gap: 4px;
		}
	}
	@media (min-width: 1200px) {
		.image_viewer_bottom_actions {
			left: calc(50% - 195px);
		}
	}
	.image_viewer_bottom_actions .bottom-action {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 10px 16px;
		border-radius: 50px;
		background: transparent;
		color: rgba(255,255,255,0.9);
		font-size: 14px;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s;
		white-space: nowrap;
	}
	.image_viewer_bottom_actions .bottom-action:hover {
		background: rgba(255,255,255,0.1);
	}
	.image_viewer_bottom_actions .bottom-action img {
		width: 16px;
		height: 16px;
		filter: invert(1);
	}
	/* Hide image-only actions in desktop sidebar/bottom bar when viewing a video */
	.image_viewer.video .image_viewer_sidebar [data-action="action-relight"],
	.image_viewer.video .image_viewer_sidebar [data-action="action-zoom-out"],
	.image_viewer.video .image_viewer_sidebar [data-action="action-add-grain"],
	.image_viewer.video .image_viewer_sidebar [data-action="action-make-3d-model"],
	.image_viewer.video ~ .image_viewer_sidebar [data-action="action-relight"],
	.image_viewer.video ~ .image_viewer_sidebar [data-action="action-zoom-out"],
	.image_viewer.video ~ .image_viewer_sidebar [data-action="action-add-grain"],
	.image_viewer.video ~ .image_viewer_sidebar [data-action="action-make-3d-model"],
	.image_viewer.video ~ .image_viewer_bottom_actions [data-action="action-copycat"],
	.image_viewer.video ~ .image_viewer_bottom_actions [data-action="action-set-product-scene"],
	.image_viewer.video ~ .image_viewer_bottom_actions [data-action="action-inpaint"],
	.image_viewer.video ~ .image_viewer_bottom_actions [data-action="action-crop"] {
		display: none !important;
	}
	/* Hide non-applicable actions in desktop sidebar/bottom bar when viewing a 3D model */
	.image_viewer.three_d .image_viewer_sidebar [data-action="action-relight"],
	.image_viewer.three_d .image_viewer_sidebar [data-action="action-zoom-out"],
	.image_viewer.three_d .image_viewer_sidebar [data-action="action-add-grain"],
	.image_viewer.three_d .image_viewer_sidebar [data-action="action-make-talking-video"],
	.image_viewer.three_d .image_viewer_sidebar [data-action="action-make-3d-model"],
	.image_viewer.three_d ~ .image_viewer_sidebar [data-action="action-relight"],
	.image_viewer.three_d ~ .image_viewer_sidebar [data-action="action-zoom-out"],
	.image_viewer.three_d ~ .image_viewer_sidebar [data-action="action-add-grain"],
	.image_viewer.three_d ~ .image_viewer_sidebar [data-action="action-make-talking-video"],
	.image_viewer.three_d ~ .image_viewer_sidebar [data-action="action-make-3d-model"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-copycat"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-make-video"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-upscale"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-set-product-scene"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-inpaint"],
	.image_viewer.three_d ~ .image_viewer_bottom_actions [data-action="action-crop"] {
		display: none !important;
	}
	.div_stripe_modal,
	.div_login_modal {
		position: fixed;
		display: none;
		border-radius: 12px;
		border: 1px solid rgba(255,255,255,0.2);
		transform: translateX(-50%) translateY(-50%);
		left: 50%;
		top: 50%;
		background: #111;
		padding: 42px;
		z-index: 101;
		/*max-width: 500px;*/
		overflow-y: auto;
	}
	.div_login_modal {
		max-width:400px;
		width:100%;
	}
	.div_stripe_modal {
		min-height: 100vh;
		max-height: 100vh;
		width:100%;
		max-width:100vw;
		text-align: center;
		padding: 21px;
	}
	.stripe_pricing_table {
		min-height: 75vh;
		display: block;
		margin-bottom: -7px;
	}
	.div_login_modal .input_email {
		background:#fff;
		color:#000;
	}
	.div_login_modal .input_email:focus,
	.div_login_modal .input_email:active {
		border:2px solid #f47353;
	}
	.div_login_modal .button {
		width: 100%;
		margin: 0;
/*		margin-bottom: 7px;*/
	}
	.div_login_modal h2 {
		margin: 0;
		margin-bottom: 14px;
		text-align: center;
	}
	.div_login_modal input {
		width: 100%;
		margin: 0;
		margin-bottom: 7px;
	}
	
	/* Talking Video Modal Styles */
	/* .talking_video_modal_backdrop styles in shared backdrop rule above */
	.talking_video_modal {
		cursor: default;
		position: fixed;
		z-index: 101;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		background: var(--global-background-color);
		border-radius: 21px;
		padding: 21px;
		width: 90%;
		max-width: 900px;
		max-height: 90vh;
		overflow-y: auto;
		display: none;
	}
	.talking_video_modal_content {
		display: flex;
		flex-direction: column;
		gap: 21px;
	}
	.talking_video_modal_image {
		width: 100%;
		text-align: center;
	}
	.talking_video_modal_image img {
		max-width: 100%;
		max-height: 75vh;
		border-radius: 14px;
	}
	.talking_video_modal_script {
		width: 100%;
	}
	.talking_video_modal_script_header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 8px;
	}
	.talking_video_modal_char_count {
		font-size: 12px;
		color: var(--global-text-color);
		opacity: 0.7;
	}
	.talking_video_modal_generate_script_button {
		margin-top: 8px;
		font-size: 14px;
		padding: 8px 16px;
	}
	.talking_video_modal_voice {
		width: 100%;
		margin-top: 14px;
	}
	.talking_video_modal_captions {
		margin-top: 14px;
	}
	.talking_video_modal_audio_upload {
		margin-top: 14px;
	}
	.div_audio_uploader {
		margin-top: 8px;
	}
	.input_audio_uploader {
		width: 100%;
		padding: 14px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 14px;
		background: var(--global-background-color);
		color: var(--global-text-color);
		cursor: pointer;
	}
	.talking_video_audio_preview {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-top: 8px;
	}
	.talking_video_audio_player {
		flex: 1;
		height: 40px;
	}
	.talking_video_audio_clear {
		padding: 8px 16px;
		font-size: 14px;
	}
	.talking_video_modal_script_textarea {
		width: 100%;
		min-height: 150px;
		padding: 14px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 14px;
		background: var(--global-background-color);
		color: var(--global-text-color);
		font-size: 16px;
		resize: vertical;
	}
	.talking_video_modal_voice_selector,
	.mocap_voice_selector {
		padding: 14px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 14px;
		cursor: pointer;
		text-align: left;
		background: var(--global-background-color);
	}
	.mocap_voice_selector {
		margin-left:21px;
		margin-right:21px;
		width:calc(100% - 21px - 21px);
	}
	.talking_video_modal_voice_selector:hover,
	.mocap_voice_selector:hover {
		background: rgba(128,128,128,0.1);
	}
	.talking_video_modal_voice_selector.selected,
	.mocap_voice_selector.selected {
		background: rgba(244, 115, 83, 0.1);
		outline: 2px solid #f47353;
	}
	.mocap_voice_selector {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.mocap_voice_clear {
		display: none;
		cursor: pointer;
		padding: 0 8px;
		opacity: 0.6;
	}
	.mocap_voice_clear:hover {
		opacity: 1;
	}
	.mocap_voice_selector.selected .mocap_voice_clear {
		display: inline-block;
	}
	.talking_video_modal_selected_voice {
		font-weight: bold;
		color: var(--global-text-color);
	}
	.talking_video_modal_make_button,
	.action-make-talking-video-submit {
		margin-top: 14px;
	}
	.talking_video_modal_cancel_button {
		margin-top: 8px;
		margin-bottom: 14px;
	}
	
	/* Voice Selector Modal Styles */
	.voice_selector_modal_backdrop {
		z-index: 102;
	}
	.voice_selector_modal {
		display: none;
		cursor: default;
		position: fixed;
		z-index: 103;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		background: var(--global-background-color);
		border-radius: 21px;
		padding: 21px;
		width: 90%;
		max-width: 600px;
		max-height: 80vh;
		min-height:600px;
	}
	.voice_selector_modal_title {
		font-size: 21px;
		font-weight: bold;
		margin-bottom: 21px;
		text-align: center;
	}
	.voice_selector_modal_search {
		width: 100%;
		padding: 14px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 14px;
		background: var(--global-background-color);
		color: var(--global-text-color);
		font-size: 16px;
		margin-bottom: 21px;
		box-sizing: border-box;
	}
	.voice_selector_modal_filters {
		display: flex;
		gap: 14px;
		margin-bottom: 21px;
		flex-wrap: wrap;
	}
	.voice_selector_modal_filter {
		flex: 1;
		min-width: 120px;
	}
	.voice_selector_modal_filter select {
		width: 100%;
		padding: 10px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 8px;
		background: var(--global-background-color);
		color: var(--global-text-color);
		font-size: 16px;
	}
	.voice_selector_modal_filter select:focus {
		outline: none;
		border-color: var(--global-text-color);
	}
	@media (max-width: 600px) {
		.voice_selector_modal_filters {
			flex-direction: column;
		}
		.voice_selector_modal_filter {
			min-width: auto;
		}
	}
	.voice_selector_modal_voices {
		display: flex;
		flex-direction: column;
		gap: 14px;
		max-height: 380px;
		overflow-y: scroll;
		padding: 5px;
		margin: -5px;
		position: relative;
	}
	.voice_selector_modal_voices::-webkit-scrollbar {
		width: 8px;
	}
	.voice_selector_modal_voices::-webkit-scrollbar-track {
		background: rgba(128,128,128,0.1);
		border-radius: 4px;
	}
	.voice_selector_modal_voices::-webkit-scrollbar-thumb {
		background: rgba(128,128,128,0.3);
		border-radius: 4px;
	}
	.voice_selector_modal_voices::-webkit-scrollbar-thumb:hover {
		background: rgba(128,128,128,0.5);
	}
	.voice_selector_modal_voice {
		padding: 9px;
		padding-left: 14px;
		padding-right: 14px;
		border: 1px solid rgba(128,128,128,0.3);
		border-radius: 14px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: space-between;
		background: var(--global-background-color);
	}
	.voice_selector_modal_voice:hover {
		background: rgba(128,128,128,0.1);
	}
	.voice_selector_modal_voice.previewing {
		background: rgba(244, 115, 83, 0.1);
		outline:2px solid #f47353;
	}
	.voice_selector_modal_voice_name {
		font-weight: bold;
		font-size: 16px;
	}
	.voice_selector_modal_voice_details {
		display: flex;
		gap: 6px;
		align-items: center;
		margin-top: 6px;
		flex-wrap: wrap;
	}
	.voice_selector_modal_voice_details span {
		background: rgba(128,128,128,0.15);
		color: rgba(128,128,128,0.9);
		padding: 4px 8px;
		border-radius: 12px;
		font-size: 12px;
		font-weight: 500;
		border: 1px solid rgba(128,128,128,0.2);
	}
	.voice_play_button {
		padding: 10px;
		font-size: 20px;
		cursor: pointer;
		user-select: none;
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 40px;
		width: 40px;
		min-height: 50px;
		height: 50px;
		flex-shrink: 0;
	}
	.voice_play_button:hover {
		opacity:0.5;
	}
	.voice_play_button:active {
		opacity:0.25;
	}
	
	@media (max-width: 767px) {
		.talking_video_modal {
			left: 0;
			top: 0;
			transform: none;
			width: 100%;
			height: 100%;
			max-width: none;
			max-height: none;
			border-radius: 0;
		}
		.action-make-talking-video-submit,
		.talking_video_modal_cancel_button {
			width: 100%;
			padding: 14px;
		}
		.talking_video_modal_script {
			text-align: right;
		}
	}
	
	@media (min-width: 768px) {
		.talking_video_modal_content {
			flex-direction: row;
		}
		.talking_video_modal_image {
			flex: 1;
		}
		.talking_video_modal_inputs {
			flex: 1;
			display: flex;
			flex-direction: column;
			gap:10px;
		}
	}
	
	.div_output_image_buttons {
		cursor:normal;
		display: none;
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 100%;
		text-align: center;
		z-index: 4;
	}
	html.guest .div_output_image_buttons {
		display:none !important;
	}
	@media (min-width:600px) {
		.div_output_image:active .output_image,
		.div_output_image:focus .output_image,
		.div_output_image:hover .output_image,
		.div_output_image:hover .model_viewer_background_container {
			opacity: 0.5;
		}
		.div_output_image.finished:active .div_output_image_buttons,
		.div_output_image.finished:focus .div_output_image_buttons,
		.div_output_image.finished:hover .div_output_image_buttons {
			display: block;
		}
	}


	@media (max-width:600px) {
		/* on mobile make buttons only show after first tap which toggles ACTIVE class with JS, to avoid accidentally instant tapping because hover on mobile is tap */
		.div_output_image.active .output_image {
			opacity: 0.75;
		}
		.div_output_image.finished.active .div_output_image_buttons {
			display: block;
		}
	}
	/* Hide these buttons from hover gallery (still accessible via image viewer sidebar) */
	.div_output_image_buttons .action-relight,
	.div_output_image_buttons .action-add-grain,
	.div_output_image_buttons .action-make-3d-model {
		display: none !important;
	}
	.image_viewer_buttons div,
	.div_output_image_buttons div {
		cursor: pointer;
		display: inline-block;
		margin: 7px;
		-webkit-user-select: none;
		-khtml-user-select: none;
		-moz-user-select: none;
		-ms-user-select: none;
		text-transform: uppercase;
		font-size: 9px;
		text-align: center;
		/* max-width:52px; */
	}
	.image_viewer_buttons div {
		margin-left:7px;
		margin-right:7px;
	}
	.image_viewer_buttons div span.circle,
	.div_output_image_buttons div span.circle {
		border-radius: 100%;
		display: inline-block;
		border: 2px solid #fff;
		margin-bottom: 4px;
	}
	.div_output_image_buttons div span.circle {
		backdrop-filter: blur(10px);
	}
	.image_viewer_buttons div span.circle span.icon,
	.div_output_image_buttons div span.circle span.icon {
		padding: 21px;
		filter:invert(1);
		background-size: 45%;
		background-repeat: no-repeat;
		background-position: 12px 11px;
		display:block;
	}
	html:not(.dark) .div_output_image_buttons div span.circle span.icon {
		filter:none;
	}
	html:not(.dark) .action-save-photo svg,
	html:not(.dark) .action-undelete-photo svg,
	html:not(.dark) .action-delete-photo svg {
		filter:invert(1);
	}
	.image_viewer_buttons {
		position:absolute;
		bottom:14px;
		right:14px;
	}
	@media (max-width:1200px) {
		.image_viewer_buttons {
			display:none;
		}
	}
	
	/* hack because backdrop-filter on .icon stops working if you apply opacity:0.75 etc on parent on :hover */
	.image_viewer_buttons div:hover span.circle,
	.div_output_image_buttons div:hover span.circle {
		border:2px solid rgba(255,255,255,0.75);
	}
	.image_viewer_buttons div:hover span.icon,
	.div_output_image_buttons div:hover span.icon {
		opacity: 0.75
	}
	.image_viewer_buttons div:active span.circle,
	.div_output_image_buttons div:active span.circle {
		border:2px solid rgba(255,255,255,0.5);
	}
	.image_viewer_buttons div:active span.icon,
	.div_output_image_buttons div:active span.icon {
		opacity: 0.5;
	}
	.image_viewer_buttons div.action-view-image span.icon,
	.div_output_image_buttons div.action-view-image span.icon {
		background-image: url('/assets/expand.svg?2');
	}
	.image_viewer_buttons div.action-download-image span.icon,
	.div_output_image_buttons div.action-download-image span.icon {
		background-image: url('/assets/download.svg?2');
	}
	.image_viewer_buttons div.action-copycat span.icon,
	.div_output_image_buttons div.action-copycat span.icon {
		background-image: url('/assets/recycle.svg?2');
	}
	.image_viewer_buttons div.action-google-lens span.icon,
	.div_output_image_buttons div.action-google-lens span.icon {
		background-image: url('/assets/google-lens.svg?4');
	}
	.image_viewer_buttons div.action-lens span.icon,
	.div_output_image_buttons div.action-lens span.icon {
		background-image: url('/assets/google-lens.svg?4');
	}
	.image_viewer_buttons div.action-copy-prompt span.icon,
	.div_output_image_buttons div.action-copy-prompt span.icon {
		background-image: url('/assets/recycle.svg?2');
	}
	.image_viewer_buttons div.action-carbon-copy span.icon,
	.div_output_image_buttons div.action-carbon-copy span.icon {
		background-image: url('/assets/recycle.svg?2');
	}
	.image_viewer_buttons div.action-edit span.icon,
	.div_output_image_buttons div.action-edit span.icon {
		background-image: url('/assets/edit.svg?4');
	}
	.image_viewer_buttons div.action-dump-data span.icon,
	.div_output_image_buttons div.action-dump-data span.icon {
		background-image: url('/assets/barrel.svg?4');
	}
	.image_viewer_buttons div.action-open-replicate span.icon,
	.div_output_image_buttons div.action-open-replicate span.icon {
		background-image: url('/assets/edit.svg?4');
	}
	.image_viewer_buttons div.action-view-raw span.icon,
	.div_output_image_buttons div.action-view-raw span.icon {
		background-image: url('/assets/raw.svg?6');
	}
	.image_viewer_buttons div.action-upscale span.icon,
	.div_output_image_buttons div.action-upscale span.icon {
		background-image: url('/assets/upscale.svg?7');
	}
	.image_viewer_buttons div.action-add-grain span.icon,
	.div_output_image_buttons div.action-add-grain span.icon {
		background-image: url('/assets/grain.svg?7');
	}
	.image_viewer_buttons div.action-zoom-out span.icon,
	.div_output_image_buttons div.action-zoom-out span.icon {
		background-image: url('/assets/zoom-out.svg?7');
	}
	.image_viewer_buttons div.action-make-video span.icon,
	.div_output_image_buttons div.action-make-video span.icon {
		background-image: url('/assets/video.svg?6');
	}
	.image_viewer_buttons div.action-extend-video span.icon,
	.div_output_image_buttons div.action-extend-video span.icon {
		background-image: url('/assets/extend.svg');
	}
	.div_output_image_buttons div.action-make-subject-video span.icon {
		background-image: url('/assets/video.svg?6');
	}
	.image_viewer_buttons div.action-make-3d-model span.icon,
	.div_output_image_buttons div.action-make-3d-model span.icon {
		background-image: url('/assets/3d.svg?6');
	}
	.image_viewer_buttons div.action-publish-photo span.icon,
	.div_output_image_buttons div.action-publish-photo span.icon {
		background-image: url('/assets/export.svg');
	}
	.image_viewer_buttons div.action-make-talking-video span.icon,
	.div_output_image_buttons div.action-make-talking-video span.icon {
		background-image: url('/assets/talk.svg?6');
	}
	.image_viewer_buttons div.action-add-audio span.icon,
	.div_output_image_buttons div.action-add-audio span.icon {
		background-image: url('/assets/audio.svg');
	}
	.image_viewer_buttons div.action-relight span.icon,
	.div_output_image_buttons div.action-relight span.icon {
		background-image: url('/assets/bulb.svg?6');
	}
	.image_viewer_buttons div.action-ai-edit span.icon,
	.div_output_image_buttons div.action-ai-edit span.icon {
		background-image: url('/assets/stars.svg?6');
	}
	.image_viewer_buttons div.action-crop span.icon,
	.div_output_image_buttons div.action-crop span.icon {
		background-image: url('/assets/crop.svg?6');
	}
	.image_viewer_buttons div.action-inpaint span.icon,
	.div_output_image_buttons div.action-inpaint span.icon {
		background-image: url('/assets/eraser.svg?6');
	}
	.image_viewer_buttons div.action-set-product-scene span.icon,
	.div_output_image_buttons div.action-set-product-scene span.icon {
		background-image: url('/assets/hand.svg');
	}
	.image_viewer_buttons div.action-set-mocap-person span.icon,
	.div_output_image_buttons div.action-set-mocap-person span.icon {
		background-image: url('/assets/mocap.svg');
	}
	.image_viewer_buttons div.action-delete span.icon,
	.div_output_image_buttons div.action-delete span.icon {
		background-image: url('/assets/garbage.svg?2');
	}

	/* hide ios Play button */
	.div_output_image.video .div_output_image_container video::-webkit-media-controls {
		display: none !important;
	}

	.div_output_image.flux:after {
		content:'flux';
		background:#2bde73;
		color:#000;
		font-weight:bold;
		position:absolute;
		top:0;
		right:0;
		font-size:8px;
		padding:5px;
		border-top-right-radius: var(--global-border-radius);
		border-bottom-left-radius: 6px;
		text-transform: uppercase;
		z-index:2;
	}
	.div_output_image.flux_2x:after {
		content:'Flux HD';
		background:linear-gradient(to right, #FFD700, #FFA500);
		color:#000;
		font-weight:bold;
		position:absolute;
		top:0;
		right:0;
		font-size:8px;
		padding:5px;
		border-top-right-radius: var(--global-border-radius);
		border-bottom-left-radius: 6px;
		text-transform: uppercase;
		z-index:2;
	}

	.div_output_image.realism:after {
		content:'hyper realism';
		background:var(--gradient);
		animation:animatedgradient 6s ease infinite alternate;
		background-size: 300% 300%;
		color:#000;
		font-weight:bold;
