		var deletePhotoConfirmationGiven=false;

		$('body').on('click','.action-delete-photo',function(event){
			event.stopPropagation();
			

							if($('.hero .cta-box .input_confirm_email').val().trim()=='') {
					$('html').animate({
						scrollTop:
						-$('html').offset().top+$('.hero .cta-box').scrollTop()+$('.hero .cta-box ').offset().top-28
					},500);
					$('.hero .cta-box .input_confirm_email').focus();
					return;
				}
			
			if(selectedFolder=='trash') {
				if(!deletePhotoConfirmationGiven) {
					if(!confirm("Do you want to permanently delete this photo? This action cannot be undone. After this I will not ask you again when permanently deleting photos.")) {
						return;
					}
					deletePhotoConfirmationGiven=true;
				}
			}
			
			// move photo to trash folder
			if(selectedFolder!='trash') {
				// if already in trash, don't add it back to trash, but nuke it
				if($('.div_output_images.trash .div_output_image').length) {
					// only save, if saved folder loaded
					$('.div_output_images.trash').prepend($(this).parent()[0].outerHTML);
				}
			}

			// now delete photo from current folder
			if($(this).parent().hasClass('image_viewer')) {
				// deleting from image viewer
				var to_delete_photo_id=$(this).parent().data('photo-id');

				console.log('to_delete_photo_id = '+to_delete_photo_id);

				// go to next image BEFORE removing (so nextAll can find siblings)
				imageViewerGoPrevOrNextImage('next');

				// delete from gallery too
				$('.div_output_image[data-photo-id="'+to_delete_photo_id+'"').remove();
				console.log('removing '+to_delete_photo_id);
			}
			else {
				// deleting from gallery
				var to_delete_photo_id=$(this).parent().data('photo-id');
				

				console.log($(this).parent().parent().prev().hasClass('.job_divider_prompt'));
				console.log($(this).parent().parent().prev().hasClass('.job_divider'));

				// remove remaining job dividers
				if(
					$('.div_output_image.photo-'+to_delete_photo_id).prev().hasClass('job_divider_prompt') &&
					$('.div_output_image.photo-'+to_delete_photo_id).next().hasClass('job_divider')
				) {
					var a=$('.div_output_image.photo-'+to_delete_photo_id).prev('.job_divider_prompt').prev('.job_divider');
					var b=$('.div_output_image.photo-'+to_delete_photo_id).prev('.job_divider_prompt');
					a.remove();
					b.remove();
				}

				$(this).parent().remove();
			}

			$.ajax({
				async:true,
				url: '/?action=delete-photo&photo_id='+to_delete_photo_id,
				dataType:'json',
			}).done(function(reply) {
				if(reply.message) {
					alert(reply.message);
				}
			});
		});

		$('body').on('click','.action-publish-photo',function(event){
			event.stopPropagation();
			var $divOutputImage = $(this).closest('.div_output_image');
			var photo_id = $divOutputImage.length ? $divOutputImage.data('photo-id') : $('.image_viewer').data('photo-id');
			if(!photo_id) return;
			var $photoEl = $('.div_output_image.photo-'+photo_id);
			var isPublished = $photoEl.data('epoch-published');

			if(isPublished) {
				// Unpublish — no confirm needed
				$.ajax({ url:'/?action=unpublish-photo&photo_id='+photo_id, dataType:'json' })
				.done(function(reply){
					if(reply.success) {
						$photoEl.data('epoch-published','');
						$photoEl.removeClass('published');
						$('.publish-label').text('Publish');
					}
					if(reply.message) alert(reply.message);
				});
			} else {
				// Publish — confirm first
				if(!confirm('Your photo will be visible to everyone in the community and on your public profile page.\n\nContinue?')) return;
				$.ajax({ url:'/?action=publish-photo&photo_id='+photo_id, dataType:'json' })
				.done(function(reply){
					if(reply.success) {
						$photoEl.data('epoch-published', Math.floor(Date.now()/1000));
						$photoEl.addClass('published');
						$('.publish-label').text('Unpublish');
						alert('Photo submitted! After approval, it will appear on the Community tab and your public profile page.');
					}
					if(reply.message) alert(reply.message);
				});
			}
		});

		
		$('body').on('click','.action-grab-video-frame',function(event){
			event.stopPropagation();
			
			// store whether video was playing before pausing
			var video = $('.image_viewer video').get(0);
			var wasPlaying = !video.paused && !video.ended && video.currentTime > 0 && video.readyState > 2;
			
			// first pause video
			video.pause();
			flash();
			bigFlash();

			// get the prompt so we can save it with the frame grab
			var manualPrompt=$('.photo-'+currentPhotoId).data('manual-prompt');
			
			// also check for data-description
			var description = $('.photo-'+currentPhotoId).data('description');
			if(description) {
				manualPrompt = description;
			}

			// check if this is a 3D model viewer
			if($('.image_viewer').hasClass('three_d')) {
				console.log('3D model capture detected');
				// handle 3D model capture
				var modelViewer = $('.image_viewer model-viewer')[0];
				if(modelViewer) {
					console.log('Model viewer found, capturing screenshot...');
					// Capture screenshot from model-viewer using correct API
					modelViewer.toBlob({
						mimeType: 'image/png',
						qualityArgument: 0.92,
						idealAspect: false
					}).then(function(blob) {
						console.log('3D model screenshot captured, blob size:', blob.size);
						// Create a File object from the blob
						var file = new File([blob], 'frame-grab-' + 1775208927 + '.png', { type: 'image/png' });
						console.log('Created file object:', file.name);
						
						// submit the model's photo_id to the upload to so we can attach the data to the new grab frame
						var photoId=currentPhotoId;
						
						// Upload the screenshot using existing uploadImportImage function
						uploadImportImage(file,true,photoId);
						console.log('3D model screenshot upload initiated');
					}).catch(function(error) {
						console.error('Error capturing 3D model screenshot:', error);
					});
				} else {
					console.log('No model-viewer element found');
				}
			} else {
				console.log('Video capture detected');
				// grab frame from video
				// Create a canvas element to capture the video frame
				var canvas = document.createElement('canvas');
				var video = $(this).parent().find('video')[0];
				
				// Set canvas dimensions to match video
				canvas.width = video.videoWidth;
				canvas.height = video.videoHeight;
				
				// Draw current video frame to canvas
				var ctx = canvas.getContext('2d');
				ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

				// submit the video's photo_id to the upload to so we can attach the data to the new grab frame
				var photoId=currentPhotoId;
				

				// Convert canvas to blob and upload via uploadImportImage
				canvas.toBlob(function(blob) {
					// Create a File object from the blob
					var file = new File([blob], 'frame-grab-' + 1775208927 + '.png', { type: 'image/png' });
					
					// Upload the frame grab using existing uploadImportImage function
					uploadImportImage(file,true,photoId);
				}, 'image/png');

				// only continue playing if video was playing before the frame grab
				if(wasPlaying) {
					$('.image_viewer video').get(0).play();
				}

			}

			
		});

		$('body').on('click','.action-save-photo',function(event){
			event.stopPropagation();


							if($('.hero .cta-box .input_confirm_email').val().trim()=='') {
					$('html').animate({
						scrollTop:
						-$('html').offset().top+$('.hero .cta-box').scrollTop()+$('.hero .cta-box ').offset().top-28
					},500);
					$('.hero .cta-box .input_confirm_email').focus();
					return;
				}
			
			var photo_id = $(this).parent().data('photo-id');
			var isSaved = $(this).hasClass('saved');

			if(isSaved) {
				// unsave photo
				$(this).removeClass('saved');
				$(this).parent().removeClass('saved');

				if($(this).parent().hasClass('image_viewer')) {
					// unsave from image viewer - update gallery too
					$('.div_output_image[data-photo-id="'+photo_id+'"]').removeClass('saved');
					$('.div_output_image[data-photo-id="'+photo_id+'"] .action-save-photo').removeClass('saved');
				}

				// remove from saved folder
				if(selectedFolder=='saved') {
					$(this).parent().remove();
				} else {
					$('.div_output_images.saved .div_output_image[data-photo-id="'+photo_id+'"]').remove();
				}

				console.log("unsave-photo");
				$.ajax({
					async:true,
					url: '/?action=unsave-photo&photo_id='+photo_id,
					dataType:'json',
				});
			} else {
				// save photo
				$(this).addClass('saved');

				// move photo to saved folder
				if($('.div_output_images.saved .div_output_image').length) {
					// only save, if saved folder loaded
					$('.div_output_images.saved').prepend($(this).parent()[0].outerHTML);
				}

				if($(this).parent().hasClass('image_viewer')) {
					// save from image viewer - update gallery too
					$('.div_output_image[data-photo-id="'+photo_id+'"]').addClass('saved');
					$('.div_output_image[data-photo-id="'+photo_id+'"] .action-save-photo').addClass('saved');
				}

				// if we are in trash, remove photo from trash now it's saved again
				if(selectedFolder=='trash') {
					// also move it back to camera folder
					$('.div_output_images.camera').prepend($(this).parent()[0].outerHTML);
					$(this).parent().remove();
				}

				$(this).parent().addClass('saved');

				console.log("save-photo");
				$.ajax({
					async:true,
					url: '/?action=save-photo&photo_id='+photo_id,
					dataType:'json',
				});
			}
		});



		// <untrash photo>
			$('body').on('click','.action-undelete-photo',function(event){
				event.stopPropagation();


									if($('.hero .cta-box .input_confirm_email').val().trim()=='') {
						$('html').animate({
							scrollTop:
							-$('html').offset().top+$('.hero .cta-box').scrollTop()+$('.hero .cta-box ').offset().top-28
						},500);
						$('.hero .cta-box .input_confirm_email').focus();
