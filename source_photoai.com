	/* <select photos logic> */
		/* users can select photo mode and then select and then download photos */
			.action-select-all {
				display:none;
			}
			html.select-photos-mode .action-select-all {
				display:inline-block;
			}
			@media (max-width:600px) {
				html.select-photos-mode .action-select-all {
					display:none;
				}
				/* make header fixed on mobile when select mode is on */
				html.select-photos-mode .header {
					position:fixed;
				}
			}
			html.select-photos-mode .div_output_image.selected {
				background: #fff;
			}
			html.select-photos-mode .div_output_image.selected .output_image,
			html.select-photos-mode .div_output_image.selected .copycat_image {
				opacity:0.75;
			}
			html.select-photos-mode .div_output_image.selected:after {
				background:#fff;
				border-radius:100%;
				padding:2px;
				content:url('/assets/checkmark-circle-green.svg?1708109684');
				width:30px;
				height:30px;
				position:absolute;
				bottom:14px;
				right:14px;
				top:auto;
				font-size:20px;
			}
			html:not(.select-photos-mode) .select-photos-mode-buttons-bar {
				display:none !important;
			}
			html.select-photos-mode .select-photos-mode-buttons-bar {
				display:none;
				z-index:100;
				position:fixed;
				left:0;
				bottom:0;
				width:100%;
				padding:21px;
				background:var(--sidebar-background-color);
				border-top:1px solid var(--global-border-color);
				justify-content:center;
				gap:14px;
			}
			html.select-photos-mode .select-photos-mode-buttons-bar .button {
				flex:1;
				display:flex;
				align-items:center;
				justify-content:center;
				gap:6px;
			}
			html.select-photos-mode .select-photos-mode-buttons-bar .button img {
				height:16px;
			}
			html.select-photos-mode .select-photos-mode-buttons-bar .button.gradient img {
				filter:invert(1);
			}
			html.select-photos-mode .select-photos-mode-buttons-bar .button.reverse img {
				filter:invert(1);
			}
			html.select-photos-mode .select-photos-mode-buttons-bar .button.reverse:hover img {
				filter:invert(0);
			}
			html.select-photos-mode .action-delete-photo,
			html.select-photos-mode .action-save-photo,
			html.select-photos-mode .div_output_image_buttons,
			html.select-photos-mode .div_output_image_meta {
				display:none !important;
			}
			html.select-photos-mode .div_output_image.finished {
				cursor:pointer;
			}
