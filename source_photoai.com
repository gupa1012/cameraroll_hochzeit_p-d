		<script>

			var userIsChangingFolder=false;

			$(function() {

				$('.top_folder_selector h3').bind('click',function() {

					if(userIsChangingFolder) {
						return;
					}

					// remove blinking class for when user takes an action in a different folder like upscale
					$(this).removeClass('blinking');
					
					userIsChangingFolder=true;
					disableInfinityScrollBecauseWeReachedEnd=false;

					selectedFolder=$(this).data('folder');

					// remove all classes starting with selected-folder
					$('html').removeClass(function(index, className) {
						return (className.match(/(^|\s)selected-folder-\S+/g) || []).join(' ');
					});
					// add current one
					$('html').addClass('selected-folder-'+selectedFolder);
					
					$('.div_output_images').hide();
					$('.div_output_images.'+selectedFolder).show();

					$('html').data('selected-folder',selectedFolder);
					// window.location.hash=selectedFolder;

					loadPhotos(selectedFolder);

					if(selectedFolder=='templates') {
						$('.photo_pack_filters').addClass('visible');
						$('.photo_search').hide();
						if(!isMobile) {
							$('.photo_pack_search').focus();
						}
					}
					else if(selectedFolder=='examples') {
						$('.photo_pack_filters').removeClass('visible');
						$('.photo_search').hide();
					}
					else {
						$('.photo_pack_filters').removeClass('visible');
						$('.photo_search').show();
					}

					$('.top_folder_selector h3').removeClass('active');
					$(this).addClass('active');

					// scroll back to top when changing folder
					if(empty($('.photo_search').val()) && $('.photo_search').is(':visible') && empty($('#model-filter').val())) {
						var scrollToPosY=$('.photo_search').outerHeight()+14;
					}
					else {
						var scrollToPosY=0;
					}

					console.log('3 scrollToPosY='+scrollToPosY);

					$('.section.main').animate({
						scrollTop:scrollToPosY
					},0);

				});
			});
		</script>

	
		<div class="top_folder_selector"><h3 data-folder="templates" class="">
				Photo packs <span class="badge">new</span>
			</h3><h3 data-folder="examples" class="active">
