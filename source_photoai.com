		$('.div_import_uploader').addClass('collapsed');
		$('.div_import_uploader_center').show();

		// clear thumbnail
		$('.try_on_mode_current_import_thumbnail').attr('src','data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==').hide();

		// re-enable the input for the next batch
		$('.input_import_uploader').val('').removeClass('disabled');

	}


	function uploadImportImage(file,videoFrameGrab=false,photoId='',callback=null) {

		if(
			selectedFolder!='camera'
		) {
			//
			// if we are not in the camera folder
			// and user upscales
			// glow the top_folder_selector of camera
			// so user knows the upscale will run there
			//
			// for @johnonolan
			//
			setTimeout(function() {
				$('.top_folder_selector h3[data-folder="camera"]').addClass('blinking');
				$('.top_folder_selector h3[data-folder="camera"]').addClass('glow');
				setTimeout(function() {
					$('.top_folder_selector h3[data-folder="camera"]').removeClass('glow');
				},500);
			},500);
		}

		// uploader UI state is now managed by the batch handler in the change event
		// so we don't update it here anymore

		// <process image>
			var fileIndex=0;

			var fileReader = new FileReader();
			fileReader.readAsDataURL(file);

			fileReader.onload = function () {

				// <add placeholder before upload is done>
					// generate a random class for this placeholder
					var placeholderRandomClass = 'placeholder_' + Math.random().toString(36).substr(2, 9);
					$('.div_output_images.camera').prepend(
						'<div class="div_output_image '+(videoFrameGrab ? 'frame_grab' : 'import')+' placeholder postprocessing '+placeholderRandomClass+'">'+
							'<div class="loading_spinner"><svg class="loading_spinner_svg" viewBox="25 25 50 50"><circle class="loading_spinner_circle" cx="50" cy="50" r="22" fill="none"></circle><circle class="loading_spinner_circle loading_spinner_circle--spinner" cx="50" cy="50" r="22" fill="none"></circle></svg></div>'+
							'<div class="div_output_image_container">'+
								'<img class="output_image" src="'+fileReader.result+'">'+
							'</div>'+
						'</div>'
					);
				// </add placeholder before upload is done>


				// <resize image>
					var img = document.createElement('img');
					img.src = fileReader.result;
					// console.log('#'+fileIndex+f ileReader.result);
					console.log('#'+fileIndex);

					// <resize image onload>
						img.onload = function() {

							// preview is now shown in the gallery placeholders for batch import

							// Dynamically create a canvas element
							var canvasResize = document.createElement("canvas");
							var ctxResize = canvasResize.getContext("2d");

							// Determine max size based on hyper realism setting
							var maxSize;
							var hyperRealismEnabled = $('.realism_switch_label').hasClass('enabled');
							if(hyperRealismEnabled) {
								// Hyper realism supports up to 4096px, use native size if smaller
								maxSize = 4096;
							} else {
								// Standard mode uses 1024px
								maxSize = 1024;
							}

							// Actual resizing using max dimension approach
							var maxDimension = Math.max(img.width, img.height);
							if(maxDimension <= maxSize) {
								// Use native size - image is within limits
								ctxResize.width = img.width;
								ctxResize.height = img.height;
							} else {
								// Scale down proportionally so largest dimension = maxSize
								var scale = maxSize / maxDimension;
								ctxResize.width = Math.round(img.width * scale);
								ctxResize.height = Math.round(img.height * scale);
							}

							canvasResize.width=ctxResize.width;
							canvasResize.height=ctxResize.height;
							ctxResize.drawImage(img, 0, 0, ctxResize.width, ctxResize.height);

							// Show resized image in preview element
							var dataURL = canvasResize.toDataURL('image/png');
							var imgResize = document.createElement('img');
							imgResize.src = dataURL;
							imgResize.width=ctxResize.width;
							imgResize.height=ctxResize.height;

							importWidth=imgResize.width;
							importHeight=imgResize.height;

							// <resize image finished onload>
								imgResize.onload = function() {
									
									// Show cropped image in preview element
									var dataURL = canvasResize.toDataURL('image/png');
										
									// <save as blob>
										canvasResize.toBlob(function(blob){

											var totalFiles = $('.input_import_uploader')[0].files.length;
											console.log('#'+fileIndex+' finished '+(fileIndex+1)+'/'+totalFiles);

											// <upload>
												var uploadUrl='/copycat_upload?video_frame_grab='+encodeURIComponent(videoFrameGrab)+'&import=true&photo_id='+encodeURIComponent(photoId);

												var maxRetries = 2;
												var retryCount = 0;

												function doUpload() {
													var formData = new FormData();
													formData.append('file',blob);

													var xhttp = new XMLHttpRequest();
													xhttp.open('POST', uploadUrl, true);

													xhttp.onreadystatechange = function() {
														if (this.readyState == 4) {
															if (this.status == 200) {
																// uploader UI is now managed by batch handler

																var reply=JSON.parse(xhttp.responseText);
																console.log(reply);


																if(!reply.success) {
																	alert(reply.message);
																	$('.div_output_image.placeholder.'+placeholderRandomClass).remove();
																	if(callback) callback();
																	return;
																}

																$('.div_output_image.placeholder.'+placeholderRandomClass).remove();

																if(reply.photos.length>0) {
																	photo=reply.photos[0];
																	var html=makePhotoBox(photo);
																	$('.div_output_images.camera').prepend(
																		html
																	);
																}

																if(reply.photos[0].cost_in_credits) {
																	// decrement user credits with cost of finished photo from the photo's cost_in_credits data
																	if($('.photoCreditsLeft').data('credits')-photo.cost_in_credits<0) {
																		// Not enough regular credits, check extra credits
																		var remainingCost = photo.cost_in_credits - $('.photoCreditsLeft').data('credits');
																		$('.photoCreditsLeft').data('credits',0);

																		if($('.photoCreditsExtraLeft').data('credits')-remainingCost<0) {
																			$('.photoCreditsExtraLeft').data('credits',0);
																		} else {
																			$('.photoCreditsExtraLeft').data('credits',
																				$('.photoCreditsExtraLeft').data('credits')-remainingCost
																			);
																		}
																		$('.photoCreditsExtraLeft').text(number_format(
																			$('.photoCreditsExtraLeft').data('credits')
																		));
																		$('.photoCreditsExtraLeft').addClass('glow');
																		setTimeout(function() {
																			$('.photoCreditsExtraLeft').removeClass('glow')
																		},500);
																	}
																	else {
																		$('.photoCreditsLeft').data('credits',
																			$('.photoCreditsLeft').data('credits')-photo.cost_in_credits
																		);
																		$('.photoCreditsLeft').text(number_format(
																			$('.photoCreditsLeft').data('credits')
																		));
																		$('.photoCreditsLeft').addClass('glow');
																		setTimeout(function() {
																			$('.photoCreditsLeft').removeClass('glow')
																		},500);
																	}
																}

																if(!reply.success) {
																	alert(reply.message);
																	if(callback) callback();
																	return;
																}

																// Success - call callback for sequential processing
																if(callback) callback();
															} else {
																// Non-200 status (e.g., 502 timeout) - retry
																console.log('Upload failed with status ' + this.status + ', retry ' + (retryCount + 1) + '/' + maxRetries);
																if (retryCount < maxRetries) {
																	retryCount++;
																	setTimeout(doUpload, 1000);
																} else {
																	console.log('Upload failed after ' + maxRetries + ' retries');
																	$('.div_output_image.placeholder.'+placeholderRandomClass).remove();
																	alert('Upload failed after multiple attempts. Please try again.');
																	if(callback) callback();
																}
															}
														}
													}
													xhttp.send(formData);
												}
												doUpload();
											// </upload>



										},'image/png');
									// </save as blob>
								}
							// </resize image finished onload>
						}
					// </resize image onload>
				// </resize image>
			}
		// </process image>
	}




	function showStripeModal() {

		
		if(!stripeLoaded) {
			$('html').append('<script async defer src="https://js.stripe.com/v3/pricing-table.js">'+decodeURI('%3C/script%3E'));
		}
		stripeLoaded=true;
		$('.div_stripe_modal_backdrop').show();
		$('.div_stripe_modal').show();
	}

	

	function switchFolder(newFolder,action) {
		if(selectedFolder!=newFolder) {
			// switch to camera folder first
			// then grab video frame
			selectedFolder=newFolder;
			loadPhotos(selectedFolder, function() {
				$('.top_folder_selector h3').removeClass('active');
				$('.top_folder_selector h3[data-folder="'+newFolder+'"]').addClass('active');
				$('.div_output_images').hide();
				$('.div_output_images.'+newFolder).show();
				if(action) {
					action();
				}
			});
			return;
		}
	}

	var loadedPhotosYet=false;
	var stillLoadingPhotos=false;

	function loadPhotos(selectedFolderParameter,callbackFunction,forceReload=false,offset=0) {

		
		console.log('loadPhotos '+selectedFolder);
		
		selectedFolder=selectedFolderParameter;
		
		// <scroll to top but below filters box>
			if(empty($('.photo_search').val()) && $('.photo_search').is(':visible') && empty($('#model-filter').val())) {
				var scrollToPosY=$('.photo_search').outerHeight()+14;
			}
			else {
				var scrollToPosY=0;
			}

			console.log('1 scrollToPosY='+scrollToPosY);

			$('.section.main').animate({
				scrollTop:scrollToPosY
			},0);
		// </scroll to top but below search box>

		
		// <show or not show search>
			if(selectedFolder=='camera' || selectedFolder=='saved') {
				$('.photo_search').show();
			}
			else {
				$('.photo_search').hide();
			}
		// </show or not show search>
		
		if(
			selectedFolder=='templates' ||
			selectedFolder=='poses'
		) {
			// don't need to load photos for these tabs
			// as it's not dynamic but static and loaded
			// on page load inside HTML/PHP
			userIsChangingFolder=false;
			return;
		}

		$('.top_folder_selector h3').removeClass('active');
		$('.top_folder_selector h3[data-folder="'+selectedFolder+'"]').addClass('active');

		// <only load if no photos loaded in the selected folder yet>

			// don't reload camera tab if photos processing
			// if(
			// 	selectedFolder=='camera' && 
			// 	(
			// 		$('.div_output_images.camera .processing').length ||
			// 		$('.div_output_images.camera .postprocessing').length
			// 	)
			// 	/* ||
			// 	selectedFolder!='examples' && /* let user keep clicking examples to refresh examples, also important for when gender of model changes and we reload examples 
			// 	!forceReload &&
			// 	$('.div_output_images.'+selectedFolder+' .div_output_image:not(.placeholder)').length && // do not reload if no photos in gallery
			// 	!$('#model-filter').val() && !$('#month-filter').val() && !$('#year-filter').val() // only return if NO filters are selected*/
			// ) {
			// 	// folder already has photos, don't reload
			// 	console.log('not loading photos because folder already loaded and no filters active');
			// 	userIsChangingFolder=false;
			// 	return;
			// }
		// </only load if no photos loaded in the selected folder yet>

		userIsChangingFolder=true;


		if(loadedPhotosYet) {
			// don't show spinner on first load
			// only show if already loaded photos
			$('.loading_spinner.main').show();
		}

		$('.div_templates').hide();

		// send current model gender so we can show example tab photos in right gender for model selected
		currentModelGender='';
		if($('select.model_id option:selected').data('gender')) {
			currentModelGender=$('select.model_id option:selected').data('gender');
		}
		currentModelId=selectedModelIds[0];

		if(stillLoadingPhotos) {
			return;
		}
		stillLoadingPhotos=true;


		// <add placeholders>
			for(var placeholdersI=0; placeholdersI<18; placeholdersI++) {
				$('.div_output_images.'+selectedFolder).append(
					'<div class="div_output_image placeholder">'+
						'<img width="768" height="1024" class="output_image" src="https://resizeapi.com/resize-cgi/image/format=auto,fit=cover,width=768,height=1024,quality=50/https://photoai.com/assets/pixel.gif">'+
					'</div>'
				);
			}
		// </add placeholders>




		// Build the query parameters
		let queryParams = {
			folder: selectedFolder,
			offset: offset
		};

		// Add search query if exists
		if ($('.photo_search').val()) {
			queryParams.query = $('.photo_search').val();
		}

		// Add new filters if they exist
		const modelId = $('#model-filter').val();
		const month = $('#month-filter').val();
		const year = $('#year-filter').val();

		if (modelId) queryParams.model_id = modelId;
		if (month) queryParams.month = month;
		if (year) queryParams.year = year;

								
		// Convert query params to URL string
		const queryString = Object.keys(queryParams)
				.map(key => `${key}=${encodeURIComponent(queryParams[key])}`)
				.join('&');
		

		$.ajax({
			async:true,
							url: '/load_photos_gallery?',
						dataType:'json',
			type: 'GET',
			error: function(xhr,status,error){

			},
		}).done(function(photos) {

			console.log("Got photos back from AJAX for .div_output_images."+selectedFolder);

			$('.div_output_images.'+selectedFolder).html('');
			$('.loading_spinner.main').hide();


			// <scroll to top but below search box>
				if(empty($('.photo_search').val()) && $('.photo_search').is(':visible') && empty($('#model-filter').val())) {
					var scrollToPosY=$('.photo_search').outerHeight()+14;
				}
				else {
					var scrollToPosY=0;
				}

				console.log('2 scrollToPosY='+scrollToPosY);

				$('.section.main').animate({
					scrollTop:scrollToPosY
				},0);
			// </scroll to top but below search box>

			
			
			// <set last photo made defaults>
							// <set last photo made defaults>

			loadedPhotosYet=true;
			stillLoadingPhotos=false;

			$('.div_output_images').css('opacity',1);

			$('.loading_spinner.main').hide();


							photos=photos.slice(0,4*7);
			

			var currentJobId;
			var previousPhoto=[];
			var firstDividerSkippedYet=false;

			for(var photosI=0; photosI<photos.length; photosI++) {
				var photo=photos[photosI];

				if(!firstDividerSkippedYet || previousPhoto['manual_prompt']!=photo['manual_prompt'] || (previousPhoto['template'] && previousPhoto['template']!=photo['template'])){
					// new job (or first job), show prompt here
					$('.div_output_images.'+selectedFolder).append(
						makeJobDivider(photo)
					);
				}

				if(photosI<12) {
					// don't lazy load first N images to improve LCP
					var doNotLazyLoad=true;
				}
				else {
					var doNotLazyLoad=false;
				}

				// offset is used for infinity scrolling
				var offsetCounter=photosI;

				if(photo['status']=='queued') {
					photo['status']='processing';
				}

				var html=makePhotoBox(photo,doNotLazyLoad,offsetCounter);
				$('.div_output_images.'+selectedFolder).append(
					html
				);

				// <start poller for processing images>
					if(photo['status']=='processing') {
						loadingSpinnerStep(photo['photo_id']);
						loadingSpinnerStartTime[photo['photo_id']]=photo['epoch_queued']*1000;
						setTimeout(waitForServerToGenerate,(pollIntervalTime*2*Math.random()),photo['photo_id'],'poll_for_preprocessed');
					}
				// </start poller for processing images>

				if(photo['job_id']) {
					currentJobId=photo['job_id'];
				}

				previousPhoto=photo;
				firstDividerSkippedYet=true;
			}

			userIsChangingFolder=false;





			if(
				!photos.length && selectedFolder=='videos'
			) {
				$('.div_output_images.'+selectedFolder).html(
					'<div style="line-height:1.5;color:rgba(255,255,255,0.5);font-weight:bold;text-align:center;padding:28px;"><p>Start taking videos by hovering over a photo (or tap it on mobile) and tap the [ <img style="vertical-align:middle;filter:invert(1);opacity:0.5;" src="/assets/video.svg" width="25" height="25"> Make video ] button. Your photo will be turned into a video.</br><br/>All your videos are collected in this tab.</p></div>'
				);
			}


			if(
				!photos.length && selectedFolder=='saved'
			) {
				$('.div_output_images.'+selectedFolder).html(
					'<div style="line-height:1.5;color:rgba(255,255,255,0.5);font-weight:bold;text-align:center;padding:28px;"><p>You can save photos you like by hovering over them and tapping the ❤️ heart in the top left.</br><br/>All your saved photos are collected in this tab.</p></div>'
				);
			}




			// if callbackFunction given, e.g. for taking photo after switching from saved to camera folder, run it
			if(typeof callbackFunction == 'function') {
				callbackFunction();
			}

		});
	}

	function forceDownload(blob, filename) {
		var a = document.createElement('a');
		a.download = filename;
		a.href = blob;
		// For Firefox https://stackoverflow.com/a/32226068
		document.body.appendChild(a);
		a.click();
		a.remove();
	}

	
	function makePhotoBox(photo,doNotLazyLoad,offsetCounter,preliminaryId) {

		var loadingSpinnerHTML='';
		var extraClasses='';
		var aLinkStart='';
		var aLinkEnd='';



		if(
			photo['status']=='processing'
		) {
			// show spinner and blur with placeholder class cause no image yet
			var loadingSpinnerHTML='<div class="loading_spinner">'+
				'<svg class="loading_spinner_svg" viewBox="25 25 50 50"><circle class="loading_spinner_circle" cx="50" cy="50" r="22" fill="none"></circle><circle class="loading_spinner_circle loading_spinner_circle--spinner" cx="50" cy="50" r="22" fill="none"></circle></svg>'+
				'<div class="loading_message"></div>'+
			'</div>';
			var extraClasses='placeholder';
		}

		if(
			photo['status']=='preliminary'
		) {
			// show spinner and blur with placeholder class cause no image yet
			var loadingSpinnerHTML='<div class="loading_spinner">'+
				'<svg class="loading_spinner_svg" viewBox="25 25 50 50"><circle class="loading_spinner_circle" cx="50" cy="50" r="22" fill="none"></circle><circle class="loading_spinner_circle loading_spinner_circle--spinner" cx="50" cy="50" r="22" fill="none"></circle></svg>'+
				'<div class="loading_message"></div>'+
			'</div>';
			var extraClasses='processing placeholder preliminary '+preliminaryId;
		}

		if(
			photo['status']=='postprocessing'
		) {
			// show spinner but not blur with placeholder class cause we have low-res preprocessed image
			var loadingSpinnerHTML='<div class="loading_spinner">'+
				'<svg class="loading_spinner_svg" viewBox="25 25 50 50"><circle class="loading_spinner_circle" cx="50" cy="50" r="22" fill="none"></circle><circle class="loading_spinner_circle loading_spinner_circle--spinner" cx="50" cy="50" r="22" fill="none"></circle></svg>'+
				'<div class="loading_message"></div>'+
			'</div>';
		}
		

		if(photo['status']=='nsfw_detected') {
			var loadingSpinnerHTML='<div class="loading_spinner">'+
				'<div class="loading_message">NSFW detected</div>'+
			'</div>';
		}

		var extraClasses=extraClasses+ ' '+photo['status'];


		if(
			photo['epoch_finished'] && photo['epoch_queued']
		) {
			if(photo['epoch_finished']-photo['epoch_queued']<60) {
				var tookText=', took <span>'+(Math.round(photo['epoch_finished']-photo['epoch_queued']))+'</span>s';
			}
			else {
				var totalSeconds = Math.round(photo['epoch_finished']-photo['epoch_queued']);
				var minutes = Math.floor(totalSeconds / 60);
				var seconds = totalSeconds % 60;
				var tookText=', took <span>'+minutes+'m'+seconds+'s</span>';
			}
		}
		else {
			var tookText='';
		}

		extraClasses=extraClasses+' photo-'+photo['photo_id'];


		var savedClass='';
		if(photo['saved']) {
			savedClass='saved';
		}

		var frontpagedClass='';
		if(photo['frontpage']) {
			frontpagedClass='frontpaged';
		}


		var trashedClass='';
		if(photo['trashed']) {
			trashedClass='trashed';
		}

		var src='';
		var originalImageAsDataSrc='';
		var extraMetaText='';


		if(photo['status']=='finished') {
			var src=photo['photo_url'];
			var originalImageAsDataSrc='data-src="'+src+'"';
		}
		else if(photo['status']=='postprocessing') {
			var src=photo['preprocessed_photo_url']+'?'+photo['epoch_queued'];
			extraClasses=extraClasses+' postprocessing';
			var originalImageAsDataSrc='data-src="'+src+'"';

			if(photo['combine']) {
				if(photo['combine_photo_urls_json']) {
					var combinePhotoUrls = JSON.parse(photo['combine_photo_urls_json']);
					if(combinePhotoUrls && combinePhotoUrls[0]) {
						var src=combinePhotoUrls[0];
					}
				}
			}
		}

		else {
			if(photo['video']) {
				var extraMetaText='Making video...';
			}
			else {
				var extraMetaText='Taking photo...';
			}

			if(photo['status']=='preliminary') {
				var extraMetaText='Picking up camera...';
			}

			var src='assets/photo-ai-social-media-pic-2023-01-13.jpg?1';
			if(!empty(copycatId) && !empty(photo['copycat_url'])) {
				// use copycat input image as placeholder if active
				var src=photo['copycat_url'];
				photo['no_cdn']=true;
			}
			else {
				// non copycat, use last finished img as blurred preview
				if($('.div_output_image.finished:not(.video)').eq(0).find('img')) {
					var src=$('.div_output_image.finished:not(.video)').eq(0).find('img').data('preprocessed-src');
				}
			}
		}



		if(!photo['example']) {

			if(photo['model_id']) {
				var model_name=$('.model_selector .model_sample[data-model-id="'+photo['model_id']+'"]').data('model-name');
				// console.log('model_name='+model_name);
				if(model_name) {
					extraMetaText=extraMetaText+model_name+', ';
				}
			}

		}


		if(photo['complimentary'] && selectedFolder!='examples') {
			extraMetaText='❤️ Free auto generated photos for new model. No credits were used'+"\n<br/>"+extraMetaText;
		}


		if(photo['realism'] && photo['retry'] > 0) {
			extraMetaText="⚠️ Nano Banana content flagged, so fell back to Hyper Realism"+"\n<br/>"+extraMetaText;
		}

		if(photo['talking_video']) {
			extraClasses=extraClasses+' talking_video';
		}
		if(photo['extend_video']) {
			extraClasses=extraClasses+' extend_video';
		}
		/*if(photo['nsfw']) {
			extraClasses=extraClasses+' nsfw';
		}
		if(photo['racy']) {
			extraClasses=extraClasses+' racy';
		}*/

		if(photo['copycat_id'] || photo['copycat_url']) {
			extraClasses=extraClasses+' copycat';
		}
		if(photo['clothing_id'] || photo['clothing_url']) {
			extraClasses=extraClasses+' try_on';
		}
			
		if(photo['copycat_url']) {

			if(photo['copycat_what']) {
				extraMetaText = extraMetaText + ucfirst(photo['copycat_what']);
			}

			extraMetaText=extraMetaText+' Remix (';

			var copycat_strength=photo['copycat_strength'];
			var copycat_strength_label = '';
			$('.sidebar select.copycat_strength option').each(function() {
				if ($(this).val() == photo['copycat_strength']) {
					copycat_strength_label = $(this).text().split(' (')[0];
				}
			});
			extraMetaText = extraMetaText + copycat_strength_label + '), ';

		}

		var preprocessedImageAsDataSrc='';

		if(photo['preprocessed_photo_url']) {
			preprocessedImageAsDataSrc='data-preprocessed-src="'+photo['preprocessed_photo_url']+'" ';
		}
		
		var cloudflareCDN='';
		if(!photo['no_cdn']) {
			if(photo['width']<photo['height']) {
				cloudflareCDN='https://resizeapi.com/resize-cgi/image/format=auto,fit=cover,width=720,quality=90/';
			}
			else {
				cloudflareCDN='https://resizeapi.com/resize-cgi/image/format=auto,fit=cover,height=720,quality=90/';
			}
		}

		
		// <make sure placeholder and processing photos show the right dimensions>
			console.log('status='+photo['status']);
			if(
				photo['status']=='preliminary' ||
				photo['status']=='processing' /* actually it's queued from server after take-photo but it is turned into processing quickly */
			) {
				cloudflareCDN='https://resizeapi.com/resize-cgi/image/format=auto,fit=cover,width='+photo['width']+',height='+photo['height']+',quality=90/';
				console.log('cloudflareCDN='+cloudflareCDN);
			}
		// </make sure placeholder and processing photos show the right dimensions>



		var copyPromptLabel = photo['example'] ? 'Try prompt' : 'Copy prompt';
		var actionCopyPromptHtml='<br/><div class="action-copy-prompt">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>'+copyPromptLabel+'</div>';
		var actionCopycatHTML='';

		if(!photo['three_d'] && !photo['video']) {
			var actionCopycatHTML='<div class="action-copycat">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Remix</div>';
		}

		var outputImageButtonsHtml=
			'<div class="action-download-image">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Download</div>'+
			'<div class="action-view-image">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>View</div>'+
			actionCopycatHTML+
			// '<div class="action-google-lens">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Google Lens</div>'+

			// '<div class="action-google-lens">'+'<span></span>'+'<br/>Find clothes</div><br/>'+
			actionCopyPromptHtml;



		// if($(window).width()>800 && !photo['example']) {
		// 	outputImageButtonsHtml=outputImageButtonsHtml
		// 								+'<div class="action-carbon-copy">'+'<span></span>'+'<br/>Carbon copy</div>';
		// }
		if(
			!photo['video'] &&
			!photo['three_d']
		) {
			outputImageButtonsHtml=outputImageButtonsHtml
				+'<div class="action-inpaint">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Magic edit</div>';
		}

					var outputImageButtonsHtml=
			'<div class="action-download-image">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Download</div>'+
				'<div class="action-view-image">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>View</div>'
			;
		

		
		if(
			!(photo['upscaled'] && photo['api']=='clarity_on_fal') /* upscaled before but not with Clarity so allow */ &&
			!photo['three_d'] &&
			!photo['video']
		) {
			if(photo['upscaled'] && photo['upscaled']!=2) {
				var outputImageButtonsHtml=outputImageButtonsHtml+
					'<div class="action-upscale">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Upscale 4x</div>';
			}
			else {
				var outputImageButtonsHtml=outputImageButtonsHtml+
					'<div class="action-upscale">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Upscale</div>';
			}
		}
		
		/*
		problems with videoo upscaler reaching limits with 2.5 turbo "The output video resolution exceeds 4K limits (3840x2160)."
		if(photo['video'] && !photo['upscaled']) {
			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-upscale">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Upscale</div>';
		}*/

		// 2025-12-16: we now have audio built into the video model so we can hide this and maybe remove functionality later
		// if(photo['video']) {
		// 	var outputImageButtonsHtml=outputImageButtonsHtml+
		// 		'<div class="action-add-audio">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Add audio</div>';
		// }
		
		if(
			!photo['video'] && !photo['three_d']
		) {
			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-relight">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Relight</div>';

			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-add-grain">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Add grain</div>';

		}


		if(!photo['three_d']) {
			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-make-video">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>'+(photo['video'] ? 'Make another video' : 'Make video')+'</div>'
		}

		// Show "Extend video" button only for videos
		if(photo['video']) {
			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-extend-video">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Extend video</div>'
		}

		if(
			!photo['video'] &&
			!photo['three_d']
		) {
			var outputImageButtonsHtml=outputImageButtonsHtml+
				'<div class="action-make-3d-model">'+'<span class="circle"><span class="icon"></span></span>'+'<br/>Make 3d</div>';
		}

		
		var agoText='';

		

		extraMetaText=extraMetaText+agoText+tookText;

		if(photo['relight']) {
			var relightPrompt = photo['relight_prompt'] || '';
			if (relightPrompt.length > 100) {
				relightPrompt = relightPrompt.substring(0, 100) + '...';
			}
			extraMetaText = extraMetaText + '<br/>Relight: <b>"' + relightPrompt + '"</b><br/>';
		}
		if(photo['ai_edit']) {
			var aiEditPrompt = photo['ai_edit_prompt'] || '';
			if (aiEditPrompt.length > 100) {
				aiEditPrompt = aiEditPrompt.substring(0, 100) + '...';
			}
			extraMetaText = extraMetaText + '<br/>Magic edit: <b>"' + aiEditPrompt + '"</b><br/>';
		}
		if(photo['inpaint']) {
			var inpaintPrompt = photo['inpaint_prompt'] || '';
			if (inpaintPrompt.length > 100) {
				inpaintPrompt = inpaintPrompt.substring(0, 100) + '...';
			}
			extraMetaText = extraMetaText + '<br/>Brush edit: <b>"' + inpaintPrompt + '"</b><br/>';
		}

		if(photo['video']) {
			if(photo['talking_video'] && photo['talking_video_script']) {
				// This is a talking video, show script
				var talkingVideoScript = photo['talking_video_script'];
				if (talkingVideoScript.length > 50) {
					talkingVideoScript = talkingVideoScript.substring(0, 90) + '...';
				}
				extraMetaText = extraMetaText + '<br/>Talking script: <b>"' + talkingVideoScript + '"</b><br/>';
			}
			else if(photo['audio'] && photo['audio_prompt']) {
				// This is an audio-enhanced video, show audio prompt
				var audioPrompt = photo['audio_prompt'];
				if (audioPrompt.length > 50) {
					audioPrompt = audioPrompt.substring(0, 90) + '...';
				}
				extraMetaText = extraMetaText + '<br/>Audio: <b>"' + audioPrompt + '"</b><br/>';
			} else {
				// Regular video, show video prompt
				var manualVideoPrompt;
				if(photo['manual_video_prompt']) {
					manualVideoPrompt = photo['manual_video_prompt'];
				}
				else if(photo['manual_prompt']) {
					// for pre 2025-07-14 when video prompt was in manual_prompt
					manualVideoPrompt = photo['manual_prompt'];
				}
				if (manualVideoPrompt && manualVideoPrompt.length > 50) {
					manualVideoPrompt = manualVideoPrompt.substring(0, 90) + '...';
				}
				if(photo['extend_video'] && manualVideoPrompt) {
					extraMetaText = extraMetaText + '<br/>Extend video: <b>"' + manualVideoPrompt + '"</b><br/>';
				}
				else if (manualVideoPrompt) {
					extraMetaText = extraMetaText + '<br/>Video prompt: <b>"' + manualVideoPrompt + '"</b><br/>';
				}
			}
		}



