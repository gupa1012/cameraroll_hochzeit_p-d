	/* Grid size slider override (dashboard only, not template pages) */
	html.logged-in[data-grid-cols]:not(.template) .div_output_image,
	html.logged-in[data-grid-cols]:not(.template) .div_template,
	html.logged-in[data-grid-cols]:not(.template) .div_pose {
		width: calc(100% / var(--grid-cols) - 14px) !important;
	}
	.grid_size_slider_wrap {
		display: flex;
		align-items: center;
		margin-left: auto;
		gap: 6px;
		padding: 0 10px;
	}
	.grid_size_slider_wrap span {
		font-size: 12px;
		opacity: 0.5;
	}
	.grid_size_slider {
		-webkit-appearance: initial;
		width: 100px;
		cursor: pointer;
		accent-color: #fff;
		padding: 0;
		border-radius: 12px;
		font-size: inherit;
	}
	@media (max-width: 800px) {
		.grid_size_slider_wrap {
			display: none;
		}
	}

	@media (max-width: 1400px) {
		html:not(.guest) .div_pose,
		html:not(.guest) .div_template,
		html:not(.guest) .div_output_image {
/*			width: calc(100% / 3 - 14px - 14px);*/
			width: calc(100% / 3 - 7px - 7px);
		}
		html.guest .div_output_image,
		html.guest .div_template,
		html.template .div_output_image {
			width: calc(100% / 4 - 7px - 7px);
		}
	}

	@media (max-width: 1100px) {
		html:not(.guest) .div_pose,
		html:not(.guest) .div_template,
		html:not(.guest) .div_output_image {
/*			width: calc(100% / 2 - 14px - 14px);*/
			width: calc(100% / 2 - 7px - 7px);
		}
		html.guest .div_output_image,
		html.guest .div_template,
		html.template .div_output_image {
			width: calc(100% / 3 - 7px - 7px);
		}
	}

	@media (max-width: 600px) {
		html:not(.guest) .div_pose,
		html:not(.guest) .div_template,
		html:not(.guest) .div_output_image {
			width: calc(100% - 14px) !important;
		}
		html.guest .div_template {
			width: calc(100% / 2 - 7px - 7px);
		}
