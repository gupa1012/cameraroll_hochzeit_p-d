<style>
    .countdown-timer-bar {
        width: 100%;
        background: var(--gradient);
        background-size: 300% 300%;
        animation: animatedgradient 6s ease infinite alternate;
        color: #fff;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 10000;
        font-size: 13px;
        height: 50px;
        padding: 0 21px;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: none;
        box-shadow: none;
        cursor: pointer;
        text-decoration: none;
    }
    .countdown-timer-bar:hover {
        opacity: 0.9;
    }
    .countdown-timer-bar .ticker-track {
        display: flex;
        animation: banner-ticker 30s linear infinite;
        white-space: nowrap;
    }
    .countdown-timer-bar:hover .ticker-track {
        animation-play-state: paused;
    }
    @keyframes banner-ticker {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .countdown-timer-bar .timer-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        flex-direction: row;
        text-align: center;
        height: 100%;
        padding: 0 24px;
        flex-shrink: 0;
    }
    .countdown-timer-bar .countdown-display {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin: 0 6px 0 0;
        height: 100%;
    }
    .countdown-timer-bar .time-digit {
        background: rgba(0,0,0,0.2);
        border-radius: 2px;
        padding: 0 3px;
        min-width: 16px;
        text-align: center;
        letter-spacing: 1px;
        font-size: 13px;
        font-family: monospace;
        height: 20px;
        line-height: 20px;
        display: inline-block;
        margin: 0 0.5px;
    }
    .countdown-timer-bar .time-separator {
        margin: 0 1px;
        font-size: 13px;
        font-family: monospace;
        line-height: 20px;
        color: #fff;
    }
    .countdown-timer-bar .offer-text {
        color: #fff;
        display: inline-block;
        font-size: 12px;
        line-height: 1;
        margin: 0 8px 0 0;
        white-space: nowrap;
        vertical-align: middle;
    }
    .countdown-timer-bar .highlight-text {
        font-weight: 600;
        display: inline-block;
        font-size: 12px;
        margin-left: 4px;
        vertical-align: middle;
    }
    .countdown-timer-bar .claim-button {
        background: #fff;
        color: #222;
        border-radius: 4px;
        padding: 2px 7px;
        font-size: 11px;
        font-weight: 600;
        box-shadow: 0 1px 2px rgba(0,0,0,0.07);
        border: none;
        cursor: pointer;
        display: inline-block;
        height: 22px;
        line-height: 18px;
        vertical-align: middle;
    }
    .header {
        position: fixed !important;
        top: 50px !important;
    }
    @media (max-width:600px) {
        .countdown-timer-bar {
            font-size: 11px;
            height: 28px;
            padding: 0 2px;
        }
        .countdown-timer-bar .timer-container {
            gap: 3px;
        }
        .countdown-timer-bar .countdown-display {
            margin: 0 2px 0 0;
        }
        .countdown-timer-bar .time-digit,
        .countdown-timer-bar .time-separator {
            font-size: 11px;
            height: 16px;
            line-height: 16px;
            min-width: 12px;
            padding: 0 2px;
        }
        .countdown-timer-bar .offer-text {
            font-size: 10px;
            margin: 0 3px 0 0;
        }
        .countdown-timer-bar .highlight-text {
            font-size: 10px;
            margin-left: 2px;
        }
        .countdown-timer-bar .claim-button {
            font-size: 10px;
            padding: 1px 4px;
            height: 16px;
            line-height: 13px;
        }
        .header {
            position: fixed !important;
            top: 28px !important;
        }
    }
</style>
